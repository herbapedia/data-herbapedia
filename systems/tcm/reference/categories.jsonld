    "zh-Hant": "中藥分類",
    "zh-Hans": "中药分类"
  },
  "description": {
    "en": "Functional categories of Chinese herbs based on primary therapeutic action. Categories are organized by treatment principle.",
    "zh-Hant": "根據主要治療作用劃分的中藥功能分類。"
  },
  "members": [
    {
      "@id": "https://www.herbapedia.org/system/tcm/category/release-exterior",
      "name": {
        "en": "Release Exterior",
        "zh-Hant": "解表藥",
        "zh-Hans": "解表药"
      },
      "pinyin": "Jiě Biǎo Yào",
      "categoryCode": "01",
      "description": {
        "en": "Releases the exterior, treats exterior patterns (wind-cold or wind-heat).",
        "zh-Hant": "發散表邪，治療表證（風寒或風熱）。"
      },
      "indications": {
        "en": "Common cold, flu, early stage exterior invasion"
      },
      "subcategories": [
        {
          "@id": "https://www.herbapedia.org/system/tcm/category/acrid-warm-release"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/category/acrid-cool-release"
        }
      ],
      "exampleHerbs": [
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/mahuang"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/guizhi"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/mint"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/chrysanthemum"
        }
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/tcm/category/clear-heat",
      "name": {
