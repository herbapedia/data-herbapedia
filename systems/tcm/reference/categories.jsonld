    {
      "@id": "https://www.herbapedia.org/system/tcm/category/dispel-wind-damp",
      "name": {
        "en": "Dispel Wind-Damp",
        "zh-Hant": "祛風濕藥",
        "zh-Hans": "祛风湿药"
      },
      "pinyin": "Qū Fēng Shī Yào",
      "categoryCode": "04",
      "description": {
        "en": "Dispels wind-damp, treats bi syndrome (painful obstruction).",
        "zh-Hant": "祛風除濕，治療痹證。"
      },
      "indications": {
        "en": "Arthritis, joint pain, bi syndrome"
      },
      "exampleHerbs": [
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/duhuo"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/qinjiao"
