      "name": {
        "en": "Purgative",
        "zh-Hant": "瀉下藥",
        "zh-Hans": "泻下药"
      },
      "pinyin": "Xiè Xià Yào",
      "categoryCode": "03",
      "description": {
        "en": "Promotes bowel movement, treats constipation and accumulation.",
        "zh-Hant": "通導大便，治療便秘和積滯。"
      },
      "indications": {
        "en": "Constipation, accumulation, excess patterns"
