      "pinyin": "Huà Shī Yào",
      "categoryCode": "05",
      "description": {
        "en": "Transforms dampness, awakens the spleen.",
        "zh-Hant": "芳香化濕，醒脾。"
      },
      "indications": {
        "en": "Dampness obstructing spleen, digestive disorders"
