{
  "@context": "https://www.herbapedia.org/schema/context/tcm.jsonld",
  "@id": "https://www.herbapedia.org/system/tcm/profile/reference/flavors",
  "@type": [
    "tcm:ReferenceCollection",
    "skos:Collection"
  ],
  "name": {
    "en": "TCM Five Flavors",
    "zh-Hant": "五味",
    "zh-Hans": "五味"
  },
  "description": {
    "en": "The five flavors (五味) in Traditional Chinese Medicine. Each flavor has specific therapeutic functions and corresponds to one of the Five Elements.",
    "zh-Hant": "中藥的五味，每種味道有特定的治療功能，對應五行。"
  },
  "members": [
    {
      "@id": "https://www.herbapedia.org/system/tcm/flavor/sweet",
      "@type": [
        "tcm:Flavor"
      ],
      "name": {
        "en": "Sweet",
        "zh-Hant": "甘",
        "zh-Hans": "甘"
      },
      "pinyin": "Gān",
      "fiveElement": "earth",
      "associatedOrgan": "Spleen",
      "qiDirection": "ascending",
      "description": {
        "en": "Tonifies, harmonizes, moistens. Often used for deficiency patterns.",
        "zh-Hant": "補益、調和、潤燥。常用於虛證。"
      },
      "functions": {
        "en": "Tonifies qi and blood, nourishes yin, harmonizes other herbs, relieves pain, moistens dryness",
        "zh-Hant": "補氣血，養陰，調和諸藥，緩急止痛，潤燥"
      },
      "effectOnQi": {
        "en": "Supplements, moistens, harmonizes"
      },
      "exampleHerbs": [
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/ren-shen"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/gan-cao"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/da-zao"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/dang-gui"
        }
      ],
      "contraindications": {
        "en": "Dampness, stagnation, excess conditions"
      }
    },
    {
      "@id": "https://www.herbapedia.org/system/tcm/flavor/sour",
      "@type": [
        "tcm:Flavor"
      ],
      "name": {
        "en": "Sour",
        "zh-Hant": "酸",
        "zh-Hans": "酸"
      },
      "pinyin": "Suān",
      "fiveElement": "wood",
      "associatedOrgan": "Liver",
      "qiDirection": "gathering",
      "description": {
        "en": "Astringes, consolidates, generates fluids. Often used for leakage patterns.",
        "zh-Hant": "收斂、固澀、生津。常用於滑脫之證。"
      },
      "functions": {
        "en": "Astringes and consolidates, generates fluids, calms the liver",
        "zh-Hant": "收斂固澀，生津，平肝"
      },
      "effectOnQi": {
        "en": "Astringes, consolidates, absorbs"
      },
      "exampleHerbs": [
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/wumei"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/wuweizi"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/shanzhuyu"
        }
      ],
      "contraindications": {
        "en": "Early stage exterior patterns, stagnation"
      }
    },
    {
      "@id": "https://www.herbapedia.org/system/tcm/flavor/salty",
      "@type": [
        "tcm:Flavor"
      ],
      "name": {
        "en": "Salty",
        "zh-Hant": "鹹",
        "zh-Hans": "咸"
      },
      "pinyin": "Xián",
      "fiveElement": "water",
      "associatedOrgan": "Kidney",
      "qiDirection": "descending",
      "description": {
        "en": "Softens hardness, purges, enters kidney channel. Often used for masses.",
        "zh-Hant": "軟堅、瀉下、入腎經。常用於癥瘕積聚。"
      },
      "functions": {
        "en": "Softens hard masses, purges bowels, clears heat, enters kidney",
        "zh-Hant": "軟堅散結，瀉下，清熱，入腎"
      },
      "effectOnQi": {
        "en": "Softens, descends, purges"
      },
      "exampleHerbs": [
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/haizao"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/kunbu"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/mangxiao"
        }
      ],
      "contraindications": {
        "en": "Kidney deficiency, edema from deficiency"
      }
    },
    {
      "@id": "https://www.herbapedia.org/system/tcm/flavor/pungent",
      "@type": [
        "tcm:Flavor"
      ],
      "name": {
        "en": "Pungent/Acrid",
        "zh-Hant": "辛",
        "zh-Hans": "辛"
      },
      "pinyin": "Xīn",
      "fiveElement": "metal",
      "associatedOrgan": "Lung",
      "qiDirection": "dispersing",
      "description": {
        "en": "Disperses, promotes circulation, resolves stagnation. Often used for exterior patterns.",
        "zh-Hant": "發散、行氣、活血。常用於表證。"
      },
      "functions": {
        "en": "Disperses exterior, promotes qi and blood circulation, resolves stagnation",
        "zh-Hant": "發散解表，行氣活血，化濕"
      },
      "effectOnQi": {
        "en": "Disperses, moves, opens"
      },
      "exampleHerbs": [
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/mahuang"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/guizhi"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/sheng-jiang"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/chuanxiong"
        }
      ],
      "contraindications": {
        "en": "Qi deficiency, yin deficiency, sweating from deficiency"
      }
    },
    {
      "@id": "https://www.herbapedia.org/system/tcm/flavor/acrid",
      "@type": [
        "tcm:Flavor",
        "tcm:FlavorAlias"
      ],
      "name": {
        "en": "Acrid",
        "zh-Hant": "辛",
        "zh-Hans": "辛"
      },
      "pinyin": "Xīn",
      "sameAs": {
        "@id": "https://www.herbapedia.org/system/tcm/flavor/pungent"
      },
      "description": {
        "en": "Alias for pungent flavor. Disperses, promotes circulation, resolves stagnation."
      }
    },
    {
      "@id": "https://www.herbapedia.org/system/tcm/flavor/bitter",
      "@type": [
        "tcm:Flavor"
      ],
      "name": {
        "en": "Bitter",
        "zh-Hant": "苦",
        "zh-Hans": "苦"
      },
      "pinyin": "Kǔ",
      "fiveElement": "fire",
      "associatedOrgan": "Heart",
      "qiDirection": "descending",
      "description": {
        "en": "Drains, dries, clears heat. Often used for excess heat or dampness.",
        "zh-Hant": "洩、燥、清熱。常用於實熱或濕證。"
      },
      "functions": {
        "en": "Clears heat, drains dampness, purges, dries, descends qi",
        "zh-Hant": "清熱，燥濕，瀉火，降氣"
      },
      "effectOnQi": {
        "en": "Drains, descends, dries"
      },
      "exampleHerbs": [
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/huanglian"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/huangqin"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/dahuang"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/zhizi"
        }
      ],
      "contraindications": {
        "en": "Qi deficiency, yin deficiency, spleen deficiency"
      }
    },
    {
      "@id": "https://www.herbapedia.org/system/tcm/flavor/astringent",
      "@type": [
        "tcm:Flavor"
      ],
      "name": {
        "en": "Astringent",
        "zh-Hant": "澀",
        "zh-Hans": "涩"
      },
      "pinyin": "Sè",
      "fiveElement": "wood",
      "associatedOrgan": "Liver",
      "qiDirection": "gathering",
      "description": {
        "en": "Often paired with sour. Astringes and consolidates.",
        "zh-Hant": "常與酸味並稱，收斂固澀。"
      },
      "functions": {
        "en": "Astringes, consolidates, prevents leakage",
        "zh-Hant": "收斂，固澀，止漏"
      },
      "effectOnQi": {
        "en": "Astringes, consolidates"
      },
      "exampleHerbs": [
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/muli"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/muli"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/chishizhi"
        }
      ],
      "contraindications": {
        "en": "Stagnation, excess patterns"
      },
      "notes": "Often considered a secondary flavor, paired with sour"
    },
    {
      "@id": "https://www.herbapedia.org/system/tcm/flavor/bland",
      "@type": [
        "tcm:Flavor"
      ],
      "name": {
        "en": "Bland",
        "zh-Hant": "淡",
        "zh-Hans": "淡"
      },
      "pinyin": "Dàn",
      "fiveElement": "earth",
      "associatedOrgan": "Spleen",
      "qiDirection": "descending",
      "description": {
        "en": "Promotes urination, leaches out dampness. Often paired with sweet.",
        "zh-Hant": "利尿，滲濕。常與甘味並稱。"
      },
      "functions": {
        "en": "Promotes urination, leaches out dampness",
        "zh-Hant": "利尿，滲濕"
      },
      "effectOnQi": {
        "en": "Leaches, drains"
      },
      "exampleHerbs": [
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/fuling"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/zexie"
        },
        {
          "@id": "https://www.herbapedia.org/system/tcm/profile/jobs-tears"
        }
      ],
      "contraindications": {
        "en": "Yin deficiency, fluid deficiency"
      },
      "notes": "Considered a variation of sweet, 'bland leaches dampness'"
    }
  ],
  "_documentation": {
    "classicalReference": "《素問·藏氣法時論》：'辛散、酸收、甘緩、苦堅、鹹軟。'",
    "clinicalApplication": "五味與五行、五臟相應：甘入脾，酸入肝，鹹入腎，辛入肺，苦入心。",
    "combination": "藥物常具多種味道，如'辛苦溫'、'甘苦寒'等配伍。"
  }
}
