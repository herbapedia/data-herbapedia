      },
      "associatedHumor": "dam",
      "characteristics": [
        "Hot and moist",
        "Subtle and light",
        "Expansive",
        "Moving in all directions"
      ],
      "organs": [
        "Lungs",
        "Brain"
      ],
      "seasons": [
        "Spring"
      ],
      "ages": [
        "Childhood"
      ],
