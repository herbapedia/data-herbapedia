  "name": {
    "en": "Unani Four Elements",
    "fa": "چهار عنصر"
  },
  "description": {
    "en": "The four elements (عناصر أربعة - Anasir al-Arba'a) in Traditional Unani Medicine. All substances are composed of these elements in varying proportions."
  },
  "members": [
    {
      "@id": "https://www.herbapedia.org/system/unani/profile/element/fire",
      "@type": [
        "unani:Element"
      ],
      "name": {
        "en": "Fire",
        "fa": "آتش",
        "ar": "نار"
      },
      "unaniName": "آتش",
      "arabicName": "نار",
      "transliteration": "Atash",
      "qualities": {
        "heat": "hot",
        "moisture": "dry"
      },
      "associatedTemperament": {
        "@id": "https://www.herbapedia.org/system/unani/profile/temperament/hot-dry"
      },
      "associatedHumor": "safra",
      "characteristics": [
        "Hot and dry to the highest degree",
        "Transformative",
        "Subtle and light",
        "Rising upward"
      ],
      "organs": [
        "Heart",
        "Liver"
      ],
      "seasons": [
        "Summer"
      ],
      "ages": [
        "Youth",
        "Prime of life"
      ],
      "description": {
        "en": "Fire is hot and dry, associated with transformation, lightness, and upward movement. It corresponds to yellow bile humor."
      }
    },
