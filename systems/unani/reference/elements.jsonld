  "_documentation": {
    "classicalReference": "Derived from Greek medicine (Empedocles, Hippocrates, Galen) via Islamic medicine",
    "humors": {
      "fire": "Safra (Yellow Bile) - Hot/Dry",
      "air": "Dam (Blood) - Hot/Wet",
      "water": "Balgham (Phlegm) - Cold/Wet",
      "earth": "Sauda (Black Bile) - Cold/Dry"
    },
    "composition": "All substances contain all four elements, but in different proportions"
  }
