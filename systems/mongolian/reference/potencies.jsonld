        "@id": "https://www.herbapedia.org/system/mongolian/profile/potency/light"
      },
      "pairNumber": 1,
      "effectOnRoots": {
        "heyi": "decreases",
        "xila": "decreases",
        "badagan": "increases"
      },
      "physiologicalEffect": {
        "en": "Grounds, stabilizes, promotes sleep, nourishes tissues"
      },
      "indications": [
        "vata disorders",
