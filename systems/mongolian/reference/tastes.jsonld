  "_documentation": {
    "classicalReference": "Four Tantras (རྒྱུད་བཞི་), explanatory tantra",
    "postDigestive": "After digestion, tastes transform: Sweet/Salty → Sweet; Sour → Sour; Pungent/Bitter/Astringent → Pungent",
    "clinicalNote": "Taste is the first quality perceived; potency (nūs-po) is the post-digestive effect"
  }
