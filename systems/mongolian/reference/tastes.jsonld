  "name": {
    "en": "Mongolian Six Tastes",
    "mn": "Зургаан амт"
  },
  "description": {
    "en": "The Six Tastes (Зургаан амт - Zurgaan Amt) in Mongolian Traditional Medicine. Each taste has specific effects on the Three Roots and correspond to element combinations."
  },
  "members": [
    {
      "@id": "https://www.herbapedia.org/system/mongolian/profile/taste/sweet",
      "@type": [
        "mongolian:Taste"
      ],
      "name": {
        "en": "Sweet",
        "mn": "амттай",
        "bo": "མངར་"
      },
      "mongolianName": "амттай",
      "tibetanName": "མངར་",
      "tibetanWylie": "mngar",
      "englishName": "Sweet",
      "elementComposition": [
        {
          "element": "earth",
          "proportion": "primary"
        },
        {
          "element": "water",
          "proportion": "secondary"
        }
      ],
      "effectOnRoots": {
        "heyi": "decreases",
        "xila": "decreases",
        "badagan": "increases"
      },
      "therapeuticActions": [
        "nourishes",
        "builds tissues",
        "promotes strength"
      ],
      "indications": [
        "emaciation",
        "weakness",
        "vata disorders"
      ],
      "excessEffects": [
        "obesity",
        "diabetes",
        "kapha disorders"
      ],
      "exampleSubstances": [
        "sugar",
        "honey",
        "licorice",
        "grains"
