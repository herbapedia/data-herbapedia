    {
      "@id": "https://www.herbapedia.org/system/western/action/cholagogue",
      "@type": [
        "western:Action"
      ],
      "name": {
        "en": "Cholagogue",
        "zh-Hant": "利膽",
        "zh-Hans": "利胆"
      },
      "description": {
        "en": "Promotes the flow of bile from the gallbladder to the intestines."
      },
      "physiologicalEffect": {
        "en": "Stimulates bile release, aids fat digestion"
      },
      "mechanism": {
        "en": "Bitter principles stimulate release of cholecystokinin"
      },
      "bodySystem": [
        "digestive"
      ],
      "evidenceLevel": "moderate",
      "clinicalIndications": [
        "gallbladder dysfunction",
        "fat malabsorption",
        "constipation"
