        "en": "Anodyne (Analgesic)",
        "zh-Hant": "止痛",
        "zh-Hans": "止痛"
      },
      "description": {
        "en": "Relieves pain without causing unconsciousness."
      },
      "physiologicalEffect": {
        "en": "Reduces pain perception, blocks pain signals"
      },
      "mechanism": {
        "en": "Various: opioid receptor interaction, anti-inflammatory, prostaglandin inhibition"
      },
      "bodySystem": [
        "nervous",
        "musculoskeletal"
      ],
      "evidenceLevel": "moderate",
      "clinicalIndications": [
        "pain",
        "headache",
        "neuralgia",
        "arthritis"
