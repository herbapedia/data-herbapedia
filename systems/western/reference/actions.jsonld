      "description": {
        "en": "Supports liver function, protects hepatocytes, and promotes bile flow."
      },
      "physiologicalEffect": {
        "en": "Enhances liver detoxification, promotes bile secretion, protects liver cells"
      },
      "mechanism": {
        "en": "Upregulates detoxification enzymes, antioxidant protection, membrane stabilization"
      },
      "bodySystem": [
        "digestive"
      ],
      "evidenceLevel": "moderate",
      "clinicalIndications": [
