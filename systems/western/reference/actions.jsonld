  "members": [
    {
      "@id": "https://www.herbapedia.org/system/western/action/carminative",
      "@type": [
        "western:Action"
      ],
      "name": {
        "en": "Carminative",
        "zh-Hant": "驅風",
        "zh-Hans": "驱风"
      },
      "description": {
        "en": "Relieves flatulence and digestive discomfort by expelling gas from the stomach and intestines."
      },
      "physiologicalEffect": {
        "en": "Relaxes smooth muscle of digestive tract, reduces gas formation"
      },
      "mechanism": {
        "en": "Volatile oils stimulate peristalsis and relax intestinal spasms"
      },
      "bodySystem": [
        "digestive"
      ],
      "evidenceLevel": "strong",
      "clinicalIndications": [
        "indigestion",
        "bloating",
        "flatulence",
        "colic"
      ],
      "keyHerbs": [
        {
          "@id": "https://www.herbapedia.org/entity/preparation/ginger"
        },
        {
          "@id": "https://www.herbapedia.org/entity/preparation/peppermint"
        },
        {
          "@id": "https://www.herbapedia.org/entity/preparation/fennel"
        }
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/western/action/spasmolytic",
      "@type": [
        "western:Action"
      ],
      "name": {
        "en": "Spasmolytic (Antispasmodic)",
        "zh-Hant": "解痙",
        "zh-Hans": "解痉"
      },
      "description": {
        "en": "Relieves smooth muscle spasms, particularly in the digestive, respiratory, and urinary tracts."
      },
      "physiologicalEffect": {
        "en": "Relaxes smooth muscle contractions, reduces cramping"
      },
      "mechanism": {
        "en": "Various mechanisms including calcium channel blocking, anticholinergic effects"
      },
      "bodySystem": [
        "digestive",
        "respiratory",
        "urinary"
      ],
      "evidenceLevel": "strong",
      "clinicalIndications": [
        "muscle cramps",
        "asthma",
        "irritable bowel syndrome",
        "dysmenorrhea"
      ],
      "keyHerbs": [
        {
          "@id": "https://www.herbapedia.org/entity/preparation/valerian"
        },
        {
          "@id": "https://www.herbapedia.org/entity/preparation/cramp-bark"
        },
        {
          "@id": "https://www.herbapedia.org/entity/preparation/wild-yam"
        }
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/western/action/anti-inflammatory",
      "@type": [
        "western:Action"
      ],
      "name": {
        "en": "Anti-inflammatory",
        "zh-Hant": "抗炎",
        "zh-Hans": "抗炎"
      },
      "description": {
        "en": "Reduces inflammation and inflammatory processes in the body."
      },
      "physiologicalEffect": {
        "en": "Inhibits pro-inflammatory mediators (COX, LOX, cytokines)"
      },
      "mechanism": {
        "en": "Various: COX inhibition, NF-κB modulation, antioxidant activity"
      },
      "bodySystem": [
        "immune",
        "musculoskeletal",
        "cardiovascular"
      ],
      "evidenceLevel": "strong",
      "clinicalIndications": [
        "arthritis",
        "tendonitis",
        "inflammatory bowel disease",
        "dermatitis"
      ],
      "keyHerbs": [
        {
          "@id": "https://www.herbapedia.org/entity/preparation/turmeric"
        },
        {
          "@id": "https://www.herbapedia.org/entity/preparation/boswellia"
        },
        {
          "@id": "https://www.herbapedia.org/entity/preparation/ginger"
        }
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/western/action/antioxidant",
      "@type": [
        "western:Action"
      ],
      "name": {
        "en": "Antioxidant",
        "zh-Hant": "抗氧化",
        "zh-Hans": "抗氧化"
      },
      "description": {
        "en": "Neutralizes free radicals and protects cells from oxidative damage."
      },
      "physiologicalEffect": {
        "en": "Scavenges reactive oxygen species, supports endogenous antioxidants"
      },
      "mechanism": {
        "en": "Polyphenols, flavonoids, vitamins C and E, glutathione support"
      },
      "bodySystem": [
        "cardiovascular",
        "nervous",
        "immune"
      ],
      "evidenceLevel": "strong",
      "clinicalIndications": [
        "cardiovascular disease prevention",
        "cognitive decline",
        "premature aging"
      ],
      "keyHerbs": [
        {
          "@id": "https://www.herbapedia.org/entity/preparation/green-tea"
