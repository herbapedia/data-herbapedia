  "@type": [
    "western:ReferenceCollection",
    "skos:Collection"
  ],
  "name": {
    "en": "Western Body Systems"
  },
  "description": {
    "en": "Major physiological systems of the human body as understood by biomedical science. Used for categorizing herbs by their primary system affinity."
  },
  "members": [
    {
      "@id": "https://www.herbapedia.org/system/western/profile/system/digestive",
      "@type": [
        "western:System"
      ],
      "name": {
        "en": "Digestive System"
      },
      "description": {
        "en": "The digestive system breaks down food into nutrients, absorbs them into the bloodstream, and eliminates waste. Includes mouth, esophagus, stomach, intestines, liver, gallbladder, and pancreas."
      },
      "components": [
        {
          "@id": "https://www.herbapedia.org/system/western/organ/stomach"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/organ/small-intestine"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/organ/large-intestine"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/organ/liver"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/organ/gallbladder"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/organ/pancreas"
        }
      ],
      "functions": [
        "digestion",
        "absorption",
        "elimination",
        "detoxification"
      ],
      "associatedActions": [
        {
          "@id": "https://www.herbapedia.org/system/western/action/carminative"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/action/cholagogue"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/action/hepatic"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/action/spasmolytic"
        }
      ],
      "commonConditions": [
        "indigestion",
        "gastritis",
        "IBS",
        "constipation",
        "liver disease"
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/western/profile/system/nervous",
      "@type": [
        "western:System"
      ],
      "name": {
        "en": "Nervous System"
      },
      "description": {
        "en": "The nervous system controls all body functions through electrical signals. Includes brain, spinal cord, peripheral nerves, and sensory organs."
      },
      "components": [
        {
          "@id": "https://www.herbapedia.org/system/western/organ/brain"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/organ/spinal-cord"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/organ/peripheral-nerves"
        }
      ],
      "functions": [
        "cognition",
        "sensation",
        "movement",
        "autonomic regulation",
        "mood"
      ],
      "associatedActions": [
        {
          "@id": "https://www.herbapedia.org/system/western/action/nervine"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/action/anodyne"
        },
        {
          "@id": "https://www.herbapedia.org/system/western/action/adaptogen"
        }
      ],
      "commonConditions": [
        "anxiety",
        "depression",
        "insomnia",
        "neuropathy",
        "headache"
      ]
    },
    {
