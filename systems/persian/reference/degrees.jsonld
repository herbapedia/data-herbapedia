{
  "@context": "https://www.herbapedia.org/schema/context/persian.jsonld",
  "@id": "https://www.herbapedia.org/system/persian/profile/reference/degrees",
  "@type": [
    "persian:ReferenceCollection",
    "skos:Collection"
  ],
  "name": {
    "en": "Persian Four Degrees",
    "fa": "چهار درجه"
  },
  "description": {
    "en": "The four degrees (درجه - Darajah) of potency in Traditional Persian Medicine. Each degree indicates the strength of a substance's temperament effect, from mild (1st) to very strong (4th)."
  },
  "members": [
    {
      "@id": "https://www.herbapedia.org/system/persian/profile/degree/1",
      "@type": [
        "persian:Degree"
      ],
      "name": {
        "en": "First Degree",
        "fa": "درجه اول"
      },
      "persianName": "درجه اول",
      "degree": 1,
      "therapeuticStrength": "mild",
      "description": {
        "en": "Mild potency. Safe for regular consumption, suitable for food and gentle medicine. Effects are subtle but cumulative."
      },
      "safetyProfile": {
        "en": "Very safe. Can be used freely by most people including children, elderly, and those with sensitive constitutions."
      },
      "usageGuidelines": {
        "en": "May be consumed regularly as food or mild remedy. No special precautions needed."
      },
      "exampleSubstances": [
        "Chamomile (warm 1st)",
        "Fennel (warm 1st)",
        "Coriander (cool 1st)",
        "Barley (cool 1st)"
      ],
      "cautions": [],
      "correctivesNeeded": false
    },
    {
      "@id": "https://www.herbapedia.org/system/persian/profile/degree/2",
      "@type": [
        "persian:Degree"
      ],
      "name": {
        "en": "Second Degree",
        "fa": "درجه دوم"
      },
      "persianName": "درجه دوم",
      "degree": 2,
      "therapeuticStrength": "moderate",
      "description": {
        "en": "Moderate potency. Stronger therapeutic effect than food, but generally safe for therapeutic use."
      },
      "safetyProfile": {
        "en": "Generally safe for most adults. Some caution needed with prolonged use or in sensitive individuals."
      },
      "usageGuidelines": {
        "en": "Used as medicine, can be consumed regularly with awareness. Suitable for most therapeutic applications."
      },
      "exampleSubstances": [
        "Ginger (warm 2nd)",
        "Cinnamon (warm 2nd)",
        "Peppermint (cool 2nd)",
        "Rose (cool 2nd)"
      ],
      "cautions": [
        "Avoid in extreme opposite conditions",
        "Use with awareness in pregnancy"
      ],
      "correctivesNeeded": false
    },
    {
      "@id": "https://www.herbapedia.org/system/persian/profile/degree/3",
      "@type": [
        "persian:Degree"
      ],
      "name": {
        "en": "Third Degree",
        "fa": "درجه سوم"
      },
      "persianName": "درجه سوم",
      "degree": 3,
      "therapeuticStrength": "strong",
      "description": {
        "en": "Strong potency. Significant therapeutic effect, requires more careful dosing and may need correctives (Musleh)."
      },
      "safetyProfile": {
        "en": "Requires caution. May cause side effects if used improperly or in sensitive individuals. Often requires correctives."
      },
      "usageGuidelines": {
        "en": "Use therapeutically, not for casual consumption. Follow proper dosing guidelines. May need correctives (Musleh) to prevent side effects."
      },
      "exampleSubstances": [
        "Myrrh (warm 3rd)",
        "Aloe (warm 3rd)",
        "Saffron (balanced 3rd)",
        "Rhubarb (cold 3rd)"
      ],
      "cautions": [
        "Use with professional guidance",
        "Monitor for side effects",
        "Short-term use preferred",
        "May need correctives"
      ],
      "correctivesNeeded": true
    },
    {
      "@id": "https://www.herbapedia.org/system/persian/profile/degree/4",
      "@type": [
        "persian:Degree"
      ],
      "name": {
        "en": "Fourth Degree",
        "fa": "درجه چهارم"
      },
      "persianName": "درجه چهارم",
      "degree": 4,
      "therapeuticStrength": "very-strong",
      "description": {
        "en": "Very strong potency. Powerful therapeutic effect but potentially toxic. Requires expert knowledge, careful dosing, and always requires correctives."
      },
      "safetyProfile": {
        "en": "Potentially toxic. Should only be used by experienced practitioners with proper preparation and correctives. Can cause serious harm if misused."
      },
      "usageGuidelines": {
        "en": "Use ONLY under expert supervision. Always requires correctives (Musleh). Precise dosing essential. Often processed to reduce toxicity."
      },
      "exampleSubstances": [
        "Opium (cold 4th)",
        "Henbane (cold 4th)",
        "Aconite (hot 4th)",
        "Copper sulfate (hot 4th)"
      ],
      "cautions": [
        "EXPERT USE ONLY",
        "Potentially toxic",
        "Always requires correctives",
        "Precise dosing essential",
        "Often requires special preparation"
      ],
      "contraindications": [
        "Pregnancy",
        "Children",
        "Elderly",
        "Weak patients",
        "Without proper corrective"
      ],
      "correctivesNeeded": true
    }
  ],
  "_documentation": {
    "classicalReference": "Ibn Sina (Avicenna), Al-Qanun fi al-Tibb, Book II",
    "correctivesMusleh": "Correctives (Musleh) are substances added to moderate the side effects of strong medicines. For example, honey is often used as a corrective.",
    "principle": "The degree determines both therapeutic power and safety considerations. Higher degrees require more expertise and caution."
  }
}