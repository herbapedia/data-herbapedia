        "sa": "कषाय"
      },
      "sanskritName": "कषाय",
      "sanskritTransliteration": "Kashaya",
      "englishName": "Astringent",
      "elementComposition": [
        {
          "element": "prithvi",
          "proportion": "dominant"
        },
        {
          "element": "vayu",
          "proportion": "secondary"
        }
      ],
      "effectOnDoshas": {
        "vata": "increases",
        "pitta": "decreases",
        "kapha": "decreases"
      },
      "effectOnDigestion": {
        "en": "Binds tissues, dries excess moisture, promotes healing"
      },
      "generalActions": [
        "binds tissues",
        "stops bleeding",
        "dries moisture",
        "promotes healing"
      ],
      "indications": [
        "diarrhea",
        "bleeding",
        "wounds",
        "excess moisture"
      ],
      "excessEffects": {
