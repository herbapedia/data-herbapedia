  "@type": [
    "ayurveda:ReferenceCollection",
    "skos:Collection"
  ],
  "name": {
    "en": "Ayurveda Six Rasas",
    "sa": "षड्रस"
  },
  "description": {
    "en": "The six tastes (षड्रस - Shad Rasa) in Ayurveda. Each taste has specific effects on the doshas and the body."
  },
  "members": [
    {
      "@id": "https://www.herbapedia.org/system/ayurveda/profile/rasa/sweet",
      "@type": [
        "ayurveda:Rasa"
      ],
      "name": {
        "en": "Sweet",
        "sa": "मधुर"
      },
      "sanskritName": "मधुर",
      "sanskritTransliteration": "Madhura",
      "englishName": "Sweet",
      "elementComposition": [
        {
          "element": "prithvi",
          "proportion": "dominant"
        },
        {
          "element": "apas",
          "proportion": "secondary"
        }
      ],
      "effectOnDoshas": {
        "vata": "decreases",
        "pitta": "decreases",
        "kapha": "increases"
      },
      "effectOnDigestion": {
        "en": "Nourishes and builds tissues, promotes strength and longevity"
      },
      "generalActions": [
        "nourishes",
        "builds tissues",
        "promotes strength",
        "soothes",
        "moistens"
      ],
      "indications": [
        "emaciation",
        "weakness",
        "depletion",
        "burning sensations"
      ],
      "excessEffects": {
        "en": "Obesity, diabetes, kapha disorders, lethargy, heaviness"
      },
      "contraindications": [
        "diabetes",
        "obesity",
        "kapha excess",
        "low agni"
      ],
      "exampleSubstances": [
        "sugar",
        "honey",
        "licorice",
        "shatavari",
        "ashwagandha"
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/ayurveda/profile/rasa/sour",
      "@type": [
        "ayurveda:Rasa"
      ],
      "name": {
        "en": "Sour",
        "sa": "अम्ल"
      },
      "sanskritName": "अम्ल",
      "sanskritTransliteration": "Amla",
      "englishName": "Sour",
      "elementComposition": [
        {
          "element": "prithvi",
          "proportion": "dominant"
        },
        {
          "element": "tejas",
          "proportion": "secondary"
        }
      ],
      "effectOnDoshas": {
        "vata": "decreases",
        "pitta": "increases",
        "kapha": "increases"
      },
      "effectOnDigestion": {
        "en": "Stimulates digestion, increases salivation and appetite"
      },
      "generalActions": [
        "stimulates digestion",
        "increases appetite",
        "carminative",
        "refreshes"
      ],
      "indications": [
        "low appetite",
        "sluggish digestion",
        "vata disorders"
      ],
      "excessEffects": {
        "en": "Hyperacidity, heartburn, skin diseases, pitta disorders"
      },
      "contraindications": [
        "hyperacidity",
        "ulcers",
        "pitta disorders",
        "skin diseases"
      ],
      "exampleSubstances": [
        "amalaki",
        "lemon",
        "tamarind",
        "fermented foods"
      ]
    },
