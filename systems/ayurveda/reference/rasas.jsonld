  ],
  "_documentation": {
    "classicalReference": "Charaka Samhita, Sutrasthana, Chapter 26",
    "tasteSequence": "Sweet → Sour → Salty → Pungent → Bitter → Astringent (digestion order)",
    "digestiveStages": "Madhura (beginning) → Amla (middle) → Katu (end) - vipaka transforms tastes"
  }
}