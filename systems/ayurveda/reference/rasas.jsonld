      "englishName": "Bitter",
      "elementComposition": [
        {
          "element": "akasha",
          "proportion": "dominant"
        },
        {
          "element": "vayu",
          "proportion": "secondary"
        }
      ],
      "effectOnDoshas": {
        "vata": "increases",
        "pitta": "decreases",
        "kapha": "decreases"
      },
      "effectOnDigestion": {
        "en": "Cleanses the mouth, improves taste perception, reduces toxins"
      },
      "generalActions": [
        "reduces toxins",
        "clears heat",
        "reduces fever",
        "antiparasitic",
