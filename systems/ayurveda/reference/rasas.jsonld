      "englishName": "Pungent",
      "elementComposition": [
        {
          "element": "tejas",
          "proportion": "dominant"
        },
        {
          "element": "vayu",
          "proportion": "secondary"
        }
      ],
      "effectOnDoshas": {
        "vata": "increases",
        "pitta": "increases",
        "kapha": "decreases"
      },
      "effectOnDigestion": {
        "en": "Stimulates digestion, clears sinuses, improves circulation"
      },
      "generalActions": [
        "stimulates digestion",
        "clears sinuses",
        "improves circulation",
        "reduces kapha"
      ],
      "indications": [
        "kapha disorders",
        "low digestion",
        "congestion",
        "obesity"
      ],
      "excessEffects": {
