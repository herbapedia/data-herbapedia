  "@type": [
    "ayurveda:ReferenceCollection",
    "skos:Collection"
  ],
  "name": {
    "en": "Ayurveda Twenty Gunas",
    "sa": "विंशतिगुण"
  },
  "description": {
    "en": "The twenty qualities (गुण - Guna) in Ayurveda, organized in ten opposing pairs. These qualities describe the attributes of substances and their effects on the body."
  },
  "members": [
    {
      "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/heavy",
      "@type": [
        "ayurveda:Guna"
      ],
      "name": {
        "en": "Heavy",
        "sa": "गुरु"
      },
      "sanskritName": "गुरु",
      "sanskritTransliteration": "Guru",
      "englishName": "Heavy",
      "pairNumber": 1,
      "pairName": {
        "en": "Heavy-Light"
      },
      "oppositeOf": {
        "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/light"
      },
      "effectOnDoshas": {
        "vata": "decreases",
        "pitta": "decreases",
        "kapha": "increases"
      },
      "physiologicalEffect": {
        "en": "Grounds, stabilizes, nourishes, promotes sleep"
      },
      "psychologicalEffect": {
        "en": "Calms the mind, promotes stability, can cause lethargy in excess"
      },
      "indications": [
        "vata disorders",
        "insomnia",
        "emaciation",
        "lightness"
      ],
      "excessEffects": {
        "en": "Lethargy, heaviness, dullness, kapha increase"
      },
      "exampleSubstances": [
        "ghee",
        "meat",
        "wheat",
        "dairy"
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/light",
      "@type": [
        "ayurveda:Guna"
      ],
      "name": {
        "en": "Light",
        "sa": "लघु"
      },
      "sanskritName": "लघु",
      "sanskritTransliteration": "Laghu",
      "englishName": "Light",
      "pairNumber": 1,
      "pairName": {
        "en": "Heavy-Light"
      },
      "oppositeOf": {
        "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/heavy"
      },
      "effectOnDoshas": {
        "vata": "increases",
        "pitta": "increases",
        "kapha": "decreases"
      },
      "physiologicalEffect": {
        "en": "Lightens tissues, promotes digestion, reduces kapha"
      },
      "psychologicalEffect": {
        "en": "Promotes clarity, can cause anxiety in excess"
      },
      "indications": [
        "kapha disorders",
        "obesity",
        "sluggish digestion"
      ],
      "excessEffects": {
        "en": "Weakness, dizziness, vata increase"
      },
      "exampleSubstances": [
        "barley",
        "corn",
        "honey",
        "mung beans"
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/oily",
      "@type": [
        "ayurveda:Guna"
      ],
      "name": {
        "en": "Oily/Unctuous",
        "sa": "स्निग्ध"
      },
      "sanskritName": "स्निग्ध",
      "sanskritTransliteration": "Snigdha",
      "englishName": "Oily",
      "pairNumber": 2,
      "pairName": {
        "en": "Oily-Dry"
      },
      "oppositeOf": {
        "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/dry"
      },
      "effectOnDoshas": {
        "vata": "decreases",
        "pitta": "decreases",
        "kapha": "increases"
      },
      "physiologicalEffect": {
        "en": "Lubricates, nourishes, promotes flexibility"
      },
      "psychologicalEffect": {
        "en": "Promotes love, compassion"
      },
      "indications": [
        "dry skin",
        "constipation",
        "vata disorders",
        "stiff joints"
      ],
      "excessEffects": {
        "en": "Oiliness, excess kapha, sluggish digestion"
      },
      "exampleSubstances": [
        "ghee",
        "oils",
        "nuts",
        "dairy"
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/dry",
      "@type": [
        "ayurveda:Guna"
      ],
      "name": {
        "en": "Dry",
        "sa": "रूक्ष"
      },
      "sanskritName": "रूक्ष",
      "sanskritTransliteration": "Rūkṣa",
      "englishName": "Dry",
      "pairNumber": 2,
      "pairName": {
        "en": "Oily-Dry"
      },
      "oppositeOf": {
        "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/oily"
      },
      "effectOnDoshas": {
        "vata": "increases",
        "pitta": "increases",
        "kapha": "decreases"
      },
      "physiologicalEffect": {
        "en": "Dries excess moisture, absorbs, reduces kapha"
      },
      "psychologicalEffect": {
        "en": "Can cause nervousness, anxiety in excess"
      },
      "indications": [
        "kapha disorders",
        "excess moisture",
        "obesity"
      ],
      "excessEffects": {
        "en": "Dry skin, constipation, vata increase"
      },
      "exampleSubstances": [
        "barley",
        "corn",
        "legumes",
        "dried fruits"
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/hot",
      "@type": [
        "ayurveda:Guna"
      ],
      "name": {
        "en": "Hot",
        "sa": "उष्ण"
      },
      "sanskritName": "उष्ण",
      "sanskritTransliteration": "Uṣṇa",
      "englishName": "Hot",
      "pairNumber": 3,
      "pairName": {
        "en": "Hot-Cold"
      },
      "oppositeOf": {
        "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/cold"
      },
      "effectOnDoshas": {
        "vata": "decreases",
        "pitta": "increases",
        "kapha": "decreases"
      },
      "physiologicalEffect": {
        "en": "Increases metabolism, promotes digestion, reduces cold"
      },
      "psychologicalEffect": {
        "en": "Promotes intensity, passion, can cause anger in excess"
      },
      "indications": [
        "cold conditions",
        "kapha disorders",
        "vata disorders",
        "low agni"
      ],
      "excessEffects": {
        "en": "Burning, inflammation, bleeding, pitta increase"
      },
      "exampleSubstances": [
        "ginger",
        "pepper",
        "chilies",
        "garlic"
      ]
    },
    {
      "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/cold",
      "@type": [
        "ayurveda:Guna"
      ],
      "name": {
        "en": "Cold",
        "sa": "शीत"
      },
      "sanskritName": "शीत",
      "sanskritTransliteration": "Śīta",
      "englishName": "Cold",
      "pairNumber": 3,
      "pairName": {
        "en": "Hot-Cold"
      },
      "oppositeOf": {
        "@id": "https://www.herbapedia.org/system/ayurveda/profile/guna/hot"
      },
      "effectOnDoshas": {
        "vata": "increases",
        "pitta": "decreases",
        "kapha": "increases"
      },
      "physiologicalEffect": {
        "en": "Cools, reduces fever, soothes inflammation"
      },
      "psychologicalEffect": {
        "en": "Calms, can cause lethargy in excess"
      },
      "indications": [
        "pitta disorders",
        "fever",
        "inflammation",
        "burning"
      ],
      "excessEffects": {
        "en": "Cold, stiffness, vata/kapha increase"
      },
      "exampleSubstances": [
        "coconut",
        "mint",
        "coriander",
        "aloe vera"
      ]
    },
