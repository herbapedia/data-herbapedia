  "_documentation": {
    "classicalReference": "Charaka Samhita, Sutrasthana, Chapter 1",
    "tenPairs": [
      "Heavy-Light (Guru-Laghu)",
      "Oily-Dry (Snigdha-Rūkṣa)",
      "Hot-Cold (Uṣṇa-Śīta)",
      "Slow-Sharp (Manda-Tīkṣṇa)",
      "Smooth-Rough (Ślakṣṇa-Khara)",
      "Liquid-Dense (Drava-Sandra)",
      "Static-Mobile (Sthira-Cala)",
      "Cloudy-Clear (Picchila-Viśada)",
      "Soft-Hard (Mṛdu-Kaṭhina)",
      "Subtle-Gross (Sūkṣma-Sthūla)"
    ]
  }
