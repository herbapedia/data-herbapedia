  "indications": [
    "Digestive disorders",
    "Loss of appetite",
    "Cough and cold",
    "Joint pain (Vata type)",
    "Nausea",
    "Respiratory congestion"
  ],
  "contraindications": {
    "en": "Avoid in high Pitta conditions, bleeding disorders, and pregnancy in high doses.",
    "sa": "पित्ते रक्तपित्ते च वर्जयेत्"
  },
  "dosage": {
    "en": "1-3g powder; 5-10g fresh rhizome decoction."
  },
  "anupana": {
    "en": "Take with warm water, honey, or as directed."
  },
  "ayurvedaHistory": {
    "en": "Ginger (Nagara/Shunthi) has been used in Ayurveda for millennia. It is classified as a Mahaaushadha (great medicine). Both fresh (Ardra) and dry (Shunthi) forms are used, with different properties.",
    "sa": "नागरं शुण्ठी विश्वौषधं महौषधं च"
  },
  "ayurvedaTraditionalUsage": {
    "en": "In Ayurveda, dry Ginger (Nagara/Shunthi) is primarily used to:\n\n- Kindle digestive fire (Agni)\n- Reduce Vata and Kapha doshas\n- Relieve cough and respiratory issues\n- Alleviate joint pain\n- Treat nausea and motion sickness",
    "sa": "शुण्ठी दीपनी पाचनी कटूष्णा कफवातनुत्"
  },
  "ayurvedaFunctions": {
    "en": "- Digestive stimulant\n- Anti-inflammatory\n- Expectorant\n- Carminative\n- Analgesic"
  },
  "ayurvedaClassicalReference": {
    "sa": "चरकसंहितायां शुण्ठी दीपनी पाचनी कटूष्णा कफवातनुत् इति वर्णिता।",
    "en": "In Charaka Samhita, ginger is described as digestive stimulant, carminative, and reducer of Kapha and Vata."
  },
  "ayurvedaSafetyConsideration": {
    "en": "May increase Pitta. Use cautiously in peptic ulcers, gallstones, and bleeding disorders. May interact with anticoagulants."
  },
