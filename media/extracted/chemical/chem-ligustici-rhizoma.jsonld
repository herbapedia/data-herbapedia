    "developingDistance": "6 cm",
    "visualization": "UV light at 366 nm",
    "identificationCriteria": {
      "positiveMarkers": ["(E)-ferulic acid"],
      "criteria": "Test solution chromatogram must show characteristic spots or bands with the same color and corresponding Rf value as (E)-ferulic acid"
