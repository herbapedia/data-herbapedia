  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel G60 plate",
    "developingSolvent": {
      "components": ["cyclohexane", "ethyl acetate"],
      "ratio": "19:1 (v/v)"
    },
    "sprayReagent": {
      "composition": "5 g vanillin in 100 mL sulfuric acid",
      "visualization": "Heat at approximately 105°C for about 2 minutes until spots/bands visible"
    },
    "testSolution": {
      "samplePreparation": "Mix sample with kieselguhr (diatomaceous earth) in 2:1 ratio, pulverize",
      "sampleAmount": "1.5 g powder",
      "solvent": "ethyl acetate",
      "solventVolume": "50 mL",
      "extraction": "ultrasonication at 320 W for 30 minutes",
      "evaporation": "rotary evaporator under reduced pressure at approximately 40°C",
      "finalVolume": "2 mL ethyl acetate"
    },
    "standardSolutions": {
      "concentration": "1.0 mg/mL (5.0 mg in 5 mL ethyl acetate)",
      "compound": "1,8-Cineole"
    },
    "applicationVolumes": {
      "standardSolution": "3 μL",
      "testSolution": "2 μL"
    },
    "developingDistance": "8 cm",
    "saturationTime": "15 minutes (twin-trough developing tank)",
    "visualization": "visible light",
    "identificationCriteria": {
      "positiveMarkers": ["1,8-Cineole"],
      "rfMatchRequirement": "Spots or bands with same color and corresponding Rf value as reference"
    }
  },
  "gcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "detector": "FID (Flame Ionization Detector)",
      "column": {
        "type": "Capillary column DB-1701",
        "dimensions": "30 m × 0.32 mm (internal diameter)",
        "stationaryPhase": "(14%-cyanopropyl-phenyl)-methylpolysiloxane",
        "filmThickness": "0.25 μm"
      },
      "inletTemperature": "210°C",
      "detectorTemperature": "230°C",
      "splitRatio": "20:1",
      "injectionVolume": "1 μL"
    },
    "temperatureProgram": [
      {
        "timeRange": "0-3 min",
        "temperature": "40°C",
        "rate": "-"
