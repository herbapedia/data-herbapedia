    "testSolution": {
      "samplePreparation": "Mix sample with kieselguhr (diatomaceous earth) in 2:1 ratio, pulverize",
      "sampleAmount": "1.5 g powder",
      "extraction": {
        "method": "Volatile oil determination apparatus",
        "waterVolume": "200 mL",
        "nHexaneVolume": "3 mL",
        "refluxTime": "2 hours"
      },
      "finalVolume": "25 mL n-hexane",
      "drying": "1 g anhydrous sodium sulfate",
      "filtration": "0.45 μm nylon membrane"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (1,8-Cineole)",
      "retentionTimeRSD": "≤ 2.0% (1,8-Cineole)",
      "theoreticalPlates": "≥ 100,000 (based on 1,8-Cineole)",
      "resolution": "≥ 1.5 (between peak 4 and adjacent peak)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard",
