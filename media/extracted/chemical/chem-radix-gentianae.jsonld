    },
    "testSolution": {
      "sampleAmount": "0.25 g",
      "solvent": "1:1 (v/v) 0.4% phosphoric acid and methanol mixture",
      "solventVolume": "25 mL",
      "container": "50 mL centrifuge tube",
      "extraction": "ultrasonication at 240 W for 45 minutes",
      "centrifugation": "approximately 3000 × g for 10 minutes",
      "filtration": "0.45 μm PTFE microporous membrane"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 2.0% (Gentiopicroside)",
      "retentionTimeRSD": "≤ 3.0% (Gentiopicroside)",
      "theoreticalPlates": "≥ 3000 (based on Gentiopicroside)",
      "resolution": "≥ 1.5 (between peak 2 and peak 3)"
