{
  "@context": "../../../schema/context/core.jsonld",
  "@id": "media/extracted/chemical/rhizoma-cimicifugae",
  "@type": ["herbapedia:ChemicalAnalysisData", "schema:Dataset"],
  "dataType": "ChemicalAnalysis",
  "sourceDocument": "CHEM____Rhizoma_Cimicifugae_V1.pdf",
  "scientificName": "Cimicifuga foetida",
  "chineseName": "升麻",
  "pinyinName": "Sheng Ma",
  "identificationMethod": ["Physicochemical", "TLC", "HPLC-Fingerprint", "HPLC-Assay"],
  "referenceCompounds": [
    {
      "name": "Isoferulic acid",
      "chineseName": "異阿魏酸",
      "formula": "C10H10O4",
      "purpose": ["TLC identification", "HPLC fingerprint marker", "Assay quantification"]
    },
    {
      "name": "Ferulic acid",
      "chineseName": "阿魏酸",
      "purpose": ["HPLC fingerprint marker"]
    }
  ],
  "assayLimits": {
    "isoferulicAcid": {
      "compound": "Isoferulic acid",
      "formula": "C10H10O4",
      "minimumContent": "Not less than 0.05%",
      "basis": "dried substance"
    }
  },
  "physicochemicalIdentification": {
    "method": "Color reaction with sulfuric acid",
    "procedure": {
      "sampleAmount": "0.2 g",
      "solvent": "dichloromethane",
      "solventVolume": "10 mL",
      "extraction": "ultrasonication (560 W) for 30 minutes",
      "centrifugation": "3000 × g for 10 minutes",
      "testVolume": "0.5 mL supernatant",
      "reagent": "sulfuric acid",
      "reagentVolume": "0.5 mL",
      "standingTime": "20 minutes",
      "positiveResult": "reddish-brown or yellowish-brown ring at the interface of the two solvent layers"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F254 plate",
    "developingSolvent": {
      "components": ["toluene", "dichloromethane", "glacial acetic acid"],
      "ratio": "6:1:0.5 (v/v)"
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "ethanol",
      "solventVolume": "50 mL",
      "extraction": "reflux for 1 hour",
      "evaporation": "rotary evaporator at reduced pressure",
      "finalVolume": "1 mL ethanol"
    },
    "standardSolutions": {
      "isoferulicAcid": {
        "concentration": "1.0 mg/mL in methanol",
        "compound": "Isoferulic acid"
      }
    },
    "applicationVolumes": {
      "standardSolution": "5 μL",
      "testSolution": "5 μL"
    },
    "developingDistance": "6 cm",
    "visualization": "UV light at 254 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Isoferulic acid"],
      "criteria": "Sample must show spot or band with same color and Rf value as isoferulic acid standard"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "3.9 × 300 mm",
        "particleSize": "4 μm"
      },
      "detector": "UV",
      "detectionWavelength": "325 nm",
      "flowRate": "0.9 mL/min",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
      "solventA": "0.1% Trifluoroacetic acid",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-5 min",
          "solventA": "95%",
          "solventB": "5%",
          "elution": "isocratic"
        },
        {
          "timeRange": "5-50 min",
          "solventA": "95% → 75%",
          "solventB": "5% → 25%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "50-70 min",
          "solventA": "75% → 50%",
          "solventB": "25% → 50%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolutions": {
      "isoferulicAcid": {
        "name": "Std-FP",
        "concentration": "100 mg/L",
        "preparation": "1.0 mg isoferulic acid in 10 mL methanol"
      }
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "methanol",
      "solventVolume": "10 mL",
      "extraction": "ultrasonication (560 W) for 30 minutes",
      "centrifugation": "3000 × g for 5 minutes",
      "filtration": "0.45 μm microporous membrane (RC)"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (Isoferulic acid)",
      "retentionTimeRSD": "≤ 2.0% (Isoferulic acid)",
      "theoreticalPlates": "≥ 50,000 (based on Isoferulic acid)",
      "resolution": "≥ 1.5 (between peak 4 and peak 5)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard"
    }
  },
  "hplcAssay": {
    "appendixReference": "Appendix III",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "3.9 × 300 mm",
        "particleSize": "4 μm"
      },
      "detector": "UV",
      "detectionWavelength": "300 nm",
      "flowRate": "0.9 mL/min"
    },
    "mobilePhase": {
      "solventA": "0.1% Trifluoroacetic acid",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-5 min",
          "solventA": "90% → 85%",
          "solventB": "10% → 15%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "5-25 min",
          "solventA": "85% → 80%",
          "solventB": "15% → 20%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolutions": {
      "stockSolution": {
        "concentration": "1000 mg/L",
        "compound": "Isoferulic acid",
        "preparation": "10.0 mg in 10 mL methanol",
        "name": "Std-Stock"
      },
      "workingSolutions": {
        "name": "Std-AS",
        "concentrations": ["10", "20", "30", "40", "50 mg/L"],
        "description": "Series of standard solutions diluted with methanol"
      },
      "injectionVolume": "10 μL (for calibration)"
    },
    "testSolution": {
      "sampleAmount": "0.4 g",
      "solvent": "methanol",
      "extractionVolume": "30 mL initial + 10 mL × 3 washes",
      "extraction": "60°C water bath with shaking (40 strokes/min) for 30 minutes",
      "centrifugation": "3000 × g for 5 minutes",
      "filtration": "0.45 μm microporous membrane (RC)",
      "evaporation": "rotary evaporator at reduced pressure",
      "finalVolume": "10 mL methanol",
      "injectionVolume": "10 μL"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "injectionVolume": "10 μL",
      "standardConcentration": "40 mg/L (Isoferulic acid Std-AS)",
      "peakAreaRSD": "≤ 5.0% (Isoferulic acid)",
      "retentionTimeRSD": "≤ 2.0% (Isoferulic acid)",
      "theoreticalPlates": "≥ 15,000 (based on Isoferulic acid)",
      "resolution": "≥ 1.3 (between isoferulic acid peak and adjacent peak)"
    },
    "calibration": {
      "method": "5-point calibration curve",
      "plot": "Peak area vs. concentration (mg/L)",
      "identificationTolerance": "≤ 2.0% difference in retention times"
    }
  },
