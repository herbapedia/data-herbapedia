      },
      "workingSolutions": {
        "name": "Std-AS",
        "concentrations": ["6 mg/L", "12 mg/L", "18 mg/L", "30 mg/L", "42 mg/L"],
        "description": "Series of standard solutions for 5-point calibration curve"
      },
      "injectionVolume": "10 μL (for calibration)"
    },
    "testSolution": {
      "sampleAmount": "0.1 g",
      "solvent": "methanol",
      "solventVolume": "25 mL",
      "extraction": "ultrasonication (90 W) for 15 minutes",
      "centrifugation": "1800 × g for 10 minutes",
      "finalVolume": "25 mL",
      "filtration": "0.45 μm nylon membrane filter",
      "injectionVolume": "10 μL"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "injectionVolume": "10 μL",
      "standardConcentration": "18 mg/L (Atractylodin Std-FP)",
      "peakAreaRSD": "≤ 5.0% (Atractylodin)",
      "retentionTimeRSD": "≤ 2.0% (Atractylodin)",
      "theoreticalPlates": "≥ 10,000 (based on Atractylodin)",
