      "formula": "C₁₃H₁₀O",
      "purpose": ["TLC identification", "HPLC fingerprint marker", "Assay quantification"]
    }
  ],
  "assayLimits": {
    "atractylodin": {
      "compound": "Atractylodin",
      "formula": "C₁₃H₁₀O",
      "minimumContent": "0.32%",
      "basis": "dried substance"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
    "developingSolvent": {
      "components": ["n-hexane", "ethyl acetate"],
      "ratio": "10:0.8 (v/v)"
    },
    "sprayReagent": {
      "composition": "5 g p-dimethylaminobenzaldehyde in 100 mL of 10% (v/v) sulfuric acid",
      "visualization": "Heat at approximately 105°C until spots or bands visible (approximately 2 minutes)"
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "ethyl acetate",
      "solventVolume": "10 mL",
      "extraction": "ultrasonication (90 W) for 15 minutes"
    },
    "standardSolution": {
      "compound": "Atractylodin",
      "amount": "1.2 mg",
      "flaskVolume": "5 mL brown volumetric flask",
      "solvent": "n-hexane"
    },
    "applicationVolumes": {
      "standardSolution": "10 μL",
      "testSolution": "10 μL"
    },
    "chamberType": "Double-trough TLC chamber",
    "saturationTime": "15 minutes",
    "developingDistance": "8.5 cm",
    "visualization": "Visible light after color development",
    "identificationCriteria": {
      "positiveMarkers": ["Atractylodin"],
      "identificationRequirement": "Sample must produce a spot or band with chromatographic characteristics (including color and Rf value) corresponding to that of the atractylodin standard"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD (Diode Array Detector)",
      "detectionWavelength": "254 nm",
      "flowRate": "1.0 mL/min",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
      "solventA": "Water",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-60 min",
          "solventA": "55% → 15%",
          "solventB": "45% → 85%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolution": {
      "name": "Std-FP",
      "compound": "Atractylodin",
      "concentration": "18 mg/L",
      "preparation": "0.9 mg in 50 mL brown volumetric flask with methanol"
    },
    "testSolution": {
      "sampleAmount": "0.1 g",
      "solvent": "methanol",
      "solventVolume": "25 mL",
      "extraction": "ultrasonication (90 W) for 15 minutes",
      "centrifugation": "1800 × g for 10 minutes",
      "filtration": "0.45 μm nylon membrane filter"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (Atractylodin)",
      "retentionTimeRSD": "≤ 2.0% (Atractylodin)",
      "theoreticalPlates": "≥ 50,000 (based on Atractylodin)",
      "resolution": "≥ 1.5 (between peak 3 and adjacent peaks)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard"
    }
  },
  "hplcAssay": {
    "appendixReference": "Appendix III",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD (Diode Array Detector)",
      "detectionWavelength": "340 nm",
      "flowRate": "1.0 mL/min",
      "runTime": "approximately 15 minutes"
    },
    "mobilePhase": {
      "composition": "Methanol - Water",
      "ratio": "85:15 (v/v)",
