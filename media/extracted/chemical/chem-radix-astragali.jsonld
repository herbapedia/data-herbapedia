  "appendices": {
    "appendixI": {
      "title": "Chromatography – Thin-Layer Chromatography (TLC)",
      "description": "General procedures for TLC including plate types (silica gel G, F254, HPTLC, etc.), application methods, developing chambers, spray reagents, UV light sources, and Rf calculation"
    },
    "appendixII": {
      "title": "Gas Chromatographic and High-Performance/Ultra-High Performance Liquid Chromatographic Fingerprinting",
      "description": "Methods for establishing chromatographic fingerprints using marker peaks and RRT values. Includes guidelines for marker peak selection, RRT calculation, and acceptable range determination based on 10 batches tested in duplicate"
    },
    "appendixIII": {
      "title": "Chromatography – High-Performance Liquid Chromatography (HPLC) / Ultra-High Performance Liquid Chromatography (UHPLC)",
      "description": "General HPLC/UHPLC procedures including system suitability tests (theoretical plates, repeatability, resolution, tailing factor), quantitative calculations for both DAD and ELSD detectors, and calibration curve preparation"
    }
