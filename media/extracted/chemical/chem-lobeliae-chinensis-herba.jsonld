  "appendices": {
    "appendixI": {
      "title": "Chromatography - Thin-Layer Chromatography",
      "description": "General procedures for TLC including plate types, application methods, developing chambers, and Rf calculation"
    },
    "appendixII": {
      "title": "GC and HPLC/UHPLC Fingerprinting",
      "description": "Methods for establishing chromatographic fingerprints using marker peaks and RRT values. Reference fingerprint chromatogram established from at least 10 batches of representative samples examined in duplicate."
