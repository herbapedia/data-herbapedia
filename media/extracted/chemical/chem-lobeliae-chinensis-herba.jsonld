  "identificationMethod": ["TLC", "HPLC-Fingerprint", "HPLC-Assay"],
  "referenceCompounds": [
    {
      "name": "Diosmin",
      "chineseName": "香葉木苷",
      "synonyms": ["Diosmetin-7-O-glucoside", "Melilotoside"],
      "purpose": ["TLC identification", "HPLC fingerprint marker", "HPLC assay quantification"]
    },
    {
      "name": "Linarin",
      "chineseName": "蒙花苷",
      "synonyms": ["Buddleoside"],
      "purpose": ["TLC identification", "HPLC fingerprint marker", "HPLC assay quantification"]
    },
    {
      "name": "Diosmetin",
      "chineseName": "香葉木素",
      "purpose": ["HPLC assay quantification"]
    }
  ],
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F254 plate",
    "developingSolvent": {
      "components": ["ethyl acetate", "acetone", "formic acid", "water"],
      "ratio": "8:1:1:1 (v/v/v/v)"
    },
    "sprayReagent": {
      "composition": "1 g aluminum trichloride in 100 mL ethanol",
      "visualization": "Heat at 105C for approximately 3 minutes"
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "methanol",
      "solventVolume": "5 mL",
      "extraction": "ultrasonication (350 W) for 15 minutes",
      "centrifugation": "approximately 6000 x g for 5 minutes",
      "filtration": "0.45 micrometer nylon filter"
    },
    "standardSolutions": {
      "diosmin": {
        "preparation": "2.0 mg dissolved in 0.1 mL DMSO, then 0.02 mL diluted to 2 mL with methanol",
        "applicationVolume": "3 microliters"
      },
      "linarin": {
        "preparation": "8.0 mg dissolved in 0.1 mL DMSO, then 0.01 mL diluted to 2 mL with methanol",
        "applicationVolume": "1 microliter"
      }
    },
    "applicationVolumes": {
      "testSolution": "5 microliters"
    },
    "developingDistance": "7.5 cm",
    "chamberEquilibration": "15 minutes in twin trough chamber",
    "visualization": "UV light at 366 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Diosmin", "Linarin"],
      "matchingRequirement": "Test solution must show spots matching the color and Rf values of the standard solutions"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "C18 bonded silica gel",
        "dimensions": "4.6 x 250 mm",
        "particleSize": "5 micrometers"
      },
      "detector": "DAD (Diode Array Detector)",
      "detectionWavelength": "267 nm",
      "columnTemperature": "40C",
      "flowRate": "1.0 mL/min",
      "injectionVolume": "10 microliters"
    },
    "mobilePhase": {
      "solventA": "0.2% formic acid in water (v/v)",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-35 min",
          "solventA": "83%",
          "solventB": "17%",
          "elution": "isocratic"
        },
        {
          "timeRange": "35-60 min",
          "solventA": "83% to 70%",
          "solventB": "17% to 30%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolutions": {
      "diosmin": {
        "concentration": "80 mg/L",
        "preparation": "8.0 mg in 10 mL DMSO, then 0.2 mL diluted to 2 mL with methanol"
      },
      "linarin": {
        "concentration": "18 mg/L",
        "preparation": "1.8 mg in 10 mL DMSO, then 0.2 mL diluted to 2 mL with methanol"
      }
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "methanol",
      "solventVolume": "5 mL",
      "extraction": "ultrasonication (350 W) for 15 minutes",
      "centrifugation": "approximately 6000 x g for 5 minutes",
      "filtration": "0.45 micrometer nylon membrane filter"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "less than or equal to 5.0% for both Diosmin and Buddleoside",
      "retentionTimeRSD": "less than or equal to 2.0% for both Diosmin and Buddleoside",
      "theoreticalPlatesDiosmin": "greater than or equal to 10,000",
      "theoreticalPlatesBuddleoside": "greater than or equal to 300,000",
      "resolution": "greater than or equal to 1.5 between Peak 2 and Peak 4 and their adjacent peaks"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "less than or equal to 2.0% difference between sample and standard"
    }
  },
  "rrtValues": [
