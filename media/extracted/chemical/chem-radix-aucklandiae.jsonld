{
  "@context": "../../../schema/context/core.jsonld",
  "@id": "media/extracted/chemical/radix-aucklandiae",
  "@type": ["herbapedia:ChemicalAnalysisData", "schema:Dataset"],
  "dataType": "ChemicalAnalysis",
  "sourceDocument": "CHEM____Radix_Aucklandiae_V1.pdf",
  "scientificName": "Aucklandia lappa Decne.",
  "chineseName": "木香",
  "pinyinName": "Mu Xiang",
  "identificationMethod": ["Physicochemical", "TLC", "HPLC-Fingerprint", "HPLC-Assay"],
  "referenceCompounds": [
    {
      "name": "Costunolide",
      "chineseName": "木香烴內酯",
      "formula": "C₁₅H₂₀O₂",
      "purpose": ["TLC identification", "HPLC fingerprint marker", "Assay quantification"]
    },
    {
      "name": "Dehydrocostus lactone",
      "chineseName": "去氫木香內酯",
      "formula": "C₁₅H₁₈O₂",
      "purpose": ["TLC identification", "HPLC fingerprint marker", "Assay quantification"]
    }
  ],
  "assayLimits": {
    "totalCostunolideAndDehydrocostusLactone": {
      "compounds": ["Costunolide", "Dehydrocostus lactone"],
      "formulas": ["C₁₅H₂₀O₂", "C₁₅H₁₈O₂"],
      "minimumContent": "2.2%",
      "basis": "dried substance (combined total)"
    }
  },
  "physicochemicalIdentification": {
    "method": "Color reaction with sulfuric acid",
    "procedure": {
      "sampleAmount": "0.2 g",
      "solvent": "ethanol",
      "solventVolume": "10 mL",
      "extraction": "ultrasonication (560 W) for 5 minutes",
      "centrifugation": "3000 × g for 5 minutes",
      "dilutionVolume": "4 mL ethanol added to 1 mL supernatant",
      "testVolume": "1 mL of diluted solution",
      "reagent": "concentrated sulfuric acid",
      "reagentVolume": "approximately 0.5 mL",
      "standingTime": "10 minutes",
      "positiveResult": "reddish-purple to purple ring at the interface of the two liquid layers"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
    "developingSolvent": {
      "components": ["dichloromethane", "cyclohexane"],
      "ratio": "5:1 (v/v)"
    },
    "sprayReagent": {
      "composition": "1 mL of 50% (v/v) dilute sulfuric acid mixed with 10 mL of 2% (w/v) p-hydroxybenzaldehyde in methanol",
      "visualization": "Heat at approximately 100°C for about 10 minutes until spots or bands clearly visible"
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "dichloromethane",
      "solventVolume": "20 mL",
      "extraction": "ultrasonication for 30 minutes",
      "evaporation": "to dryness",
      "finalSolvent": "ethyl acetate",
      "finalVolume": "1 mL"
    },
    "standardSolutions": {
      "concentration": "1.0 mg/mL in methanol",
      "compounds": ["Costunolide", "Dehydrocostus lactone"]
    },
    "applicationVolumes": {
      "standardSolutions": "2 μL each",
      "testSolution": "0.5 μL"
    },
    "developingDistance": "approximately 5 cm",
    "visualization": "visible light after color development",
    "identificationCriteria": {
      "positiveMarkers": ["Costunolide", "Dehydrocostus lactone"],
      "criteria": "Test solution chromatogram must show spots or bands with same color and Rf values corresponding to the reference standards"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "UV",
      "detectionWavelength": "254 nm",
      "flowRate": "approximately 1.0 mL/min",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
      "solventA": "0.1% Trifluoroacetic acid (v/v)",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-20 min",
          "solventA": "100% → 70%",
          "solventB": "0% → 30%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "20-28 min",
          "solventA": "70%",
          "solventB": "30%",
          "elution": "isocratic"
        },
        {
          "timeRange": "28-45 min",
          "solventA": "70% → 0%",
          "solventB": "30% → 100%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "45-60 min",
          "solventA": "0%",
          "solventB": "100%",
          "elution": "isocratic"
        }
      ]
    },
    "standardSolutions": {
      "costunolide": {
        "name": "Costunolide Std-FP",
        "concentration": "100 mg/L",
        "preparation": "1.0 mg in 10 mL methanol"
      }
    },
    "testSolution": {
      "sampleAmount": "0.2 g",
      "solvent": "methanol",
      "solventVolume": "10 mL",
      "extraction": "ultrasonication (560 W) for 30 minutes",
      "filtration": "0.45 μm RC microporous membrane"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (Costunolide)",
      "retentionTimeRSD": "≤ 2.0% (Costunolide)",
      "theoreticalPlates": "≥ 600,000 (based on Costunolide)",
      "resolution": "≥ 1.5 (between peak 4 and peak 5)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard",
      "characteristicPeaks": "All 7 characteristic peaks must be present with RRTs within acceptable ranges"
    }
  },
  "hplcAssay": {
    "appendixReference": "Appendix III",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "UV",
      "detectionWavelength": "225 nm",
      "flowRate": "approximately 1.0 mL/min"
    },
    "mobilePhase": {
      "solventA": "Water",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-10 min",
          "solventA": "40% → 20%",
          "solventB": "60% → 80%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "10-20 min",
          "solventA": "20%",
          "solventB": "80%",
          "elution": "isocratic"
        }
      ]
    },
    "standardSolutions": {
      "stockSolution": {
        "concentration": "1000 mg/L each",
        "compounds": ["Costunolide", "Dehydrocostus lactone"],
        "preparation": "10.0 mg each in 10 mL methanol",
        "name": "Std-Stock"
      },
      "workingSolutions": {
        "concentrations": ["2.5", "25", "100", "250", "500 mg/L"],
        "description": "Series of mixed standard solutions (Std-AS) for both costunolide and dehydrocostus lactone",
        "injectionVolume": "10 μL (for calibration)"
      }
    },
    "testSolution": {
      "sampleAmount": "0.2 g",
      "solvent": "methanol",
      "initialExtractionVolume": "10 mL",
      "repeatExtractionVolumes": "5 mL × 2",
      "extraction": "ultrasonication (560 W) for 30 minutes each",
      "centrifugation": "3000 × g for 5 minutes",
      "finalVolume": "25 mL volumetric flask",
      "filtration": "0.45 μm RC microporous membrane",
      "injectionVolume": "10 μL"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "injectionVolume": "10 μL",
      "standardConcentration": "250 mg/L (mixed reference solution)",
      "peakAreaRSD": "≤ 5.0% (both compounds)",
      "retentionTimeRSD": "≤ 2.0% (both compounds)",
      "theoreticalPlates": "≥ 20,000 (both compounds)",
      "resolution": "≥ 1.5 (between Costunolide and Dehydrocostus lactone peaks)"
    },
    "calibration": {
      "method": "5-point calibration curve",
      "plot": "Peak area vs. concentration (mg/L)",
      "identificationTolerance": "≤ 5.0% difference in retention times"
    }
  },
