  "appendices": {
    "appendixI": {
      "title": "Chromatography – Thin-Layer Chromatography",
      "description": "General procedures for TLC including plate types (silica gel G, F₂₅₄, HPTLC), application methods, developing chambers, and Rf calculation"
    },
    "appendixII": {
      "title": "GC and HPLC/UHPLC Fingerprinting",
      "description": "Methods for establishing chromatographic fingerprints using marker peaks and RRT values. Requires at least 10 batches of representative samples examined in duplicate (20 sets of data) to establish reference fingerprint."
    },
    "appendixIII": {
      "title": "Chromatography – HPLC/UHPLC",
      "description": "General HPLC/UHPLC procedures including system suitability tests (theoretical plates, repeatability, resolution, tailing factor) and quantitative calculations using 5-point calibration curves"
    }
  },
