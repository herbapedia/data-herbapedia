  "scientificName": "Centella asiatica (L.) Urb.",
  "chineseName": "積雪草",
  "pinyinName": "Ji Xue Cao",
  "identificationMethod": ["HPTLC", "HPLC-Fingerprint", "HPLC-Assay"],
  "referenceCompounds": [
    {
      "name": "Asiaticoside",
      "chineseName": "積雪草苷",
      "formula": "C₄₈H₇₈O₁₉",
      "molecularWeight": "959.12 g/mol",
      "casNumber": "16830-15-2",
      "purpose": ["HPTLC identification", "HPLC fingerprint marker", "Assay quantification"]
    },
    {
      "name": "Madecassoside",
      "chineseName": "羥基積雪草苷",
      "formula": "C₄₈H₇₈O₂₀",
      "molecularWeight": "975.12 g/mol",
      "casNumber": "34540-22-2",
      "purpose": ["HPTLC identification", "HPLC fingerprint marker (reference)", "Assay quantification"]
    },
    {
      "name": "Madecassic acid",
      "chineseName": "羥基積雪草酸",
      "purpose": ["HPLC fingerprint marker"]
    },
    {
      "name": "Asiatic acid",
      "chineseName": "積雪草酸",
      "purpose": ["HPLC fingerprint marker"]
    }
  ],
  "assayLimits": {
    "totalAsiaticosideAndMadecassoside": {
      "compounds": ["Asiaticoside", "Madecassoside"],
      "formulas": ["C₄₈H₇₈O₁₉", "C₄₈H₇₈O₂₀"],
      "minimumContent": "0.97%",
      "basis": "dried substance (combined total)"
    }
  },
  "hptlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
    "developingSolvent": {
      "components": ["ethyl acetate", "glacial acetic acid", "water"],
      "ratio": "8:2.6:2.5 (v/v)"
    },
    "sprayReagent": {
      "composition": "10 mL sulfuric acid in 90 mL ethanol",
      "visualization": "Visible light after spraying and air drying"
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "70% ethanol",
      "solventVolume": "10 mL",
      "extraction": "ultrasonication (150 W) for 30 minutes"
    },
    "standardSolutions": {
      "asiaticoside": {
        "concentration": "1.0 mg/mL",
        "preparation": "2.0 mg asiaticoside CRS in 2 mL 70% ethanol",
        "applicationVolume": "3 μL"
      },
      "madecassoside": {
        "concentration": "1.0 mg/mL",
        "preparation": "2.0 mg madecassoside CRS in 2 mL 70% ethanol",
        "applicationVolume": "4 μL"
      }
    },
    "testApplicationVolume": "4 μL",
    "developingChamber": "Twin-trough chamber",
    "saturationTime": "15 minutes",
    "developingDistance": "8 cm",
    "identificationCriteria": {
      "positiveMarkers": ["Asiaticoside", "Madecassoside"],
      "criteria": "Sample chromatogram must show spots/bands with colors and Rf values corresponding to the standard solutions"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "205 nm",
      "columnTemperature": "20°C",
      "flowRate": "1.0 mL/min",
      "injectionVolume": "5 μL"
    },
    "mobilePhase": {
      "solventA": "Acetonitrile",
      "solventB": "0.15% Phosphoric acid",
      "gradientProgram": [
        {
          "timeRange": "0-15 min",
          "solventA": "21%",
          "solventB": "79%",
          "elution": "isocratic"
        },
        {
          "timeRange": "15-32 min",
          "solventA": "21% → 36%",
          "solventB": "79% → 64%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "32-50 min",
          "solventA": "36% → 40%",
          "solventB": "64% → 60%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "50-60 min",
          "solventA": "40% → 80%",
          "solventB": "60% → 20%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolutions": {
      "asiaticoside": {
        "concentration": "250 mg/L",
        "preparation": "2.5 mg asiaticoside CRS in 10 mL 80% methanol"
      },
      "madecassoside": {
        "concentration": "250 mg/L",
        "preparation": "2.5 mg madecassoside CRS in 10 mL 80% methanol"
      }
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "80% methanol",
      "solventVolume": "20 mL",
      "extraction": "reflux for 30 minutes",
      "centrifugation": "3000 × g for 5 minutes",
      "filtration": "0.45 μm PTFE filter"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (both compounds)",
      "retentionTimeRSD": "≤ 2.0% (both compounds)",
      "theoreticalPlates": {
        "asiaticoside": "≥ 100,000",
        "madecassoside": "≥ 200,000"
      },
      "resolution": "≥ 1.0 (between peak 2 and 3 with adjacent peaks)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard"
    }
  },
  "hplcAssay": {
    "appendixReference": "Appendix III",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "205 nm",
      "flowRate": "1.0 mL/min"
    },
    "mobilePhase": {
      "solventA": "Acetonitrile",
      "solventB": "0.15% Phosphoric acid",
      "gradientProgram": [
        {
          "timeRange": "0-10 min",
          "solventA": "21%",
          "solventB": "79%",
          "elution": "isocratic"
        },
        {
          "timeRange": "10-25 min",
          "solventA": "21% → 23%",
          "solventB": "79% → 77%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "25-50 min",
          "solventA": "23%",
          "solventB": "77%",
          "elution": "isocratic"
        }
      ]
    },
    "standardSolutions": {
      "stockSolution": {
        "concentration": "500 mg/L each",
        "compounds": ["Asiaticoside", "Madecassoside"],
        "preparation": "5.0 mg each CRS in 10 mL 80% methanol"
      },
      "workingSolutions": {
        "asiaticoside": ["5", "10", "20", "40", "100 mg/L"],
        "madecassoside": ["10", "30", "50", "75", "100 mg/L"],
        "diluent": "80% methanol"
      },
      "mixedStandard": {
        "asiaticoside": "20 mg/L",
        "madecassoside": "50 mg/L"
      },
      "injectionVolume": "10 μL"
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "80% methanol",
      "extractionVolume": "20 mL × 2 extractions",
      "extraction": "reflux for 30 minutes",
      "centrifugation": "3000 × g for 5 minutes",
      "finalVolume": "50 mL",
      "filtration": "0.45 μm PTFE filter",
      "injectionVolume": "10 μL"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "injectionVolume": "10 μL",
      "peakAreaRSD": "≤ 5.0% (both compounds)",
      "retentionTimeRSD": "≤ 2.0% (both compounds)",
      "theoreticalPlates": "≥ 18,000 (both compounds)",
      "resolution": "≥ 1.5 (between target peaks and adjacent peaks)"
    },
    "calibration": {
      "method": "5-point calibration curve",
      "plot": "Peak area vs. concentration (mg/L)",
      "identificationTolerance": "≤ 5.0% difference in retention times"
    }
  },
