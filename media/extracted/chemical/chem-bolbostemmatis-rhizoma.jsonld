  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
    "developingSolvent": {
      "components": ["ethyl acetate", "dichloromethane", "methanol", "water"],
      "ratio": "4:3:3:1 (v/v)"
    },
    "sprayReagent": {
      "composition": "10 mL sulphuric acid added slowly to 90 mL ethanol",
      "visualization": "UV light (366 nm) after heating at about 105°C for about 10 min"
    },
    "testSolution": {
      "sampleAmount": "0.1 g",
      "solvent": "70% ethanol",
      "solventVolume": "20 mL",
      "extraction": "ultrasonication (270 W) for 20 minutes",
      "postExtraction": "Evaporate to dryness at reduced pressure in a rotary evaporator, dissolve residue in 1 mL 70% ethanol"
    },
    "standardSolutions": {
      "tubeimosideI": {
        "concentration": "1.0 mg/mL in methanol",
        "preparation": "1.0 mg in 1 mL methanol"
      }
    },
    "applicationVolumes": {
      "standardSolution": "1 µL",
      "testSolution": "1 µL"
    },
    "developingDistance": "about 5 cm",
    "chamberSaturation": "15 min in twin trough chamber",
    "visualization": "UV light (366 nm) after spraying and heating",
    "identificationCriteria": {
      "positiveMarkers": ["Tubeimoside I"],
      "identificationRequirement": "Sample must show spots or bands with characteristics (color and Rf value) corresponding to tubeimoside I"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
