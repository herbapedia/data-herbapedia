        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 µm"
      },
      "flowRate": "1.0 mL/min",
      "mobilePhase": {
        "components": ["acetonitrile", "water"],
        "gradientProgram": [
          {
            "timeRange": "0-20 min",
            "acetonitrile": "10% → 40%",
            "water": "90% → 60%",
            "elution": "linear gradient"
          },
          {
            "timeRange": "20-30 min",
            "acetonitrile": "40% → 70%",
            "water": "60% → 30%",
            "elution": "linear gradient"
          }
        ]
      },
      "runTime": "about 30 min"
    },
    "standardSolutions": {
      "tubeimosideIStdFP": {
        "concentration": "200 mg/L",
        "preparation": "5.0 mg in 25 mL 70% methanol",
        "purpose": "fingerprinting"
      }
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "70% methanol",
      "solventVolume": "10 mL × 2 extractions",
      "extraction": "ultrasonication (270 W) for 30 minutes",
      "centrifugation": "5000 × g for 5 min",
      "finalVolume": "25 mL, then dilute 1 mL to 5 mL",
      "filtration": "0.45 µm RC filter"
    },
    "injectionVolume": "10 µL",
    "systemSuitability": {
