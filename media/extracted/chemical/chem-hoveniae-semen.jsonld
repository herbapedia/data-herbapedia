      "solvent": "methanol",
      "solventVolume": "10 mL",
      "extraction": "water bath at 60°C for 30 minutes",
      "evaporation": "rotary evaporator at reduced pressure",
      "finalVolume": "1 mL methanol",
      "filtration": "0.45-μm nylon membrane filter"
    },
    "standardSolutions": {
      "dihydromyricetin": {
        "concentration": "1.0 mg/mL in methanol",
        "sampleAmount": "1.0 mg in 1 mL methanol"
      }
    },
    "applicationVolumes": {
      "standardSolution": "2 μL",
      "testSolution": "2 μL"
    },
    "developingDistance": "8 cm",
    "chamberType": "twin trough chamber",
    "saturationTime": "15 minutes",
    "visualization": "UV light at 366 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Dihydromyricetin"],
      "criteria": "Test sample should show a spot or band with chromatographic characteristics (color and Rf value) corresponding to the dihydromyricetin standard"
    }
