      "minimumContent": "0.051%",
      "basis": "dried substance"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
    "developingSolvent": {
      "components": ["ethyl acetate", "formic acid", "methanol", "water"],
      "ratio": "25:1:1:1 (v/v)"
    },
    "sprayReagent": {
      "composition": "2.5 g aluminum chloride in 100 mL ethanol",
      "visualization": "Air dry until spots/bands visible (approx. 5 min)"
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "70% methanol",
      "solventVolume": "10 mL",
      "extraction": "ultrasonication (140 W) for 30 minutes",
      "centrifugation": "2800 × g for 10 minutes",
      "evaporation": "rotary evaporator under reduced pressure",
      "finalVolume": "1 mL of 70% methanol",
      "filtration": "0.45 μm nylon membrane"
    },
    "standardSolutions": {
      "concentration": "1.0 mg/mL in methanol",
      "compounds": ["Myricitrin"]
    },
    "applicationVolumes": {
      "standardSolution": "2 μL",
      "testSolution": "2 μL"
    },
    "developingDistance": "6 cm",
    "chamberSaturation": "15 minutes",
    "visualization": "UV light at 254 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Myricitrin"]
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm",
        "poreSize": "190 Å",
        "carbonLoading": "12%"
      },
      "detector": "DAD",
      "detectionWavelength": "254 nm",
      "columnTemperature": "35°C",
      "flowRate": "1.0 mL/min",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
      "solventA": "0.2% Acetic acid",
      "solventB": "Methanol",
      "gradientProgram": [
        {
          "timeRange": "0-45 min",
          "solventA": "80% → 40%",
          "solventB": "20% → 60%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolutions": {
      "myricitrin": {
        "concentration": "40 mg/L (2.0 mg in 50 mL of 60% methanol)",
        "storage": "as per laboratory guidelines"
      }
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "60% methanol",
      "solventVolume": "45 mL",
      "maceration": "1 hour",
      "reflux": "30 minutes",
      "cooling": "room temperature",
      "centrifugation": "3800 × g for 10 minutes",
      "finalVolume": "50 mL with 60% methanol",
      "filtration": "0.45 μm PTFE microporous membrane"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (Myricitrin)",
      "retentionTimeRSD": "≤ 2.0% (Myricitrin)",
      "theoreticalPlates": "≥ 20,000 (based on Myricitrin)",
      "resolution": "≥ 1.0 (between peak 1 and adjacent peak)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard"
    }
  },
