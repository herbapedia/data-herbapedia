  "scientificName": "Aster tataricus",
  "chineseName": "紫菀",
  "pinyinName": "Zi Wan",
  "identificationMethod": ["TLC", "HPLC-Fingerprint", "HPLC-Assay"],
  "referenceCompounds": [
    {
      "name": "Shionone",
      "chineseName": "紫菀酮",
      "formula": "C30H50O",
      "purpose": ["TLC identification", "HPLC fingerprint marker", "HPLC assay quantification"]
    }
  ],
  "assayLimits": {
    "shionone": {
      "compound": "Shionone",
      "formula": "C30H50O",
      "minimumContent": "0.10%",
      "basis": "dried substance"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F254 plate",
    "developingSolvent": {
      "components": ["n-hexane", "acetone"],
      "ratio": "15:1 (v/v)"
    },
    "sprayReagent": {
      "composition": "10 mL sulfuric acid in 90 mL ethanol",
      "visualization": "Heat at about 105°C until spots/bands visible (about 10 minutes)"
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "ethanol",
      "solventVolume": "20 mL",
      "extraction": "ultrasonication (160 W) for 30 minutes",
      "filtration": "filter after extraction",
      "evaporation": "rotary evaporator at reduced pressure",
      "finalVolume": "1 mL ethyl acetate"
    },
    "standardSolutions": {
      "concentration": "1.0 mg/mL",
      "compounds": ["Shionone"],
      "solvent": "ethyl acetate"
    },
    "applicationVolumes": {
      "standardSolutions": "3 μL",
      "testSolution": "3 μL"
    },
    "developingDistance": "about 4 cm",
    "visualization": "visible light",
    "identificationCriteria": {
      "positiveMarkers": ["Shionone"],
      "rfCalculation": "Distance from origin to spot center / Distance from origin to solvent front"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "200 nm",
      "columnTemperature": "25°C",
      "flowRate": "1.0-2.5 mL/min (programmed)",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
      "solventA": "Water",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-20 min",
          "solventA": "70% → 0%",
          "solventB": "30% → 100%",
          "elution": "linear gradient",
          "flowRate": "1.0 → 1.5 mL/min"
        },
        {
          "timeRange": "20-25 min",
          "solventA": "0%",
          "solventB": "100%",
          "elution": "linear gradient",
          "flowRate": "1.5 → 2.5 mL/min"
        },
        {
          "timeRange": "25-45 min",
          "solventA": "0%",
          "solventB": "100%",
          "elution": "isocratic",
          "flowRate": "2.5 mL/min"
        }
      ]
    },
    "standardSolutions": {
      "shionone": {
        "concentration": "60 mg/L",
        "preparation": "0.6 mg in 10 mL methanol",
        "storage": "-10°C in the dark",
        "code": "Std-FP"
      }
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "methanol",
      "solventVolume": "10 mL",
      "extraction": "ultrasonication (160 W) for 30 minutes",
      "centrifugation": "5000 × g for 5 minutes",
      "repeatExtraction": true,
      "combinedVolume": "25 mL",
      "filtration": "0.45 μm RC filter"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "injectionVolume": "10 μL",
      "peakAreaRSD": "≤ 5.0% (Shionone)",
      "retentionTimeRSD": "≤ 2.0% (Shionone)",
      "theoreticalPlates": "≥ 25,000 (based on Shionone)",
      "resolution": "≥ 1.5 (between peak 5 and its adjacent peak)",
      "resolutionFigure": "Fig. 3"
    },
    "rrtCalculation": "Retention time of characteristic peak / Retention time of marker peak"
  },
  "hplcAssay": {
    "appendixReference": "Appendix III",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "200 nm",
      "columnTemperature": "25°C",
      "flowRate": "1.0-2.5 mL/min (programmed)"
    },
    "mobilePhase": {
      "solventA": "Water",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-20 min",
          "solventA": "70% → 0%",
          "solventB": "30% → 100%",
          "elution": "linear gradient",
          "flowRate": "1.0 → 1.5 mL/min"
        },
        {
          "timeRange": "20-25 min",
          "solventA": "0%",
          "solventB": "100%",
          "elution": "linear gradient",
          "flowRate": "1.5 → 2.5 mL/min"
        },
        {
          "timeRange": "25-45 min",
          "solventA": "0%",
          "solventB": "100%",
          "elution": "isocratic",
          "flowRate": "2.5 mL/min"
        }
      ]
    },
    "standardSolutions": {
      "stockSolution": {
        "concentration": "1000 mg/L",
        "compounds": ["Shionone"],
        "preparation": "Weigh 10 mg Shionone CRS and dissolve in 10 mL methanol",
        "storage": "-10°C in the dark"
      },
      "workingSolutions": {
        "concentrations": ["25", "50", "100", "200", "400 mg/L"],
        "description": "Series of mixed standard solutions for 5-point calibration curve",
        "injectionVolume": "10 μL"
      }
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "methanol",
      "extractionVolume": "10 mL × 3 extractions",
      "extraction": "ultrasonication for 30 minutes",
      "centrifugation": "5000 × g for 5 minutes",
      "combination": "Combine all filtrates",
      "finalVolume": "25 mL",
      "filtration": "0.45 μm RC filter",
      "injectionVolume": "10 μL"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "injectionVolume": "10 μL",
      "standardConcentration": "200 mg/L (Shionone Std-AS)",
      "peakAreaRSD": "≤ 5.0% (Shionone)",
      "retentionTimeRSD": "≤ 2.0% (Shionone)",
      "theoreticalPlates": "≥ 25,000 (based on Shionone)",
      "resolution": "≥ 1.5"
    },
    "calibration": {
      "method": "5-point calibration curve",
      "plot": "Peak area vs. concentration (mg/L)",
      "detector": "DAD",
      "quantificationFormula": "C = (A - I) / m",
      "contentFormula": "Content (%) = (C × V × D) / (10000 × W)"
    },
    "quantification": {
      "method": "External Standard Method",
      "identificationTolerance": "≤ 5.0% difference in retention times"
