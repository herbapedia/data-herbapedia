  "assayLimits": {
    "matrinePlusOxymatrine": {
      "compounds": ["Matrine", "Oxymatrine"],
      "formulas": ["C₁₅H₂₄N₂O", "C₁₅H₂₄N₂O₂"],
      "minimumContent": "0.70%",
      "basis": "dried substance (combined total)"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel G60 plate",
    "developingSolvent": {
      "components": ["ammonium hydroxide solution (9.1%, w/v)", "n-butanol"],
      "ratio": "2:3 (v/v)",
      "preparation": "Use upper layer of the mixture"
    },
    "sprayReagent": {
      "composition": "Modified Dragendorff's reagent",
      "preparation": {
        "solutionA": "0.85 g bismuth oxynitrate in mixture of 10 mL glacial acetic acid and 40 mL water",
        "solutionB": "4 g potassium iodide in 10 mL water",
        "finalPreparation": "Mix 5 mL Solution A, 5 mL Solution B, and 20 mL glacial acetic acid in 100-mL volumetric flask, dilute to mark with water"
      },
      "note": "Freshly prepare the reagent",
      "visualization": "Heat at about 105°C until spots or bands become visible (about 1-2 min)"
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "methanol",
      "additives": "0.2 mL ammonium hydroxide solution (25%, v/v)",
      "solventVolume": "10 mL",
      "extraction": "oscillate (120 r/min) for 15 min",
      "processing": "Filter, evaporate to dryness at reduced pressure in rotary evaporator, dissolve residue in 1 mL methanol"
    },
    "standardSolutions": {
      "matrine": {
        "amount": "2.0 mg",
        "solvent": "methanol",
        "finalVolume": "1 mL",
        "concentration": "2.0 mg/mL"
      },
      "oxymatrine": {
        "amount": "2.0 mg",
        "solvent": "methanol",
        "finalVolume": "1 mL",
        "concentration": "2.0 mg/mL"
      }
    },
    "applicationVolumes": {
      "standardSolutions": "4 μL each",
      "testSolution": "4 μL"
    },
    "developingDistance": "about 5 cm",
    "plateTreatment": "Heat at about 105°C (about 1-2 min) after development before spraying",
    "visualization": "Examine under visible light",
    "identificationCriteria": {
      "positiveMarkers": ["Matrine", "Oxymatrine"],
      "matchingRequirement": "Characteristic spots or bands matching the color and Rf value of reference standards"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "220 nm",
      "columnTemperature": "30°C",
      "flowRate": "1.0 mL/min",
      "injectionVolume": "3 μL"
    },
    "mobilePhase": {
      "solventA": "Methanol",
      "solventB": "0.025 M Potassium dihydrogen phosphate solution (adjusted to pH 2.0 with phosphoric acid)",
      "gradientProgram": [
        {
          "timeRange": "0-35 min",
          "solventA": "3% → 12%",
          "solventB": "97% → 88%",
          "elution": "linear gradient"
        }
      ]
    },
    "testSolution": {
      "sampleAmount": "1.5 g",
      "solvent": "methanol",
      "solventVolume": "50 mL",
      "extraction": "reflux in water bath for 1 hour",
      "centrifugation": "approximately 5000 × g for 5 minutes",
      "repeatExtraction": "twice more",
      "concentration": "Combine supernatants, evaporate to dryness under reduced pressure using rotary evaporator",
      "finalVolume": "25 mL",
      "filtration": "0.45 μm nylon membrane filter"
    },
    "standardSolutions": {
      "stdFP": {
        "description": "Mixed reference solution containing Matrine and Oxymatrine",
        "injectionVolume": "3 μL"
      }
    },
    "systemSuitability": {
      "peakAreaRSD": "≤ 5.0% (Matrine and Oxymatrine)",
      "retentionTimeRSD": "≤ 2.0% (Matrine and Oxymatrine)",
      "theoreticalPlatesMatrine": "≥ 5000 (based on Matrine)",
      "theoreticalPlatesOxymatrine": "≥ 10000 (based on Oxymatrine)",
      "resolution": "≥ 1.5 (between Peak 1 and Peak 4 and their neighboring peaks)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard",
      "characteristicPeaks": "Sample chromatogram must contain 4 characteristic peaks within specified RRT ranges"
    }
  },
