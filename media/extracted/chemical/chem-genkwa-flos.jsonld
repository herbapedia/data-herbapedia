  "tests": {
    "heavyMetals": {
      "appendixReference": "Appendix V",
      "requirements": {
        "lead": "not more than 5.0 ppm",
        "arsenic": "not more than 2.0 ppm",
        "cadmium": "not more than 1.0 ppm",
        "mercury": "not more than 0.2 ppm"
      }
    },
    "pesticideResidues": {
      "appendixReference": "Appendix VI",
      "requirements": {
        "totalBHC": "not more than 0.2 ppm",
        "totalDDT": "not more than 0.2 ppm",
        "PCNB": "not more than 0.1 ppm"
      }
    },
    "mycotoxins": {
      "appendixReference": "Appendix VII",
      "requirements": {
        "totalAflatoxins": "not more than 10 ppb (B1+B2+G1+G2)",
        "aflatoxinB1": "not more than 5 ppb"
      }
    },
    "foreignMatter": {
      "appendixReference": "Appendix VIII",
      "requirement": "not more than 2.0%"
    },
    "ash": {
      "appendixReference": "Appendix IX",
      "totalAsh": "not more than 8.0%",
      "acidInsolubleAsh": "not more than 1.0%"
    },
    "waterContent": {
      "appendixReference": "Appendix X",
      "method": "Toluene distillation method",
      "requirement": "not more than 13.0%"
    },
    "extractives": {
      "appendixReference": "Appendix XI",
      "ethanolSoluble": {
        "method": "Hot extraction method",
        "requirement": "not less than 12.0%"
      }
    }
  },
  "appendices": {
    "appendixI": {
      "title": "Chromatography - Thin-Layer Chromatography (TLC)",
      "description": "General procedures for TLC including plate types, application methods, developing chambers, Rf calculation, and visualization techniques"
    },
    "appendixII": {
      "title": "Gas Chromatographic and HPLC/UHPLC Fingerprinting",
      "description": "Methods for establishing chromatographic fingerprints using marker peaks and RRT values"
    },
    "appendixIII": {
      "title": "Chromatography - HPLC/UHPLC",
      "description": "General HPLC/UHPLC procedures including system suitability tests (theoretical plates, repeatability, resolution, tailing factor) and quantitative calculations"
    }
  },
