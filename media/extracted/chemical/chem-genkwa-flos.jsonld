{
  "@context": "../../../schema/context/core.jsonld",
  "@id": "media/extracted/chemical/genkwa-flos",
  "@type": ["herbapedia:ChemicalAnalysisData", "schema:Dataset"],
  "dataType": "ChemicalAnalysis",
  "sourceDocument": "CHEM____Genkwa_Flos_V1.pdf",
  "scientificName": "Daphne genkwa Sieb. et Zucc.",
  "chineseName": "芫花",
  "pinyinName": "Yuan Hua",
  "identificationMethod": ["TLC", "HPLC-Fingerprint", "HPLC-Assay"],
  "referenceCompounds": [
    {
      "name": "Genkwanin",
      "chineseName": "芫花素",
      "formula": "C₁₆H₁₂O₅",
      "purpose": ["TLC identification", "HPLC fingerprint marker", "HPLC assay quantification"]
    }
  ],
  "assayLimits": {
    "genkwanin": {
      "compound": "Genkwanin",
      "formula": "C₁₆H₁₂O₅",
      "description": "Quantification by HPLC using external standard method"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
    "developingSolvent": {
      "components": ["petroleum ether (60-80°C)", "ethyl acetate", "formic acid"],
      "ratio": "3:2:0.1 (v/v/v)"
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "ethanol",
      "solventVolume": "20 mL",
      "extraction": "ultrasonication at 270 W for 10 minutes",
      "evaporation": "rotary evaporator under reduced pressure to dryness",
      "finalVolume": "1 mL ethanol"
    },
    "standardSolutions": {
      "genkwanin": {
        "concentration": "2.0 mg/mL in ethanol",
        "preparation": "1.0 mg genkwanin reference standard in 0.5 mL ethanol"
      }
    },
    "applicationVolumes": {
      "standardSolution": "2 µL",
      "testSolution": "3 µL"
    },
    "developingDistance": "approximately 5 cm",
    "visualization": "UV light at 254 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Genkwanin"],
      "identificationRequirement": "Sample must show spots or bands with characteristics (color and Rf value) corresponding to genkwanin"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "detector": "DAD (Diode Array Detector)",
      "detectionWavelength": "340 nm",
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 µm"
      },
      "flowRate": "1.0 mL/min",
      "injectionVolume": "10 µL",
      "runTime": "60 min",
      "mobilePhase": {
        "solventA": "0.5% acetic acid (v/v)",
        "solventB": "acetonitrile",
        "gradientProgram": [
          {
            "timeRange": "0-60 min",
            "solventA": "95% → 15%",
            "solventB": "5% → 85%",
            "elution": "linear gradient"
          }
        ]
      }
    },
    "standardSolutions": {
      "fingerprintSolution": {
        "name": "Std-FP",
        "concentration": "48 mg/L",
        "preparation": "1.2 mg genkwanin reference substance in 25 mL methanol"
      }
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "methanol",
      "initialSolventVolume": "10 mL",
      "container": "50 mL centrifuge tube",
      "extraction": "ultrasonication at 270 W for 30 minutes",
      "centrifugation": "approximately 5000 × g for 5 minutes",
      "repeatExtraction": "once",
      "finalVolume": "25 mL volumetric flask with methanol",
      "filtration": "0.45 µm RC (regenerated cellulose) microporous membrane"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (Genkwanin)",
      "retentionTimeRSD": "≤ 2.0% (Genkwanin)",
      "theoreticalPlates": "≥ 300,000 (based on Genkwanin)",
      "resolution": "≥ 1.5 (between peak 8 and adjacent peak)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard"
    }
  },
  "hplcAssay": {
    "appendixReference": "Appendix III",
    "chromatographicSystem": {
      "detector": "DAD (Diode Array Detector)",
      "detectionWavelength": "340 nm",
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 µm"
      },
      "flowRate": "1.0 mL/min",
      "injectionVolume": "10 µL",
      "runTime": "60 min",
      "mobilePhase": {
        "solventA": "0.5% acetic acid (v/v)",
        "solventB": "acetonitrile",
        "gradientProgram": [
          {
            "timeRange": "0-60 min",
            "solventA": "95% → 15%",
            "solventB": "5% → 85%",
            "elution": "linear gradient"
          }
        ]
      }
    },
    "standardSolutions": {
      "stockSolution": {
        "name": "Std-Stock",
        "concentration": "240 mg/L",
        "preparation": "2.4 mg genkwanin reference standard in 10 mL methanol"
      },
      "workingSolutions": {
        "name": "Std-AS",
        "concentrations": ["3", "12", "24", "48", "72 mg/L"],
        "description": "Series of genkwanin standard solutions diluted from stock with methanol"
      },
      "injectionVolume": "10 µL"
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "methanol",
      "extractionVolume": "10 mL × 2 extractions",
      "extraction": "ultrasonication at 270 W for 30 minutes",
      "centrifugation": "approximately 5000 × g for 5 minutes",
      "finalVolume": "25 mL volumetric flask",
      "filtration": "0.45 µm RC (regenerated cellulose) microporous membrane"
    },
    "systemSuitability": {
      "standardSolution": "Std-AS (48 mg/L)",
      "replicateInjections": "5 (minimum)",
      "injectionVolume": "10 µL",
      "peakAreaRSD": "≤ 5.0% (Genkwanin)",
      "retentionTimeRSD": "≤ 2.0% (Genkwanin)",
      "theoreticalPlates": "≥ 300,000 (based on Genkwanin)",
      "resolution": "≥ 1.5 (between Genkwanin peak and adjacent peak)"
    },
    "calibration": {
      "method": "5-point calibration curve",
      "plot": "Peak area vs. concentration (mg/L)",
      "identificationTolerance": "≤ 2.0% difference in retention times"
    }
  },
  "rrtValues": [
