  "assayLimits": {
    "kukoamineB": {
      "compound": "Kukoamine B",
      "formula": "C₂₈H₄₂N₄O₆",
      "minimumContent": "1.0%",
      "basis": "dried substance"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
    "developingSolvent": {
      "components": ["ethyl acetate", "cyclohexane", "glacial acetic acid"],
      "ratio": "6:5:0.2 (v/v)"
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "methanol",
      "solventVolume": "20 mL",
      "extraction": "ultrasonication for 30 minutes",
      "evaporation": "rotary evaporator to dryness",
      "finalVolume": "1 mL methanol"
    },
    "standardSolutions": {
      "scopoletin": {
        "concentration": "0.5 mg/mL in methanol",
        "volume": "0.5 mg in 10 mL methanol"
      }
    },
    "applicationVolumes": {
      "standardSolutions": "2 μL (Scopoletin)",
      "testSolution": "5 μL"
    },
    "developingDistance": "8.5 cm",
    "visualization": "UV light at 366 nm",
    "identificationCriteria": {
      "positiveMarker": "Scopoletin",
      "rfTolerance": "corresponding Rf value to Scopoletin"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "PDA",
      "detectionWavelength": "280 nm",
      "columnTemperature": "40°C",
      "flowRate": "1.0 mL/min",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
      "solventA": "0.15% trifluoroacetic acid in water",
      "solventB": "methanol",
      "gradientProgram": [
        {
          "timeRange": "0-10 min",
          "solventA": "88%",
          "solventB": "12%",
          "elution": "isocratic"
        },
        {
          "timeRange": "10-20 min",
          "solventA": "88% → 84%",
          "solventB": "12% → 16%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "20-40 min",
          "solventA": "84%",
          "solventB": "16%",
          "elution": "isocratic"
        },
        {
          "timeRange": "40-60 min",
          "solventA": "84% → 78%",
          "solventB": "16% → 22%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolutions": {
      "kukoamineB": {
        "concentration": "370 mg/L",
        "preparation": "3.7 mg in 10 mL 50% methanol and 0.5% acetic acid"
      }
    },
    "testSolution": {
      "sampleAmount": "0.2 g",
      "solvent": "50% methanol and 0.5% acetic acid",
      "solventVolume": "20 mL",
      "extraction": "ultrasonication for 30 minutes",
      "centrifugation": "4000 × g for 10 minutes",
      "filtration": "0.45 μm nylon filter"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (Kukoamine B)",
      "retentionTimeRSD": "≤ 2.0% (Kukoamine B)",
      "theoreticalPlates": "≥ 10,000 (based on Kukoamine B)",
      "resolution": "≥ 1.5 (between Kukoamine B and adjacent peaks)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard"
    }
  },
  "hplcAssay": {
    "appendixReference": "Appendix III",
    "chromatographicSystem": {
