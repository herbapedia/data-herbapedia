  "chineseName": "地骨皮",
  "pinyinName": "Di Gu Pi",
  "identificationMethod": ["TLC", "HPLC-Fingerprint", "HPLC-Assay"],
  "referenceCompounds": [
    {
      "name": "Kukoamine B",
      "chineseName": "地骨皮乙素",
      "formula": "C₂₈H₄₂N₄O₆",
      "purpose": ["HPLC fingerprint marker", "HPLC assay quantification"]
    },
    {
      "name": "Scopoletin",
      "chineseName": "東莨菪素",
      "formula": "C₁₀H₈O₄",
      "purpose": ["TLC identification"]
    },
    {
      "name": "Kukoamine A",
      "chineseName": "地骨皮甲素",
      "purpose": ["HPLC fingerprint marker"]
    }
