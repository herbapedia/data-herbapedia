      "compound": "Isoimperatorin",
      "formula": "C16H14O4",
      "minimumContent": "0.21%",
      "basis": "dried substance"
    }
  },
  "physicochemicalIdentification": {
    "method": "Color reaction with hydroxylamine hydrochloride and ferric chloride",
    "procedure": {
      "sampleAmount": "0.5 g",
      "solvent": "diethyl ether",
      "solventVolume": "5 mL",
      "extraction": "sonication (490 W) for 60 minutes",
      "testVolume": "2 mL supernatant",
      "reagent1": "hydroxylamine hydrochloride (7%, v/v)",
      "reagent1Volume": "3 drops",
      "phAdjustment1": "adjust pH to about 9 with sodium hydroxide (10%, w/v)",
      "heating": "water bath for 1 minute",
      "cooling": "cool to room temperature",
      "phAdjustment2": "adjust pH to about 3 with hydrochloric acid (6.2%, v/v)",
      "reagent2": "ferric chloride solution (1%, w/v)",
      "reagent2Volume": "1 drop",
      "positiveResult": "red coloration in the lower layer"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F254 plate",
    "developingSolvent": {
      "components": ["toluene", "ethyl acetate"],
      "ratio": "4:1 (v/v)",
      "preparation": "freshly prepared"
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "methanol",
      "solventVolume": "10 mL",
      "extraction": "sonication (490 W) for 30 minutes",
      "centrifugation": "about 1800 × g for 10 minutes",
      "filtration": "filter through appropriate filter"
    },
    "standardSolutions": {
      "concentration": "1.0 mg/mL in methanol",
      "compounds": ["Isoimperatorin", "Notopterol"]
    },
    "applicationVolumes": {
      "standardSolutions": "1 μL each",
      "testSolution": "1 μL"
    },
    "developingDistance": "about 8 cm",
    "visualization": "UV light at 366 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Isoimperatorin", "Notopterol"]
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
