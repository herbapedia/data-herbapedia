      "solventVolume": "20 mL",
      "extraction": "sonication (490 W) for 60 minutes",
      "centrifugation": "about 1800 × g for 5 minutes",
      "filtration": "0.45 μm RC filter"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 3.0% (Isoimperatorin)",
      "retentionTimeRSD": "≤ 2.0% (Isoimperatorin)",
      "theoreticalPlates": "≥ 50,000 (based on Isoimperatorin)",
      "resolution": "≥ 1.5 (between peak 3 and peak 4)"
    },
    "identificationCriteria": {
