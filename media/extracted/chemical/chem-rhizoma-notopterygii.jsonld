        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "UV",
      "detectionWavelength": "255 nm",
      "flowRate": "0.8 mL/min",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
