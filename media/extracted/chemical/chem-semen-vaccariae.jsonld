      "sampleAmount": "10.0 g",
      "solvent": "dichloromethane-methanol",
      "solventRatio": "4:1 (v/v)",
      "solventVolume": "30 mL",
      "extraction": "Sonication (240 W) for 30 minutes",
      "filtration": "Filter through filter paper",
      "evaporation": "Rotary evaporator at reduced pressure",
      "finalVolume": "1 mL methanol"
    },
    "standardSolutions": {
      "concentration": "1.0 mg/mL in methanol",
      "compounds": ["Segetalin A"]
    },
    "applicationVolumes": {
      "standardSolutions": "6 μL each",
      "testSolution": "6 μL"
    },
    "developingDistance": "8 cm",
    "visualization": "UV light at 366 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Segetalin A"],
      "description": "Sample must give spot or band with chromatographic characteristics, including colour and Rf value, corresponding to those of segetalin A"
