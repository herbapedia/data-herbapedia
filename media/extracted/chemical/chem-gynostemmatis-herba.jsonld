  "assayLimits": {
    "panaxadiol": {
      "compound": "Panaxadiol",
      "formula": "C₃₀H₅₂O₃",
      "minimumContent": "0.094%",
      "basis": "dried substance"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
    "developingSolvent": {
      "components": ["ethyl acetate", "formic acid", "water", "methanol"],
      "ratio": "8:1:1:0.5 (v/v)"
    },
    "sprayReagent": {
      "composition": "2.5 g aluminium trichloride in 100 mL ethanol",
      "visualization": "Heat at about 85°C until spots or bands visible (about 5-10 min)"
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "80% methanol",
      "solventVolume": "20 mL",
      "extraction": "ultrasonication (140 W) for 1 hour",
      "centrifugation": "1800 × g for 15 minutes"
    },
    "standardSolutions": {
      "ombuoside": {
        "concentration": "0.1 mg/mL in methanol",
        "preparation": "Heat in water bath at 60°C to dissolve"
      },
      "rutin": {
        "concentration": "0.5 mg/mL in methanol"
      }
    },
    "applicationVolumes": {
      "ombuosideStandard": "3 μL",
      "rutinStandard": "2 μL",
      "testSolution": "15 μL"
    },
    "developingDistance": "8 cm",
    "visualization": "UV light at 366 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Ombuoside", "Rutin"]
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "370 nm",
      "columnTemperature": "40°C",
      "flowRate": "1.0 mL/min",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
      "solventA": "0.1% Phosphoric acid",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-15 min",
          "solventA": "90% → 80%",
          "solventB": "10% → 20%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "15-50 min",
          "solventA": "80% → 30%",
          "solventB": "20% → 70%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "50-60 min",
          "solventA": "30% → 0%",
          "solventB": "70% → 100%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolutions": {
      "ombuin": {
        "concentration": "30 mg/L",
        "preparation": "0.3 mg in 10 mL methanol"
      },
      "ombuoside": {
        "concentration": "35 mg/L",
        "preparation": "0.35 mg in 10 mL methanol, heat at 60°C to dissolve"
      },
      "quercetin": {
        "concentration": "50 mg/L",
        "preparation": "0.5 mg in 10 mL methanol"
      },
      "rutin": {
        "concentration": "120 mg/L",
        "preparation": "1.2 mg in 10 mL methanol"
      }
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "methanol",
      "solventVolume": "20 mL",
      "finalVolume": "25 mL",
      "extraction": "ultrasonication (270 W) for 1 hour",
      "centrifugation": "1800 × g for 10 minutes",
      "filtration": "0.45 μm PTFE filter"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (ombuin, ombuoside, quercetin, rutin)",
      "retentionTimeRSD": "≤ 2.0% (ombuin, ombuoside, quercetin, rutin)",
      "theoreticalPlates": "≥ 20,000 (ombuin, ombuoside, quercetin, rutin)",
      "resolution": "≥ 1.0 (between peaks 1, 2, 3, 5 and their adjacent peaks)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard"
    }
  },
  "hplcAssay": {
    "appendixReference": "Appendix III",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 150 mm",
        "particleSize": "5 μm"
      },
      "detector": "ELSD",
      "detectorSettings": {
        "driftTubeTemperature": "75°C",
        "nebulizerGas": "N₂",
        "gasFlow": "2.0 L/min"
      },
      "columnTemperature": "30°C",
      "flowRate": "1.0 mL/min",
      "runTime": "about 30 min"
    },
    "mobilePhase": {
      "solventA": "Water",
      "solventB": "Methanol",
      "ratio": "12:88 (v/v)",
      "elution": "isocratic"
    },
    "standardSolutions": {
      "stockSolution": {
        "name": "Panaxadiol Std-Stock",
        "concentration": "1000 mg/L",
        "preparation": "10.0 mg in 10 mL methanol"
      },
      "workingSolutions": {
        "name": "Panaxadiol Std-AS",
        "concentrations": ["16", "40", "80", "200", "500 mg/L"],
        "description": "Series of standard solutions diluted from stock"
      },
      "injectionVolume": "20 μL"
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "methanol",
      "extractionVolume": "15 mL × 3 extractions",
      "washVolume": "5 mL × 3 washes",
      "extraction": "ultrasonication (270 W) for 30 minutes",
      "centrifugation": "1800 × g for 10 minutes",
      "hydrolysis": {
        "reagent": "29.5% (w/v) hydrochloric acid",
        "volume": "20 mL",
        "duration": "4 hours reflux"
      },
      "liquidLiquidExtraction": {
        "solvent": "dichloromethane",
        "volume": "30 mL × 3 extractions"
      },
      "evaporation": "rotary evaporator at reduced pressure",
      "finalVolume": "10 mL",
      "filtration": "0.45 μm PTFE filter",
      "injectionVolume": "20 μL"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "injectionVolume": "20 μL",
      "standardConcentration": "80 mg/L (Panaxadiol Std-AS)",
      "peakAreaRSD": "≤ 5.0% (Panaxadiol)",
      "retentionTimeRSD": "≤ 2.0% (Panaxadiol)",
      "theoreticalPlates": "≥ 5,000 (Panaxadiol)",
      "resolution": "≥ 1.5 (between Panaxadiol peak and adjacent peak)"
    },
    "calibration": {
      "method": "5-point calibration curve",
      "plot": "Natural logarithm of peak area vs. natural logarithm of concentration (mg/L)",
      "formula": "Concentration = e^[Ln(A)-I]/m",
      "identificationTolerance": "≤ 2.0% difference in retention times"
    }
  },
