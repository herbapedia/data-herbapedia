  "dataType": "ChemicalAnalysis",
  "sourceDocument": "CHEM____Polygoni_Cuspidati_Rhizoma_et_Radix_V1.pdf",
  "scientificName": "Polygonum cuspidatum",
  "chineseName": "虎杖",
  "pinyinName": "Huzhang",
  "identificationMethod": ["TLC", "HPLC-Fingerprint", "HPLC-Assay"],
  "referenceCompounds": [
    {
      "name": "Polydatin",
      "chineseName": "虎杖苷",
      "purpose": ["TLC identification", "HPLC fingerprint marker", "Assay quantification"]
    },
    {
      "name": "Resveratrol",
      "chineseName": "白藜蘆醇",
      "purpose": ["HPLC fingerprint marker", "Assay quantification"]
    }
  ],
  "assayLimits": {
    "polydatin": {
      "compound": "Polydatin",
      "minimumContent": "Calculated from calibration curve",
      "basis": "dried substance"
    },
    "resveratrol": {
      "compound": "Resveratrol",
      "minimumContent": "Calculated from calibration curve",
      "basis": "dried substance"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "Polyamide thin-layer plate",
    "developingSolvent": {
      "components": ["water", "ethanol", "ethyl acetate", "acetic acid"],
      "ratio": "4:2:1:0.5 (v/v)"
    },
    "testSolution": {
      "sampleAmount": "0.2 g",
      "solvent": "ethanol",
      "solventVolume": "20 mL",
      "extraction": "ultrasonication at 240 W for 30 minutes"
    },
    "standardSolution": {
      "compound": "Polydatin",
      "concentration": "0.052 mg/mL (1.3 mg in 25 mL ethanol)"
    },
    "applicationVolumes": {
      "standardSolution": "2 μL",
      "testSolution": "2 μL"
    },
    "developingDistance": "7 cm",
    "chamberSetup": {
      "type": "twin-trough developing chamber",
      "preSaturation": "15 minutes"
    },
    "visualization": "UV light at 366 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Polydatin"],
      "criterion": "Sample must show spots or bands corresponding in color and Rf value to the polydatin reference solution"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "240 nm",
      "flowRate": "1.0 mL/min",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
      "solventA": "Water",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-20 min",
          "solventA": "84%",
          "solventB": "16%",
          "elution": "isocratic"
        },
        {
          "timeRange": "20-40 min",
          "solventA": "84% → 74%",
          "solventB": "16% → 26%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "40-60 min",
          "solventA": "74%",
          "solventB": "26%",
          "elution": "isocratic"
        }
      ]
    },
    "standardSolutions": {
      "polydatin": {
        "concentration": "120 mg/L (1.2 mg in 10 mL ethanol)"
      },
      "resveratrol": {
        "concentration": "130 mg/L (1.3 mg in 10 mL ethanol)"
      }
    },
    "testSolution": {
      "sampleAmount": "0.1 g",
      "solvent": "methanol",
      "solventVolume": "10 mL",
      "extraction": "ultrasonication at 240 W for 30 minutes",
      "centrifugation": "3000 × g for 5 minutes",
      "filtration": "0.45 μm PTFE membrane"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (Polydatin and Resveratrol)",
      "retentionTimeRSD": "≤ 2.0% (Polydatin and Resveratrol)",
      "theoreticalPlates": "≥ 8,000 (Polydatin), ≥ 70,000 (Resveratrol)",
      "resolution": "≥ 1.0 (between Peak 1 and adjacent peak, and Peak 2 and adjacent peak)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard"
    }
  },
  "hplcAssay": {
    "appendixReference": "Appendix III",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "306 nm",
      "flowRate": "1.0 mL/min"
    },
    "mobilePhase": {
      "solventA": "Water",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-12 min",
          "solventA": "80%",
          "solventB": "20%",
          "elution": "isocratic"
        },
        {
          "timeRange": "12-13 min",
          "solventA": "80% → 70%",
          "solventB": "20% → 30%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "13-30 min",
          "solventA": "70%",
          "solventB": "30%",
          "elution": "isocratic"
        }
      ]
    },
    "standardSolutions": {
      "stockSolution": {
        "polydatin": {
          "concentration": "600 mg/L (3.0 mg in 5 mL ethanol)"
        },
        "resveratrol": {
          "concentration": "660 mg/L (3.3 mg in 5 mL ethanol)"
        }
      },
      "workingSolutions": {
        "polydatinConcentrations": ["4.8", "9.6", "36", "60", "108 mg/L"],
        "resveratrolConcentrations": ["5.28", "10.56", "39.6", "66", "118.8 mg/L"]
      }
    },
    "testSolution": {
      "sampleAmount": "0.1 g",
      "solvent": "ethanol",
      "extractionVolume": "10 mL + 5 mL (two extractions)",
      "extraction": "ultrasonication at 240 W for 30 minutes each",
      "centrifugation": "3000 × g for 5 minutes",
      "finalVolume": "25 mL",
      "filtration": "0.45 μm PTFE membrane"
    },
    "calibration": {
      "method": "5-point calibration curve",
      "plot": "Peak area vs. concentration (mg/L)"
    }
  },
  "rrtValues": [
    {
      "peakNumber": 1,
      "compound": "Polydatin",
      "chineseName": "虎杖苷",
      "rrt": 0.43,
      "acceptableRange": "±0.03",
      "referenceMarker": false,
      "referenceTo": "Resveratrol"
    },
    {
      "peakNumber": 2,
      "compound": "Resveratrol",
      "chineseName": "白藜蘆醇",
      "rrt": 1.00,
      "acceptableRange": null,
      "referenceMarker": true,
      "referenceTo": "self"
    },
    {
      "peakNumber": 3,
      "compound": "Characteristic peak 3",
      "rrt": 1.15,
      "acceptableRange": "±0.03",
      "referenceMarker": false,
      "referenceTo": "Resveratrol"
    },
    {
      "peakNumber": 4,
      "compound": "Characteristic peak 4",
      "rrt": 1.21,
      "acceptableRange": "±0.03",
      "referenceMarker": false,
      "referenceTo": "Resveratrol"
    }
  ],
  "appendices": {
    "appendixI": {
      "title": "Chromatography – Thin-Layer Chromatography",
      "description": "General procedures for TLC including plate types, application methods, developing chambers, Rf calculation, and saturation requirements"
    },
    "appendixII": {
      "title": "GC and HPLC/UHPLC Fingerprinting",
      "description": "Methods for establishing chromatographic fingerprints using marker peaks and RRT values. Reference fingerprint based on at least 10 batches tested in duplicate (20 data sets)"
    },
    "appendixIII": {
      "title": "Chromatography – HPLC/UHPLC",
      "description": "General HPLC/UHPLC procedures including system suitability tests (theoretical plates, repeatability, resolution, tailing factor) and quantitative calculations using 5-point calibration curves"
    }
  },
