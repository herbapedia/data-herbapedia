  "assayLimits": {
    "gentiopicroside": {
      "compound": "Gentiopicroside",
      "formula": "C₁₆H₂₀O₉",
      "minimumContent": "3.7%",
      "basis": "dried substance"
    },
    "loganicAcid": {
      "compound": "Loganic acid",
      "formula": "C₁₆H₂₄O₁₀",
      "minimumContent": "1.5%",
      "basis": "dried substance"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
    "developingSolvent": {
      "components": ["ethyl acetate", "ethanol", "water", "glacial acetic acid"],
      "ratio": "5:1:0.5:0.1 (v/v)"
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "ethanol",
      "solventVolume": "5 mL",
      "extraction": "ultrasonication (270 W) for 15 minutes"
    },
    "standardSolutions": {
      "gentiopicroside": {
        "concentration": "1.0 mg/mL in ethanol"
      },
      "loganicAcid": {
        "concentration": "1.0 mg/mL in ethanol"
      }
    },
    "applicationVolumes": {
      "gentiopicrosideStandard": "1 μL",
      "loganicAcidStandard": "2 μL",
      "testSolution": "1 μL"
    },
    "developingDistance": "5 cm",
    "chamberSaturation": "15 minutes in twin trough chamber",
    "visualization": "UV light at 254 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Gentiopicroside", "Loganic acid"],
      "description": "Sample must give spots or bands with chromatographic characteristics, including colour and Rf values, corresponding to those of gentiopicroside and loganic acid"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "254 nm",
      "flowRate": "1.0 mL/min",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
      "solventA": "0.1% Acetic acid",
      "solventB": "Acetonitrile",
      "gradientProgram": [
        {
          "timeRange": "0-60 min",
          "solventA": "95% → 85%",
          "solventB": "5% → 15%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolutions": {
      "gentiopicrosideStdFP": {
        "concentration": "800 mg/L",
        "preparation": "8.0 mg in 10 mL water"
      },
      "loganicAcidStdFP": {
        "concentration": "300 mg/L",
        "preparation": "3.0 mg in 10 mL water"
      }
    },
    "testSolution": {
      "sampleAmount": "0.25 g",
      "solvent": "water",
      "solventVolume": "10 mL × 2 extractions",
      "extraction": "ultrasonication (270 W) for 30 minutes",
      "centrifugation": "5000 × g for 5 minutes",
      "finalVolume": "25 mL",
      "filtration": "0.45 μm RC filter"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0% (Gentiopicroside and Loganic acid)",
      "retentionTimeRSD": "≤ 2.0% (Gentiopicroside and Loganic acid)",
      "theoreticalPlates": {
        "gentiopicroside": "≥ 35000",
        "loganicAcid": "≥ 20000"
      },
      "resolution": "≥ 1.5 (between peak 1 and closest peak; between peak 4 and closest peak)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard"
    }
  },
  "hplcAssay": {
