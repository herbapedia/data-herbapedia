  "appendices": {
    "appendixI": {
      "title": "Chromatography - Thin-Layer Chromatography (TLC)",
      "description": "General procedures for TLC including plate types (silica gel G, F254, HPTLC), application methods, developing chambers (twin trough), Rf calculation, and visualization techniques under UV light"
    },
    "appendixII": {
      "title": "Gas Chromatographic and HPLC/UHPLC Fingerprinting",
      "description": "Methods for establishing chromatographic fingerprints using marker peaks and RRT values. Requires at least 10 batches of representative samples tested in duplicate (20 data sets)"
    },
    "appendixIII": {
      "title": "Chromatography - HPLC/UHPLC",
      "description": "General HPLC/UHPLC procedures including system suitability tests (theoretical plates, repeatability, resolution, tailing factor) and quantitative calculations using calibration curves"
    }
