{
  "@context": "../../../schema/context/core.jsonld",
  "@id": "media/extracted/chemical/radix-rehmanniae",
  "@type": ["herbapedia:ChemicalAnalysisData", "schema:Dataset"],
  "dataType": "ChemicalAnalysis",
  "sourceDocument": "CHEM____Radix_Rehmanniae_V1.pdf",
  "scientificName": "Rehmannia glutinosa",
  "chineseName": "地黃",
  "pinyinName": "Di Huang",
  "identificationMethod": ["TLC", "HPLC-Fingerprint", "HPLC-Assay"],
  "referenceCompounds": [
    {
      "name": "Catalpol",
      "chineseName": "梓醇",
      "purpose": ["TLC identification", "HPLC fingerprint marker peak", "Assay quantification"]
    }
  ],
  "assayLimits": {
    "catalpol": {
      "compound": "Catalpol",
      "chineseName": "梓醇",
      "basis": "dried substance"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
    "developingSolvent": {
      "components": ["dichloromethane", "methanol"],
      "ratio": "26:14 (v/v)"
    },
    "sprayReagent": {
      "composition": "10 mL sulfuric acid in 90 mL ethanol",
      "visualization": "Heat at 120°C for 5-10 minutes until spots appear"
    },
    "testSolution": {
      "sampleAmount": "5.0 g",
      "solvent": "methanol",
      "solventVolume": "100 mL",
      "extraction": "stirred for 5 minutes, shaken at room temperature for 30 minutes",
      "centrifugation": "~1800 × g for 10 minutes",
      "evaporation": "supernatant evaporated to dryness under reduced pressure",
      "purification": "residue dissolved in 20 mL water, extracted 3 times with ethyl acetate (20 mL each)",
      "finalStep": "combined ethyl acetate extracts evaporated to dryness, residue dissolved in 1 mL methanol, filtered"
    },
    "standardSolution": {
      "compound": "Catalpol",
      "preparation": "0.5 mg in 5 mL methanol",
      "concentration": "0.1 mg/mL"
    },
    "applicationVolumes": {
      "standardSolution": "2.5 μL",
      "testSolution": "2 μL"
    },
    "developingDistance": "approximately 5 cm",
    "visualization": "UV light at 366 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Catalpol"],
      "criteria": "chromatogram should show characteristic spots or bands with the same color and Rf values as the catalpol reference standard"
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "210 nm",
      "flowRate": "approximately 0.6 mL/min",
      "injectionVolume": "10 μL"
    },
    "mobilePhase": {
      "solventA": "0.1% Phosphoric acid (%, v/v)",
      "solventB": "Acetonitrile (%, v/v)",
      "gradientProgram": [
        {
          "timeRange": "0-10 min",
          "solventA": "99%",
          "solventB": "1%",
          "elution": "isocratic"
        },
        {
          "timeRange": "10-30 min",
          "solventA": "99% → 95.5%",
          "solventB": "1% → 4.5%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "30-60 min",
          "solventA": "95.5% → 90%",
          "solventB": "4.5% → 10%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolution": {
      "name": "Std-FP",
      "compound": "Catalpol",
      "concentration": "200 mg/L",
      "preparation": "2.0 mg in 10 mL of 20% methanol"
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "20% methanol",
      "solventVolume": "25 mL",
      "extraction": "ultrasonic treatment (270 W) for 60 minutes",
      "centrifugation": "~1800 × g for 10 minutes",
      "finalVolume": "25 mL volumetric flask, diluted to mark with 20% methanol",
      "filtration": "0.45 μm PTFE microporous membrane"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 3.0%",
      "retentionTimeRSD": "≤ 2.0%",
      "theoreticalPlates": "≥ 20,000 (based on Catalpol peak)",
      "resolution": "≥ 1.0 (between peak number 4 and its adjacent peaks)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard",
      "characteristicPeaks": 6,
      "markerPeak": {
        "peakNumber": 4,
        "compound": "Catalpol",
        "rrt": 1.00
      }
    }
  },
  "hplcAssay": {
    "appendixReference": "Appendix III",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 150 mm",
        "particleSize": "5 μm"
      },
      "detector": "DAD",
      "detectionWavelength": "210 nm",
      "flowRate": "approximately 0.6 mL/min"
    },
    "mobilePhase": {
      "solventA": "0.1% Phosphoric acid (%, v/v)",
      "solventB": "Acetonitrile (%, v/v)",
      "gradientProgram": [
        {
          "timeRange": "0-10 min",
          "solventA": "99%",
          "solventB": "1%",
          "elution": "isocratic"
        },
        {
          "timeRange": "10-30 min",
          "solventA": "99% → 95.5%",
          "solventB": "1% → 4.5%",
          "elution": "linear gradient"
        },
        {
          "timeRange": "30-60 min",
          "solventA": "95.5% → 90%",
          "solventB": "4.5% → 10%",
          "elution": "linear gradient"
        }
      ]
    },
    "standardSolutions": {
      "stockSolution": {
        "name": "Std-Stock",
        "concentration": "1000 mg/L",
        "compound": "Catalpol",
        "preparation": "10.0 mg in 10 mL of 20% methanol"
      },
      "workingSolutions": {
        "name": "Std-AS",
        "concentrations": ["20", "50", "100", "150", "200 mg/L"],
        "description": "Series of working standards diluted from stock with 20% methanol"
      }
    },
    "testSolution": {
      "sampleAmount": "0.5 g",
      "solvent": "20% methanol",
      "initialVolume": "10 mL",
      "extraction": "ultrasonic treatment (270 W) for 30 minutes",
      "centrifugation": "~1800 × g for 10 minutes",
      "reExtraction": "3 mL of 20% methanol added to residue, centrifuged again for 10 minutes",
      "finalVolume": "25 mL volumetric flask, diluted to mark with 20% methanol",
      "filtration": "0.45 μm PTFE microporous membrane"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 3.0%",
      "retentionTimeRSD": "≤ 2.0%",
      "theoreticalPlates": "≥ 20,000 (based on Catalpol peak)"
    },
    "calibration": {
      "method": "5-point calibration curve",
      "plot": "Peak area vs. concentration (mg/L)",
      "concentrations": ["20", "50", "100", "150", "200 mg/L"]
    }
  },
  "rrtValues": [
    {
      "peakNumber": 1,
