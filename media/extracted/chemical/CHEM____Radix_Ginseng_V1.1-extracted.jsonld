  "sourceDocument": "CHEM____Radix_Ginseng_V1.1.pdf",
  "scientificName": "Panax ginseng",
  "chineseName": "人參",
  "pinyinName": "Ren Shen",
  "identificationMethod": ["Physicochemical", "TLC", "HPLC-Fingerprint", "HPLC-Assay"],
  "referenceCompounds": [
    {
      "name": "Ginsenoside Rb₁",
      "chineseName": "人參皂苷 Rb₁",
      "formula": "C₅₄H₉₂O₂₃",
      "purpose": ["TLC identification", "HPLC fingerprint marker", "Assay quantification"]
    },
    {
      "name": "Ginsenoside Re",
      "chineseName": "人參皂苷 Re",
      "formula": "C₄₈H₈₂O₁₈",
      "purpose": ["HPLC fingerprint marker", "Assay quantification"]
    },
    {
      "name": "Ginsenoside Rg₁",
      "chineseName": "人參皂苷 Rg₁",
      "formula": "C₄₂H₇₂O₁₄",
      "purpose": ["TLC identification", "HPLC fingerprint marker", "Assay quantification"]
    },
    {
      "name": "Ginsenoside Rc",
      "chineseName": "人參皂苷 Rc",
      "purpose": ["TLC identification", "HPLC fingerprint marker"]
    },
    {
      "name": "Ginsenoside Rf",
      "chineseName": "人參皂苷 Rf",
      "purpose": ["TLC identification", "HPLC fingerprint marker"]
    },
    {
      "name": "Ginsenoside Rb₂",
      "chineseName": "人參皂苷 Rb₂",
      "purpose": ["HPLC fingerprint marker"]
    },
    {
      "name": "Ginsenoside Rd",
      "chineseName": "人參皂苷 Rd",
      "purpose": ["HPLC fingerprint marker"]
    },
