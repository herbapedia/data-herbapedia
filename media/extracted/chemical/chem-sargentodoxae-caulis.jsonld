      }
    },
    "testSolution": {
      "sampleAmount": "1.0 g",
      "solvent": "water",
      "extractionVolume": "10 mL × 2 extractions",
      "extraction": "ultrasonication (270 W) for 30 minutes",
      "centrifugation": "5000 × g for 5 minutes",
      "finalVolume": "25 mL",
      "filtration": "0.2 μm nylon membrane filter",
      "injectionVolume": "5 μL"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 5.0%",
      "retentionTimeRSD": "≤ 2.0%"
    },
    "calibration": {
      "method": "5-point calibration curve",
      "plot": "Peak area vs. concentration (mg/L)",
