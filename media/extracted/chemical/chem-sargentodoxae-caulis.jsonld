  "appendices": {
    "appendixI": {
      "title": "Chromatography – Thin-Layer Chromatography (TLC)",
      "description": "General procedures for TLC including plate types, application methods, developing chambers, Rf calculation, and interpretation of chromatograms"
    },
    "appendixII": {
      "title": "Gas Chromatographic and High-Performance/Ultra-High Performance Liquid Chromatographic Fingerprinting",
      "description": "Methods for establishing chromatographic fingerprints using marker peaks and RRT values, including requirements for reference fingerprint chromatograms based on at least 10 batches of representative samples"
