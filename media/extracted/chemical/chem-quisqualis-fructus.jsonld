  "assayLimits": {
    "quisqualicAcid": {
      "compound": "Quisqualic acid",
      "formula": "C₅H₇N₃O₅",
      "minimumContent": "0.63%",
      "basis": "dried substance"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel GHLF254 plate (150 μm thickness)",
    "developingSolvent": {
      "components": ["n-butanol", "glacial acetic acid", "water"],
      "ratio": "3:1:1 (v/v)"
    },
    "sprayReagent": {
      "composition": "2 g ninhydrin in 100 mL acetone",
      "visualization": "Heat at about 105°C until spots or bands become visible (about 3-5 min)"
    },
    "testSolution": {
      "sampleAmount": "0.4 g",
      "solvent": "methanol (50%)",
      "solventVolume": "5 mL",
      "extraction": "sonication (140 W) for 15 min",
      "centrifugation": "about 2800 × g for 10 min",
      "filtration": "0.45-μm PTFE filter"
    },
    "standardSolutions": {
      "concentration": "0.5 mg/mL in methanol (50%)",
      "compounds": ["Quisqualic acid"]
    },
    "applicationVolumes": {
      "standardSolution": "1.5 μL",
      "testSolution": "1.5 - 4.5 μL"
    },
    "developingDistance": "8 cm",
    "chamberSaturation": "15 min",
    "visualization": "visible light after staining",
    "identificationCriteria": {
      "positiveMarkers": ["Quisqualic acid"]
    }
  },
  "hplcFingerprint": {
    "appendixReference": "Appendix II",
    "chromatographicSystem": {
      "column": {
        "type": "ODS bonded silica gel (C18)",
        "dimensions": "4.6 × 250 mm",
        "particleSize": "5 μm"
      },
      "detector": "Fluorescence",
      "excitationWavelength": "338 nm",
      "emissionWavelength": "450 nm",
      "columnTemperature": "30°C",
      "flowRate": "1.0 mL/min"
    },
    "mobilePhase": {
      "solventA": "0.01 M Sodium acetate buffer solution (pH 4.6)",
      "solventB": "Methanol",
      "gradientProgram": [
        {
          "timeRange": "0-5 min",
          "solventA": "80%",
          "solventB": "20%",
          "elution": "isocratic"
        },
        {
          "timeRange": "5-60 min",
          "solventA": "80% → 20%",
          "solventB": "20% → 80%",
          "elution": "linear gradient"
        }
      ]
    },
    "reagents": {
      "aceticAcidSolution": {
        "concentration": "0.2 M",
        "preparation": "Pipette 11.4 mL of acetic acid and add 1000 mL of water"
      },
      "sodiumAcetateBuffer": {
        "concentration": "0.01 M",
        "pH": "4.6",
        "preparation": "Weigh 16.4 g of sodium acetate and dissolve in 1000 mL of water. Pipette 24.5 mL of the solution and 25.5 mL of 0.2 M acetic acid solution to a 1000-mL volumetric flask. Make up to the mark with water"
      },
      "sodiumHydroxideSolution": {
        "concentration": "10 M",
        "preparation": "Weigh 40.0 g of sodium hydroxide and dissolve in 100 mL of water"
      },
      "boricAcidBuffer": {
        "concentration": "0.04 M",
        "pH": "10.5",
        "preparation": "Weigh 2.5 g of boric acid and dissolve in 1000 mL of water. Adjust the pH value to 10.5 with 10 M sodium hydroxide solution"
      },
      "oPhthalaldehydeSolution": {
        "composition": "70.0 mg o-phthalaldehyde in 1 mL methanol, 95 mL 0.04 M boric acid buffer solution (pH 10.5) and 0.2 mL 2-mercaptoethanol",
        "note": "Freshly prepare"
      }
    },
    "standardSolutions": {
      "quisqualicAcid": {
        "stockSolution": "50 mg/L (0.5 mg in 10 mL methanol 50%)",
        "designation": "Std-FP"
      }
    },
    "testSolution": {
      "sampleAmount": "0.2 g",
      "solvent": "methanol (50%)",
      "extractionVolume": "10 mL × 2 extractions",
      "extraction": "sonication (270 W) for 30 min",
      "centrifugation": "about 1800 × g for 10 min",
      "finalVolume": "25 mL",
      "filtration": "0.45-μm PTFE filter"
    },
    "derivatization": {
      "procedure": "Pipette 200 μL of the standard solution or the test solution to a 2-mL vial, then pipette 400 μL of o-phthalaldehyde solution",
      "note": "Freshly prepare and analyze within 10 min"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "injectionVolume": "10 μL",
      "peakAreaRSD": "≤ 5.0% (Quisqualic acid)",
      "retentionTimeRSD": "≤ 2.0% (Quisqualic acid)",
      "theoreticalPlates": "≥ 20,000 (based on Quisqualic acid)",
      "resolution": "≥ 1.5 (between peak 2 and the closest peak)"
    },
    "identificationCriteria": {
      "retentionTimeTolerance": "≤ 2.0% difference between sample and standard"
    }
  },
