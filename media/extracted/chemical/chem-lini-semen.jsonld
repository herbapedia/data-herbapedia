  "assayLimits": {
    "fattyAcids": {
      "compounds": ["Linoleic acid", "α-Linolenic acid"],
      "formulas": ["C₁₈H₃₂O₂", "C₁₈H₃₀O₂"],
      "minimumContent": "0.56%",
      "basis": "dried substance (combined total)"
    },
    "secoisolariciresinolDiglucoside": {
      "compound": "Secoisolariciresinol 1,4-diglucoside",
      "formula": "C₃₂H₄₆O₁₆",
      "minimumContent": "0.81%",
      "basis": "dried substance"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "stationaryPhase": "HPTLC silica gel RP-18 F₂₅₄ plate",
    "developingSolvent": {
      "components": ["acetone", "glacial acetic acid", "dichloromethane"],
      "ratio": "5:4:2 (v/v)"
    },
    "sprayReagent": {
      "composition": "5 mL sulfuric acid in 95 mL ethanol",
      "visualization": "Heat at approximately 105°C for 3-5 minutes, view under UV light at 366 nm"
    },
    "standardSolutions": {
      "linoleicAcid": {
        "concentration": "0.2 mg/mL in ethanol",
        "volume": "3.5 μL"
      },
      "alphaLinolenicAcid": {
        "concentration": "0.2 mg/mL in ethanol",
        "volume": "2.5 μL"
      }
    },
    "testSolution": {
      "sampleAmount": "0.2 g",
      "solvent": "n-hexane",
      "solventVolume": "50 mL",
      "extraction": "ultrasonication (300 W) in water bath at approximately 60°C for 1 hour",
      "evaporation": "rotary evaporator under reduced pressure",
      "redissolution": "5 mL isopropanol",
      "filtration": "0.45-μm PTFE microporous membrane",
      "volume": "6 μL"
    },
    "developingDistance": "8 cm",
    "saturationTime": "15 minutes",
    "visualization": "UV light at 366 nm",
    "identificationCriteria": {
      "positiveMarkers": ["Linoleic acid", "α-Linolenic acid"],
      "description": "Sample chromatogram should exhibit characteristic spots or bands with corresponding color and Rf values to linoleic acid and α-linolenic acid"
    }
  },
  "hplcFingerprint": {
