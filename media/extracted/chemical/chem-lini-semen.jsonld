      },
      "alphaLinolenicAcid": {
        "concentration": "40 mg/L (Std-FP)",
        "preparation": "0.4 mg in 10 mL ethanol"
      }
    },
    "testSolution": {
      "sampleAmount": "0.2 g",
      "solvent": "n-hexane",
      "solventVolume": "50 mL × 3 extractions",
      "extraction": "ultrasonication (300 W) in water bath at approximately 60°C for 1 hour",
      "centrifugation": "4000 × g for 10 minutes",
      "evaporation": "rotary evaporator under reduced pressure",
      "redissolution": "isopropanol to 25 mL volumetric flask",
      "filtration": "0.45-μm PTFE microporous membrane"
    },
    "systemSuitability": {
