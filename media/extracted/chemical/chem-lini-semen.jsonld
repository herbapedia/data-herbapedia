      "peakAreaRSD": "≤ 5.0% (Linoleic acid and α-Linolenic acid)",
      "retentionTimeRSD": "≤ 2.0% (Linoleic acid and α-Linolenic acid)",
      "theoreticalPlates": "≥ 32,000 (based on Linoleic acid and α-Linolenic acid)",
