      "name": "Secoisolariciresinol 1,4-diglucoside",
      "chineseName": "開環異落葉松樹脂酚 1,4-二葡萄糖苷",
      "formula": "C₃₂H₄₆O₁₆",
      "purpose": ["Assay quantification"]
    }
