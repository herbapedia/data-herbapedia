      "minimumContent": "0.60%",
      "basis": "dried substance"
    }
  },
  "physicochemicalIdentification": {
    "method": "Fluorescence reaction",
    "procedure": {
      "sampleAmount": "0.2 g",
      "solvent": "70% ethanol",
      "solventVolume": "2 mL",
      "extraction": "ultrasonication for 60 minutes",
      "testMethod": "spot supernatant onto filter paper",
      "visualization": "UV light at 254 nm",
      "positiveResult": "fluorescent blue spot"
    }
  },
  "tlcMethod": {
    "appendixReference": "Appendix I",
    "lipidSolubleComponents": {
      "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
      "standardSolution": {
        "compound": "Z-ligustilide",
        "concentration": "1.0 mg in 1 mL methanol"
      },
      "developingSolvent": {
        "components": ["hexane", "ethyl acetate"],
        "ratio": "5:1 (v/v)"
      },
      "sprayReagent": {
        "composition": "10 mL sulfuric acid in 90 mL ethanol",
        "visualization": "Heat at 110°C for 10 minutes, UV light at 366 nm"
      },
      "testSolution": {
        "sampleAmount": "1.0 g",
        "solvent": "diethyl ether",
        "solventVolume": "10 mL",
        "extraction": "shake occasionally for 2 hours",
        "centrifugation": "1200 × g for 10 minutes",
        "evaporation": "water bath below 50°C",
        "finalDissolution": "1 mL ethyl acetate"
      },
      "applicationVolume": "4 µL each",
      "developingDistance": "8 cm",
      "identificationCriteria": {
        "positiveMarkers": ["Z-ligustilide (matching color and Rf value)"]
      }
    },
    "waterSolubleComponents": {
      "stationaryPhase": "HPTLC silica gel F₂₅₄ plate",
      "standardSolution": {
        "compound": "Ferulic acid",
        "concentration": "0.5 mg in 1 mL methanol"
      },
      "developingSolvent": {
        "components": ["chloroform", "ethyl acetate", "formic acid"],
        "ratio": "10:5:0.5 (v/v)"
      },
      "sprayReagent": {
        "composition": "10 mL sulfuric acid in 90 mL ethanol",
        "visualization": "Heat at 110°C for 10 minutes, UV light at 366 nm"
      },
      "testSolution": {
        "sampleAmount": "2.0 g",
        "solvent": "methanol",
        "solventVolume": "20 mL",
        "extraction": "ultrasonication for 30 minutes",
        "centrifugation": "1200 × g for 10 minutes",
        "evaporation": "rotary evaporator at reduced pressure",
        "defatting": "hexane extraction (2 × 20 mL, discard)",
        "acidification": "adjust to pH 2 with 2M HCl",
        "extraction2": "diethyl ether (3 × 10 mL)",
        "finalDissolution": "0.5 mL ethyl acetate"
      },
      "applicationVolume": "4 µL each",
      "developingDistance": "8.5 cm",
      "identificationCriteria": {
        "positiveMarkers": ["Ferulic acid (matching color and Rf value)"]
      }
    }
  },
