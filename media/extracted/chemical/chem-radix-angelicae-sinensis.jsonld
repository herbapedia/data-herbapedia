      "solventVolume": "25 mL",
      "extraction": "ultrasonication for 100 minutes",
      "centrifugation": "540 × g for 5 minutes",
      "filtration": "0.2 µm PTFE filter"
    },
    "systemSuitability": {
      "replicateInjections": "5 (minimum)",
      "peakAreaRSD": "≤ 3.0% (Z-ligustilide)",
      "retentionTimeRSD": "≤ 3.0% (Z-ligustilide)",
      "theoreticalPlates": "≥ 300,000 (based on Z-ligustilide)",
