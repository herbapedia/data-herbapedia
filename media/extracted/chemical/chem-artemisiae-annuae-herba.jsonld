  "appendices": {
    "appendixI": {
      "title": "Chromatography - Thin-Layer Chromatography",
      "description": "General procedures for TLC including plate types, application methods, developing chambers, Rf calculation and interpretation"
    },
    "appendixII": {
      "title": "GC and HPLC/UHPLC Fingerprinting",
      "description": "Methods for establishing chromatographic fingerprints using marker peaks, RRT values, and system suitability requirements"
    },
    "appendixIII": {
      "title": "Liquid Chromatography-Mass Spectrometry (LC-MS)",
