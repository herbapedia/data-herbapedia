{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://herbapedia.org/schema/json-schema/reference/mongolian-element.schema.json",
  "title": "Mongolian Element",
  "description": "Mongolian Traditional Medicine five elements ( таван махбод). Wood, Fire, Earth, Metal, Water. Each element is associated with specific organs, seasons, and energetic qualities.",
  "type": "object",
  "allOf": [
    { "$ref": "./reference-entity.schema.json" }
  ],
  "required": ["@id", "@type", "name"],
  "properties": {
    "@id": {
      "description": "Unique identifier: mongolian/element/{slug}.",
      "type": "string",
      "pattern": "^mongolian/element/[a-z0-9-]+$",
      "examples": [
        "mongolian/element/wood",
        "mongolian/element/fire",
        "mongolian/element/earth",
        "mongolian/element/metal",
        "mongolian/element/water"
      ]
    },
    "@type": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "mongolian:Element" },
      "examples": [["mongolian:Element"]]
    },
    "name": {
      "description": "Element name in Mongolian and English.",
      "$ref": "../core/language-map.schema.json",
      "examples": [{ "mn": "мод", "en": "Wood" }]
    },
    "mongolianName": {
      "description": "Mongolian name (Cyrillic).",
      "type": "string",
      "examples": ["мод", "гал", "шороо", "төмөр", "ус"]
    },
    "mongolianTraditional": {
      "description": "Traditional Mongolian script.",
      "type": "string"
    },
    "tibetanName": {
      "description": "Tibetan name.",
      "type": "string",
      "examples": ["ཤིང་", "མེ་", "ས་", "ལྕགས་", "ཆུ་"]
    },
    "tibetanWylie": {
      "description": "Wylie transliteration.",
      "type": "string",
      "examples": ["shing", "me", "sa", "lcags", "chu"]
    },
    "associatedOrgan": {
      "description": "Primary associated organ (zang-fu pair).",
      "type": "object",
      "properties": {
        "zang": { "type": "string", "description": "Yin organ" },
        "fu": { "type": "string", "description": "Yang organ" }
      },
      "_documentation": {
        "wood": "Liver / Gallbladder",
        "fire": "Heart / Small Intestine",
        "earth": "Spleen / Stomach",
        "metal": "Lung / Large Intestine",
        "water": "Kidney / Bladder"
      }
    },
    "associatedSeason": {
      "description": "Associated season.",
      "type": "string",
      "enum": ["spring", "summer", "late-summer", "autumn", "winter"]
    },
    "associatedColor": {
      "description": "Associated color.",
      "type": "string",
      "examples": ["green", "red", "yellow", "white", "black/blue"]
    },
    "climate": {
      "description": "Associated climate/weather.",
      "type": "string",
      "examples": ["wind", "heat", "dampness", "dryness", "cold"]
    },
    "emotion": {
      "description": "Associated emotion.",
      "type": "string",
      "examples": ["anger", "joy", "worry", "grief", "fear"]
    },
    "tissue": {
      "description": "Associated tissue/manifestation.",
      "type": "string",
      "examples": ["tendons", "blood vessels", "muscles", "skin/hair", "bones"]
    },
    "senseOrgan": {
      "description": "Associated sense organ.",
      "type": "string",
      "examples": ["eyes", "tongue", "mouth", "nose", "ears"]
    },
    "generatesElement": {
      "description": "Element generated by this element (production cycle).",
      "$ref": "../core/iri-reference.schema.json"
    },
    "controlsElement": {
      "description": "Element controlled by this element (control cycle).",
      "$ref": "../core/iri-reference.schema.json"
    }
  },
  "additionalProperties": true,
  "_documentation": {
    "iriPattern": "mongolian/element/{slug}",
    "directory": "systems/mongolian/reference/elements.jsonld",
    "fiveElements": {
      "wood": {
        "mongolian": "мод",
        "tibetan": "ཤིང་",
        "organ": "Liver/Gallbladder",
        "season": "Spring",
        "climate": "Wind",
        "emotion": "Anger",
        "tissue": "Tendons/Nails",
        "sense": "Eyes"
      },
      "fire": {
        "mongolian": "гал",
        "tibetan": "མེ་",
        "organ": "Heart/Small Intestine",
        "season": "Summer",
        "climate": "Heat",
        "emotion": "Joy",
        "tissue": "Blood/Vessels",
        "sense": "Tongue"
      },
      "earth": {
        "mongolian": "шороо",
        "tibetan": "ས་",
        "organ": "Spleen/Stomach",
        "season": "Late Summer",
        "climate": "Dampness",
        "emotion": "Worry",
        "tissue": "Muscles",
        "sense": "Mouth"
      },
      "metal": {
        "mongolian": "төмөр",
        "tibetan": "ལྕགས་",
        "organ": "Lung/Large Intestine",
        "season": "Autumn",
        "climate": "Dryness",
        "emotion": "Grief",
        "tissue": "Skin/Hair",
        "sense": "Nose"
      },
      "water": {
        "mongolian": "ус",
        "tibetan": "ཆུ་",
        "organ": "Kidney/Bladder",
        "season": "Winter",
        "climate": "Cold",
        "emotion": "Fear",
        "tissue": "Bones",
        "sense": "Ears"
      }
    }
  }
}
