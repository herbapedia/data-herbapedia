{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://herbapedia.org/schema/json-schema/reference/persian-temperament.schema.json",
  "title": "Persian Temperament",
  "description": "Traditional Persian Medicine temperament (مزاج - Mizaj). The four primary temperaments result from combinations of Hot/Cold with Wet/Dry. Each temperament has specific physiological and psychological characteristics.",
  "type": "object",
  "allOf": [
    { "$ref": "./reference-entity.schema.json" }
  ],
  "required": ["@id", "@type", "name"],
  "properties": {
    "@id": {
      "description": "Unique identifier: persian/temperament/{slug}.",
      "type": "string",
      "pattern": "^persian/temperament/[a-z0-9-]+$",
      "examples": [
        "persian/temperament/hot-dry",
        "persian/temperament/hot-wet",
        "persian/temperament/cold-dry",
        "persian/temperament/cold-wet"
      ]
    },
    "@type": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "persian:Temperament" },
      "examples": [["persian:Temperament"]]
    },
    "name": {
      "description": "Temperament name in Persian and English.",
      "$ref": "../core/language-map.schema.json",
      "examples": [{ "fa": "گرم و خشک", "en": "Hot and Dry" }]
    },
    "persianName": {
      "description": "Persian name.",
      "type": "string",
      "examples": ["گرم و خشک", "گرم و تر", "سرد و خشک", "سرد و تر"]
    },
    "transliteration": {
      "description": "Transliteration.",
      "type": "string",
      "examples": ["Garm-o-Khoshk", "Garm-o-Tar", "Sard-o-Khoshk", "Sard-o-Tar"]
    },
    "heat": {
      "description": "Heat quality.",
      "type": "string",
      "enum": ["hot", "cold"]
    },
    "moisture": {
      "description": "Moisture quality.",
      "type": "string",
      "enum": ["wet", "dry"]
    },
    "associatedElement": {
      "description": "Primary associated element.",
      "$ref": "../core/iri-reference.schema.json"
    },
    "physiologicalCharacteristics": {
      "description": "Physical characteristics of this temperament.",
      "type": "array",
      "items": { "type": "string" }
    },
    "psychologicalCharacteristics": {
      "description": "Mental/emotional characteristics.",
      "type": "array",
      "items": { "type": "string" }
    },
    "associatedHumor": {
      "description": "Associated humoral fluid (Akhlat).",
      "type": "string",
      "enum": ["dam", "balgham", "safra", "sauda"],
      "_documentation": {
        "dam": "Blood (خون) - Hot and Wet",
        "balgham": "Phlegm (بلغم) - Cold and Wet",
        "safra": "Yellow Bile (صفرا) - Hot and Dry",
        "sauda": "Black Bile (سودا) - Cold and Dry"
      }
    },
    "indications": {
      "description": "Conditions where this temperament is beneficial.",
      "type": "array",
      "items": { "type": "string" }
    },
    "contraindications": {
      "description": "Conditions where this temperament should be avoided.",
      "type": "array",
      "items": { "type": "string" }
    },
    "balancingFoods": {
      "description": "Foods that balance this temperament.",
      "type": "array",
      "items": { "type": "string" }
    },
    "oppositeTemperament": {
      "description": "The opposite temperament.",
      "$ref": "../core/iri-reference.schema.json"
    },
    "tcmEquivalent": {
      "description": "Approximate TCM nature equivalent.",
      "$ref": "../core/iri-reference.schema.json"
    },
    "ayurvedaEquivalent": {
      "description": "Approximate Ayurvedic concept equivalent.",
      "type": "string"
    }
  },
  "additionalProperties": true,
  "_documentation": {
    "iriPattern": "persian/temperament/{slug}",
    "directory": "systems/persian/reference/temperaments.jsonld",
    "fourTemperaments": {
      "hot-dry": {
        "persian": "گرم و خشک",
        "element": "Fire (آتش)",
        "humor": "Yellow Bile (صفرا)",
        "characteristics": ["Quick thinking", "Sharp memory", "Slender build", "Warm skin"],
        "excess": "Anger, inflammation, dryness"
      },
      "hot-wet": {
        "persian": "گرم و تر",
        "element": "Air (هوا)",
        "humor": "Blood (خون)",
        "characteristics": ["Social", "Optimistic", "Rosy complexion", "Good digestion"],
        "excess": "Excess heat, moisture, inflammation"
      },
      "cold-dry": {
        "persian": "سرد و خشک",
        "element": "Earth (خاک)",
        "humor": "Black Bile (سودا)",
        "characteristics": ["Analytical", "Detail-oriented", "Thin", "Cool skin"],
        "excess": "Anxiety, depression, dryness"
      },
      "cold-wet": {
        "persian": "سرد و تر",
        "element": "Water (آب)",
        "humor": "Phlegm (بلغم)",
        "characteristics": ["Calm", "Patient", "Sturdy build", "Cool moist skin"],
        "excess": "Lethargy, weight gain, congestion"
      }
    }
  }
}
