{
  "@context": {
    "@version": 1.1,
    "@base": "https://www.herbapedia.org/",
    "@vocab": "https://www.herbapedia.org/vocab/unani/",

    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",

    "schema": "https://schema.org/",
    "dc": "http://purl.org/dc/terms/",
    "wd": "http://www.wikidata.org/entity/",

    "herbapedia": "https://www.herbapedia.org/vocab/core/",
    "tcm": "https://www.herbapedia.org/vocab/tcm/",
    "ayurveda": "https://www.herbapedia.org/vocab/ayurveda/",
    "western": "https://www.herbapedia.org/vocab/western/",
    "unani": "https://www.herbapedia.org/vocab/unani/",
    "mongolian": "https://www.herbapedia.org/vocab/mongolian/",

    "id": "@id",
    "type": "@type",
    "graph": "@graph",

    // =========================================================================
    // Unani Medicine Core Vocabulary
    // =========================================================================

    "UnaniHerb": {
      "@id": "unani:Herb",
      "@type": "@id"
    },
    "UnaniDrug": {
      "@id": "unani:Drug",
      "@type": "@id"
    },
    "UnaniProfile": {
      "@id": "unani:Profile",
      "@type": "@id"
    },

    // =========================================================================
    // Unani Medicine Properties
    // =========================================================================

    /**
     * Mizaj (Temperament)
     * The fundamental quality of a substance in Unani Medicine
     * Defined as the interaction of four qualities: Hot/Cold × Wet/Dry
     *
     * Examples:
     * - Hot-Wet (e.g., Aniseed)
     * - Hot-Dry (e.g., Ginger)
     * - Cold-Wet (e.g., Lettuce)
     * - Cold-Dry (e.g., Sandalwood)
     */
    "hasTemperament": {
      "@id": "unani:hasTemperament",
      "@type": "@id"
    },

    /**
     * Element (Arkan)
     * The four elements that constitute all matter
     */
    "hasElement": {
      "@id": "unani:hasElement",
      "@type": "@id"
    },

    /**
     * Degree (Darjah)
     * The intensity of a quality, ranked from 1st to 4th degree
     * 1st: Mild effect, 4th: Extreme effect
     */
    "hasDegree": {
      "@id": "unani:hasDegree",
      "@type": "@id"
    },

    /**
     * Unani Quality (Kayfiyyah)
     * Individual qualities: Hot, Cold, Wet, Dry
     */
    "hasQuality": {
      "@id": "unani:hasQuality",
      "@type": "@id",
      "@container": "@set"
    },

    /**
     * Mizaj Balance Quality
     * The quality (Hot/Cold/Wet/Dry) that dominates in the temperament
     */
    "balanceQuality": {
      "@id": "unani:balanceQuality",
      "@type": "xsd:string"
    },

    /**
     * Unani Dosage Form (Shorbat, Syrup, etc.)
     */
    "unaniDosageForm": {
      "@id": "unani:dosageForm",
      "@type": "xsd:string"
    },

    /**
     * Tadbīr (Correction/Modification)
     * Methods to modify the temperament of a substance
     */
    "hasTadbir": {
      "@id": "unani:hasTadbir",
      "@type": "@id",
      "@container": "@set"
    },

    /**
     * Mohallil (Anti-inflammatory)
     */
    "isMohallil": {
      "@id": "unani:isMohallil",
      "@type": "xsd:boolean"
    },

    /**
     * Mufattih (Deobstruent)
     * Opens obstructions
     */
    "isMufattih": {
      "@id": "unani:isMufattih",
      "@type": "xsd:boolean"
    },

    /**
     * Mudirr (Emmenagogue)
     * Promotes menstrual flow
     */
    "isMudirr": {
      "@id": "unani:isMudirr",
      "@type": "xsd:boolean"
    },

    /**
     * Muqawwi (Tonic)
     * Strengthens the body
     */
    "isMuqawwi": {
      "@id": "unani:isMuqawwi",
      "@type": "xsd:boolean"
    },

    /**
     * Mukhaddir (Narcotic/Sedative)
     */
    "isMukhaddir": {
      "@id": "unani:isMukhaddir",
      "@type": "xsd:boolean"
    },

    /**
     * Mugharri (Carminative)
     * Expels gas
     */
    "isMugharri": {
      "@id": "unani:isMugharri",
      "@type": "xsd:boolean"
    },

    /**
     * Mulayyin (Laxative)
     */
    "isMulayyin": {
      "@id": "unani:isMulayyin",
      "@type": "xsd:boolean"
    },

    /**
     * Musakkin (Analgesic/Antipyretic)
     */
    "isMusakkin": {
      "@id": "unani:isMusakkin",
      "@type": "xsd:boolean"
    },

    /**
     * Mu`allid (Emetic)
     */
    "isMuallid": {
      "@id": "unani:isMuallid",
      "@type": "xsd:boolean"
    },

    /**
     * Munzij (Concoctive)
     * Turns morbid humors into mature form
     */
    "isMunzij": {
      "@id": "unani:isMunzij",
      "@type": "xsd:boolean"
    },

    /**
     * Unani Name
     */
    "unaniName": {
      "@id": "unani:unaniName",
      "@container": "@language"
    },

    /**
     * Arabic Name (if different from Unani)
     */
    "arabicName": {
      "@id": "unani:arabicName",
      "@container": "@language"
    },

    /**
     * Unani Name (used in Greco-Arabic medicine)
     */
    "unaniName": {
      "@id": "unani:unaniName",
      "@container": "@language"
    },

    /**
     * Source Chapter in Canon of Medicine
     * The chapter in Avicenna's Canon where this substance is discussed
     */
    "canonChapter": {
      "@id": "unani:canonChapter",
      "@type": "xsd:string"
    },

    /**
     * Canon of Medicine Quote
     */
    "canonQuote": {
      "@id": "unani:canonQuote",
      "@container": "@language"
    },

    /**
     * Makhzan al-Adwiya Reference
     * Reference to the Makhzan al-Adwiya (Storehouse of Medicaments)
     */
    "makhzanReference": {
      "@id": "unani:makhzanReference",
      "@type": "xsd:string"
    },

    /**
     * Al-Tasrif Reference
     * Reference to Al-Tasrif by Al-Zahrawi
     */
    "tasrifReference": {
      "@id": "unani:tasrifReference",
      "@type": "xsd:string"
    },

    /**
     * Action on Akhlat (Humors)
     * Affects blood, phlegm, yellow bile, black bile
     */
    "actionOnAkhlat": {
      "@id": "unani:actionOnAkhlat",
      "@container": "@set"
    },

    /**
     * Action on A`da (Organs)
     */
    "actionOnAda": {
      "@id": "unani:actionOnAda",
      "@type": "@id",
      "@container": "@set"
    },

    /**
     * Recommended for Quwa (Faculties)
     * Mental faculties: common sense, imagination, cognition, memory
     */
    "recommendedForQuwa": {
      "@id": "unani:recommendedForQuwa",
      "@container": "@set"
    },

    /**
     * Beneficial for Umoor Tabi`iyyah
     * Natural functions: nutrition, growth, reproduction
     */
    "beneficialForUmoorTabiiyya": {
      "@id": "unani:beneficialForUmoorTabiiyya",
      "@container": "@set"
    },

    /**
     * Unani Traditional Usage
     */
    "unaniTraditionalUsage": {
      "@id": "unani:traditionalUsage",
      "@container": "@language"
    },

    /**
     * Unani Modern Research
     */
    "unaniModernResearch": {
      "@id": "unani:modernResearch",
      "@container": "@language"
    },

    /**
     * Unani Clinical Notes
     */
    "unaniClinicalNotes": {
      "@id": "unani:clinicalNotes",
      "@container": "@language"
    },

    /**
     * Unani Contraindications
     */
    "unaniContraindications": {
      "@id": "unani:contraindications",
      "@container": "@language"
    },

    /**
     * Unani Dosage
     */
    "unaniDosage": {
      "@id": "unani:dosage",
      "@container": "@language"
    },

    /**
     * Substitution (Abdal)
     * Substances that can substitute for each other
     */
    "substitutes": {
      "@id": "unani:substitutes",
      "@type": "@id",
      "@container": "@set"
    },

    // =========================================================================
    // Reference Vocabulary Terms
    // =========================================================================

    /**
     * Temperament Value
     * Controlled vocabulary for Mizaj values
     */
    "temperamentValue": {
      "@id": "unani:temperamentValue",
      "@type": "xsd:string"
    },

    /**
     * Element Value
     */
    "elementValue": {
      "@id": "unani:elementValue",
      "@type": "xsd:string"
    },

    /**
     * Degree Value (1-4)
     */
    "degreeValue": {
      "@id": "unani:degreeValue",
      "@type": "xsd:integer"
    },

    /**
     * Quality Value (Hot, Cold, Wet, Dry)
     */
    "qualityValue": {
      "@id": "unani:qualityValue",
      "@type": "xsd:string"
    },

    /**
     * Quality Strength (1-4)
     */
    "qualityStrength": {
      "@id": "unani:qualityStrength",
      "@type": "xsd:integer"
    },

    /**
     * Tadbir (Correction Method)
     */
    "tadbirValue": {
      "@id": "unani:tadbirValue",
      "@type": "xsd:string"
    },

    // =========================================================================
    // Common Properties from Core
    // =========================================================================

    "name": {
      "@id": "schema:name",
      "@container": "@language"
    },
    "description": {
      "@id": "schema:description",
      "@container": "@language"
    },
    "alternateName": {
      "@id": "schema:alternateName",
      "@container": "@set"
    },
    "image": {
      "@id": "schema:image",
      "@type": "@id"
    },
    "sameAs": {
      "@id": "schema:sameAs",
      "@type": "@id",
      "@container": "@set"
    },
    "source": {
      "@id": "dc:source",
      "@type": "xsd:string"
    },
    "sourceUrl": {
      "@id": "dc:source",
      "@type": "xsd:anyURI"
    },
    "creator": {
      "@id": "dc:creator",
      "@type": "xsd:string"
    },
    "created": {
      "@id": "dc:created",
      "@type": "xsd:dateTime"
    },
    "modified": {
      "@id": "dc:modified",
      "@type": "xsd:dateTime"
    },
    "license": {
      "@id": "dc:license",
      "@type": "@id"
    },

    "prefLabel": {
      "@id": "skos:prefLabel",
      "@container": "@language"
    },
    "altLabel": {
      "@id": "skos:altLabel",
      "@container": "@set"
    },
    "definition": {
      "@id": "skos:definition",
      "@container": "@language"
    },
    "broader": {
      "@id": "skos:broader",
      "@type": "@id",
      "@container": "@set"
    },
    "narrower": {
      "@id": "skos:narrower",
      "@type": "@id",
      "@container": "@set"
    },
    "related": {
      "@id": "skos:related",
      "@type": "@id",
      "@container": "@set"
    }
  }
}
