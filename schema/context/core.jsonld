{
  "@context": {
    "@version": 1.1,
    "@base": "https://www.herbapedia.org/",
    "@vocab": "https://www.herbapedia.org/vocab/core/",

    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "skos": "http://www.w3.org/2004/02/skos/core#",

    "schema": "https://schema.org/",
    "dc": "http://purl.org/dc/terms/",
    "dwc": "http://rs.tdwg.org/dwc/terms/",
    "gbif": "http://rs.gbif.org/terms/1.0/",

    "wd": "http://www.wikidata.org/entity/",
    "wdt": "http://www.wikidata.org/prop/direct/",

    "herbapedia": "https://www.herbapedia.org/vocab/core/",
    "tcm": "https://www.herbapedia.org/vocab/tcm/",
    "ayurveda": "https://www.herbapedia.org/vocab/ayurveda/",
    "western": "https://www.herbapedia.org/vocab/western/",
    "unani": "https://www.herbapedia.org/vocab/unani/",
    "mongolian": "https://www.herbapedia.org/vocab/mongolian/",
    "botany": "https://www.herbapedia.org/vocab/botany/",
    "mycology": "https://www.herbapedia.org/vocab/mycology/",
    "phycology": "https://www.herbapedia.org/vocab/phycology/",
    "herbal": "https://www.herbapedia.org/vocab/herbal/",

    "id": "@id",
    "type": "@type",
    "graph": "@graph",

    "MedicinalPlant": {
      "@id": "herbapedia:MedicinalPlant",
      "@type": "@id"
    },
    "ChemicalCompound": {
      "@id": "herbapedia:ChemicalCompound",
      "@type": "@id"
    },
    "PlantPart": {
      "@id": "herbapedia:PlantPart",
      "@type": "@id"
    },
    "PharmacologicalAction": {
      "@id": "herbapedia:PharmacologicalAction",
      "@type": "@id"
    },
    "HerbariumSpecimen": {
      "@id": "herbapedia:HerbariumSpecimen",
      "@type": "@id"
    },
    "Media": {
      "@id": "herbapedia:Media",
      "@type": "@id"
    },
    "Document": {
      "@id": "herbapedia:Document",
      "@type": "@id"
    },
    "Index": {
      "@id": "herbapedia:Index",
      "@type": "@id"
    },

    "SourceMaterial": {
      "@id": "herbapedia:SourceMaterial",
      "@type": "@id",
      "@description": "Abstract base class for all source materials used in herbal medicine"
    },
    "BotanicalSource": {
      "@id": "herbapedia:BotanicalSource",
      "@type": "@id",
      "@description": "Source materials from plants, fungi, or algae"
    },
    "ZoologicalSource": {
      "@id": "herbapedia:ZoologicalSource",
      "@type": "@id",
      "@description": "Source materials from animal products (antler, shell, nest, etc.)"
    },
    "MineralSource": {
      "@id": "herbapedia:MineralSource",
      "@type": "@id",
      "@description": "Source materials from minerals (calcium, iron, zinc, etc.)"
    },
    "ChemicalSource": {
      "@id": "herbapedia:ChemicalSource",
      "@type": "@id",
      "@description": "Source materials that are isolated compounds (vitamins, amino acids, etc.)"
    },
    "Formula": {
      "@id": "herbapedia:Formula",
      "@type": "@id",
      "@description": "Proprietary blends or standardized preparations containing multiple ingredients"
    },

    "sourceType": {
      "@id": "herbapedia:sourceType",
      "@type": "xsd:string",
      "@description": "The primary category of a source material: botanical, zoological, mineral, or chemical"
    },
    "sourceSubType": {
      "@id": "herbapedia:sourceSubType",
      "@type": "xsd:string"
    },
    "animalName": {
      "@id": "herbapedia:animalName",
      "@container": "@language"
    },
    "animalScientificName": {
      "@id": "herbapedia:animalScientificName",
      "@type": "xsd:string"
    },
    "animalPart": {
      "@id": "herbapedia:animalPart",
      "@type": "xsd:string"
    },
    "chemicalSubType": {
      "@id": "herbapedia:chemicalSubType",
      "@type": "xsd:string"
    },
    "formulaCode": {
      "@id": "herbapedia:formulaCode",
      "@type": "xsd:string"
    },
    "proprietaryName": {
      "@id": "herbapedia:proprietaryName",
      "@container": "@language"
    },
    "hasIngredients": {
      "@id": "herbapedia:hasIngredients",
      "@type": "@id",
      "@container": "@set"
    },
    "standardizedTo": {
      "@id": "herbapedia:standardizedTo",
      "@type": "@json"
    },
    "intendedUse": {
      "@id": "herbapedia:intendedUse",
      "@container": "@language"
    },
    "applicationMethod": {
      "@id": "herbapedia:applicationMethod",
      "@container": "@language"
    },
    "manufacturer": {
      "@id": "herbapedia:manufacturer",
      "@type": "xsd:string"
    },

    "gcmtiCode": {
      "@id": "herbapedia:gcmtiCode",
      "@type": "xsd:string"
    },
    "coordinates": {
      "@id": "herbapedia:coordinates",
      "@type": "@json"
    },
    "origin": {
      "@id": "herbapedia:origin",
      "@container": "@language"
    },
    "hasImages": {
      "@id": "herbapedia:hasImages",
      "@type": "@id",
      "@container": "@set"
    },
    "hasMedia": {
      "@id": "herbapedia:hasMedia",
      "@type": "@id",
      "@container": "@set"
    },
    "hasAnnotations": {
      "@id": "herbapedia:hasAnnotations",
      "@container": "@set"
    },
    "representsPlant": {
      "@id": "herbapedia:representsPlant",
      "@type": "@id"
    },
    "contentUrl": {
      "@id": "schema:contentUrl",
      "@type": "@id"
    },
    "thumbnailUrl": {
      "@id": "schema:thumbnailUrl",
      "@type": "@id"
    },
    "encodingFormat": {
      "@id": "schema:encodingFormat",
      "@type": "xsd:string"
    },
    "documentType": {
      "@id": "herbapedia:documentType",
      "@type": "xsd:string"
    },
    "filename": {
      "@id": "herbapedia:filename",
      "@type": "xsd:string"
    },
    "hasExtractedData": {
      "@id": "herbapedia:hasExtractedData",
      "@type": "@id"
    },
    "counts": {
      "@id": "herbapedia:counts",
      "@type": "@json"
    },
    "generated": {
      "@id": "dc:created",
      "@type": "xsd:dateTime"
    },

    "name": {
      "@id": "schema:name",
      "@container": "@language"
    },
    "description": {
      "@id": "schema:description",
      "@container": "@language"
    },
    "alternateName": {
      "@id": "schema:alternateName",
      "@container": "@set"
    },

    "scientificName": {
      "@id": "dwc:scientificName",
      "@type": "xsd:string"
    },
    "family": {
      "@id": "dwc:family",
      "@type": "xsd:string"
    },
    "genus": {
      "@id": "dwc:genus",
      "@type": "xsd:string"
    },
    "species": {
      "@id": "dwc:specificEpithet",
      "@type": "xsd:string"
    },
    "taxonID": {
      "@id": "dwc:taxonID",
      "@type": "xsd:string"
    },
    "gbifID": {
      "@id": "gbif:GBIFID",
      "@type": "xsd:string"
    },

    "image": {
      "@id": "schema:image",
      "@type": "@id"
    },
    "url": {
      "@id": "schema:url",
      "@type": "@id"
    },

    "sameAs": {
      "@id": "schema:sameAs",
      "@type": "@id",
      "@container": "@set"
    },
    "isRelatedTo": {
      "@id": "schema:isRelatedTo",
      "@type": "@id",
      "@container": "@set"
    },
    "isSimilarTo": {
      "@id": "schema:isSimilarTo",
      "@type": "@id",
      "@container": "@set"
    },

    "hasPart": {
      "@id": "herbapedia:hasPart",
      "@type": "@id",
      "@container": "@set"
    },
    "partOf": {
      "@id": "herbapedia:partOf",
      "@type": "@id"
    },
    "containsChemical": {
      "@id": "herbapedia:containsChemical",
      "@type": "@id",
      "@container": "@set"
    },
    "hasPharmacologicalAction": {
      "@id": "herbapedia:hasPharmacologicalAction",
      "@type": "@id",
      "@container": "@set"
    },

    "hasLifeStage": {
      "@id": "herbapedia:hasLifeStage",
      "@type": "@id",
      "@container": "@set",
      "@description": "Links a species to its life stages (spores, mycelium, fruiting body, etc.)"
    },
    "isLifeStageOf": {
      "@id": "herbapedia:isLifeStageOf",
      "@type": "@id",
      "@description": "Links a life stage form to its parent species"
    },
    "hasForm": {
      "@id": "herbapedia:hasForm",
      "@type": "@id",
      "@container": "@set",
      "@description": "Links a species to its forms (juvenile, adult, flowering, fruiting, etc.)"
    },
    "isFormOf": {
      "@id": "herbapedia:isFormOf",
      "@type": "@id",
      "@description": "Links a form to its parent species"
    },
    "produces": {
      "@id": "herbapedia:produces",
      "@type": "@id",
      "@container": "@set",
      "@description": "Links an organism or part to what it produces (e.g., fruiting body produces spores)"
    },
    "producedBy": {
      "@id": "herbapedia:producedBy",
      "@type": "@id",
      "@description": "Links a product to its producer"
    },
    "isProcessedFrom": {
      "@id": "herbapedia:isProcessedFrom",
      "@type": "@id",
      "@description": "Links a processed product to its raw material (e.g., shoudihuang from dihuang)"
    },
    "processedInto": {
      "@id": "herbapedia:processedInto",
      "@type": "@id",
      "@container": "@set",
      "@description": "Links a raw material to its processed forms"
    },
    "isExtractOf": {
      "@id": "herbapedia:isExtractOf",
      "@type": "@id",
      "@description": "Links an extract (oil, tincture, etc.) to its source material"
    },
    "hasExtract": {
      "@id": "herbapedia:hasExtract",
      "@type": "@id",
      "@container": "@set",
      "@description": "Links a source material to its extracts"
    },

    "slug": {
      "@id": "herbapedia:slug",
      "@type": "xsd:string"
    },
    "commonName": {
      "@id": "herbapedia:commonName",
      "@container": "@language"
    },

    "botanicalDescription": {
      "@id": "herbapedia:botanicalDescription",
      "@container": "@language"
    },
    "geographicalDistribution": {
      "@id": "herbapedia:geographicalDistribution",
      "@container": "@language"
    },
    "foodSources": {
      "@id": "herbapedia:foodSources",
      "@container": "@set"
    },

    "source": {
      "@id": "dc:source",
      "@type": "xsd:string"
    },
    "sourceUrl": {
      "@id": "dc:source",
      "@type": "xsd:anyURI"
    },
    "creator": {
      "@id": "dc:creator",
      "@type": "xsd:string"
    },
    "created": {
      "@id": "dc:created",
      "@type": "xsd:dateTime"
    },
    "modified": {
      "@id": "dc:modified",
      "@type": "xsd:dateTime"
    },
    "license": {
      "@id": "dc:license",
      "@type": "@id"
    },
    "spdxId": {
      "@id": "herbapedia:spdxId",
      "@type": "xsd:string"
    },
    "spdxUrl": {
      "@id": "herbapedia:spdxUrl",
      "@type": "@id"
    },
    "attribution": {
      "@id": "herbapedia:attribution",
      "@type": "@id"
    },
    "copyright": {
      "@id": "dc:rights",
      "@type": "xsd:string"
    },
    "creator": {
      "@id": "dc:creator",
      "@type": "xsd:string"
    },
    "sourceUrl": {
      "@id": "dc:source",
      "@type": "@id"
    },

    "inLanguage": {
      "@id": "schema:inLanguage",
      "@type": "xsd:string"
    },

    "category": {
      "@id": "schema:category",
      "@type": "@id"
    },

    "prefLabel": {
      "@id": "skos:prefLabel",
      "@container": "@language"
    },
    "altLabel": {
      "@id": "skos:altLabel",
      "@container": "@set"
    },
    "definition": {
      "@id": "skos:definition",
      "@container": "@language"
    },
    "broader": {
      "@id": "skos:broader",
      "@type": "@id",
      "@container": "@set"
    },
    "narrower": {
      "@id": "skos:narrower",
      "@type": "@id",
      "@container": "@set"
    },
    "related": {
      "@id": "skos:related",
      "@type": "@id",
      "@container": "@set"
    }
  }
}
