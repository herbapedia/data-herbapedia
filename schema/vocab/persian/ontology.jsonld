{
  "@context": {
    "@version": 1.1,
    "@base": "https://www.herbapedia.org/vocab/persian/",

    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "schema": "https://schema.org/",

    "herbapedia": "https://www.herbapedia.org/vocab/core/",
    "persian": "https://www.herbapedia.org/vocab/persian/"
  },

  "@graph": [
    {
      "@id": "https://www.herbapedia.org/vocab/persian/",
      "@type": "owl:Ontology",
      "rdfs:label": {
        "en": "Herbapedia Traditional Persian Medicine Vocabulary"
      },
      "rdfs:comment": "Traditional Persian Medicine (TPM) vocabulary including drug profiles, temperament (Mizaj), elements, and degrees."
    },

    {
      "@id": "persian:Drug",
      "@type": "owl:Class",
      "rdfs:subClassOf": ["herbapedia:MedicineSystemProfile", "schema:DietarySupplement"],
      "rdfs:label": {
        "en": "Persian Drug",
        "zh-Hant": "波斯藥物",
        "fa": "دارو"
      },
      "rdfs:comment": "A Traditional Persian Medicine drug profile with temperament (Mizaj), degree, and therapeutic properties based on Ibn Sina's Canon of Medicine."
    },

    {
      "@id": "persian:Temperament",
      "@type": "owl:Class",
      "rdfs:subClassOf": "skos:Concept",
      "rdfs:label": {
        "en": "Temperament (Mizaj)",
        "zh-Hant": "體質",
        "fa": "مزاج"
      },
      "rdfs:comment": "The four fundamental temperaments combining Hot/Cold with Wet/Dry: Hot-Wet, Hot-Dry, Cold-Wet, Cold-Dry."
    },

    {
      "@id": "persian:Element",
      "@type": "owl:Class",
      "rdfs:subClassOf": "skos:Concept",
      "rdfs:label": {
        "en": "Element (Arkān)",
        "zh-Hant": "元素",
        "fa": "عناصر"
      },
      "rdfs:comment": "The four fundamental elements (Arkan): Fire (Nar), Air (Hawa), Water (Ab), Earth (Khak)."
    },

    {
      "@id": "persian:Degree",
      "@type": "owl:Class",
      "rdfs:subClassOf": "skos:Concept",
      "rdfs:label": {
        "en": "Degree (Darajah)",
        "zh-Hant": "等級",
        "fa": "درجه"
      },
      "rdfs:comment": "The potency level from 1 (mild) to 4 (very strong). Indicates the intensity of the temperament."
    },

    {
      "@id": "persian:Humor",
      "@type": "owl:Class",
      "rdfs:subClassOf": "skos:Concept",
      "rdfs:label": {
        "en": "Humor (Akhlat)",
        "zh-Hant": "體液",
        "fa": "اخلاط"
      },
      "rdfs:comment": "The four humors: Blood (Dam), Phlegm (Balgham), Yellow Bile (Safra), Black Bile (Sauda)."
    },

    {
      "@id": "persian:Organ",
      "@type": "owl:Class",
      "rdfs:subClassOf": "skos:Concept",
      "rdfs:label": {
        "en": "Organ (A'dha)",
        "zh-Hant": "器官"
      },
      "rdfs:comment": "Body organs in Persian medicine: Heart, Brain, Liver, etc."
    },

    {
      "@id": "persian:hasTemperament",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "persian:Drug",
      "rdfs:range": "persian:Temperament",
      "rdfs:label": {
        "en": "has temperament",
        "zh-Hant": "具有體質"
      }
    },

    {
      "@id": "persian:hasElement",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "persian:Drug",
      "rdfs:range": "persian:Element",
      "rdfs:label": {
        "en": "has element",
        "zh-Hant": "具有元素"
      }
    },

    {
      "@id": "persian:hasDegree",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "persian:Drug",
      "rdfs:range": "persian:Degree",
      "rdfs:label": {
        "en": "has degree",
        "zh-Hant": "具有等級"
      }
    },

    {
      "@id": "persian:affectsHumor",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "persian:Drug",
      "rdfs:range": "persian:Humor",
      "rdfs:label": {
        "en": "affects humor",
        "zh-Hant": "影響體液"
      }
    },

    {
      "@id": "persian:affectsOrgan",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "persian:Drug",
      "rdfs:range": "persian:Organ",
      "rdfs:label": {
        "en": "affects organ",
        "zh-Hant": "影響器官"
      }
    },

    {
      "@id": "persian:persianName",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "persian:Drug",
      "rdfs:range": "rdfs:Literal",
      "rdfs:label": {
        "en": "Persian name",
        "zh-Hant": "波斯文名稱"
      }
    },

    {
      "@id": "persian:derivedFromPlant",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "persian:Drug",
      "rdfs:range": "herbapedia:BotanicalSource",
      "rdfs:label": {
        "en": "derived from plant",
        "zh-Hant": "來自植物"
      }
    },

    {
      "@id": "persian:persianTraditionalUsage",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "persian:Drug",
      "rdfs:range": "rdfs:Literal",
      "rdfs:label": {
        "en": "Persian traditional usage",
        "zh-Hant": "波斯傳統用法"
      }
    },

    {
      "@id": "persian:persianModernResearch",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "persian:Drug",
      "rdfs:range": "rdfs:Literal",
      "rdfs:label": {
        "en": "Persian modern research",
        "zh-Hant": "波斯現代研究"
      }
    }
  ]
}
