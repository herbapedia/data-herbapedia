{
  "@context": {
    "@version": 1.1,
    "@base": "https://www.herbapedia.org/vocab/core/",

    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "herbapedia": "https://www.herbapedia.org/vocab/core/",
    "botany": "https://www.herbapedia.org/vocab/botany/",
    "herbal": "https://www.herbapedia.org/vocab/herbal/"
  },

  "@graph": [

    // ========================================================================
    // ROOT CLASSES
    // ========================================================================

    {
      "@id": "herbapedia:Entity",
      "@type": "owl:Class",
      "rdfs:label": {
        "en": "Entity",
        "zh-Hant": "實體"
      },
      "rdfs:comment": "The root class for all Herbapedia entities."
    },

    {
      "@id": "herbapedia:SourceMaterial",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:Entity",
      "rdfs:label": {
        "en": "Source Material",
        "zh-Hant": "來源物質"
      },
      "rdfs:comment": "Abstract base class for all source materials used in herbal medicine, including plants, animals, minerals, and chemicals."
    },

    // ========================================================================
    // SOURCE MATERIAL SUBTYPES
    // ========================================================================

    {
      "@id": "herbapedia:BotanicalSource",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:SourceMaterial",
      "rdfs:label": {
        "en": "Botanical Source",
        "zh-Hant": "植物來源"
      },
      "rdfs:comment": "Source materials derived from plants, fungi, or algae."
    },

    {
      "@id": "herbapedia:ZoologicalSource",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:SourceMaterial",
      "rdfs:label": {
        "en": "Zoological Source",
        "zh-Hant": "動物來源"
      },
      "rdfs:comment": "Source materials derived from animal products (antler, shell, nest, etc.)."
    },

    {
      "@id": "herbapedia:MineralSource",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:SourceMaterial",
      "rdfs:label": {
        "en": "Mineral Source",
        "zh-Hant": "礦物來源"
      },
      "rdfs:comment": "Source materials derived from minerals (calcium, iron, zinc, etc.)."
    },

    {
      "@id": "herbapedia:ChemicalSource",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:SourceMaterial",
      "rdfs:label": {
        "en": "Chemical Source",
        "zh-Hant": "化學來源"
      },
      "rdfs:comment": "Source materials that are isolated or synthesized chemical compounds (vitamins, amino acids, etc.)."
    },

    {
      "@id": "herbapedia:Formula",
      "@type": "owl:Class",
      "rdfs:subClassOf": "schema:Product",
      "rdfs:label": {
        "en": "Formula",
        "zh-Hant": "配方"
      },
      "rdfs:comment": "Proprietary blends or standardized preparations containing multiple ingredients."
    },

    // ========================================================================
    // BOTANY CLASSES
    // ========================================================================

    {
      "@id": "botany:PlantSpecies",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:BotanicalSource",
      "rdfs:label": {
        "en": "Plant Species",
        "zh-Hant": "植物物種"
      },
      "rdfs:comment": "A plant species entity containing botanical facts (taxonomy, distribution, morphology)."
    },

    {
      "@id": "botany:FungalSpecies",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:BotanicalSource",
      "rdfs:label": {
        "en": "Fungal Species",
        "zh-Hant": "真菌物種"
      },
      "rdfs:comment": "A fungal species (mushrooms, etc.) used in herbal medicine."
    },

    {
      "@id": "phycology:AlgalSpecies",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:BotanicalSource",
      "rdfs:label": {
        "en": "Algal Species",
        "zh-Hant": "藻類物種"
      },
      "rdfs:comment": "An algal species used in herbal medicine."
    },

    {
      "@id": "herbapedia:PlantPart",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:BotanicalSource",
      "rdfs:label": {
        "en": "Plant Part",
        "zh-Hant": "植物部位"
      },
      "rdfs:comment": "A specific part of a specific plant (root, leaf, stem, etc.)."
    },

    {
      "@id": "herbapedia:ChemicalCompound",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:Entity",
      "rdfs:label": {
        "en": "Chemical Compound",
        "zh-Hant": "化學化合物"
      },
      "rdfs:comment": "A molecular entity (flavonoid, alkaloid, polysaccharide, etc.)."
    },

    // ========================================================================
    // HERBAL PREPARATION
    // ========================================================================

    {
      "@id": "herbal:HerbalPreparation",
      "@type": "owl:Class",
      "rdfs:subClassOf": ["schema:Product", "schema:DietarySupplement"],
      "rdfs:label": {
        "en": "Herbal Preparation",
        "zh-Hant": "草藥製劑"
      },
      "rdfs:comment": "The central pivot entity - a substance prepared from botanical sources for therapeutic or culinary use."
    },

    {
      "@id": "herbapedia:MedicineSystemProfile",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:Entity",
      "rdfs:label": {
        "en": "Medicine System Profile",
        "zh-Hant": "醫藥系統檔案"
      },
      "rdfs:comment": "Abstract base class for all medicine system-specific herb profiles (Modern Medicine, TCM, Western, Ayurveda, Persian, Mongolian)."
    },

    // ========================================================================
    // MODERN MEDICINE PROFILE CLASS
    // ========================================================================

    {
      "@id": "modern:SubstanceProfile",
      "@type": "owl:Class",
      "rdfs:subClassOf": "herbapedia:MedicineSystemProfile",
      "rdfs:label": {
        "en": "Modern Medicine Profile",
        "zh-Hant": "現代醫學檔案"
      },
      "rdfs:comment": "Evidence-based clinical profile for substances used in modern medicine, including vitamins, minerals, amino acids, and pharmaceuticals."
    },

    // Disjoint class declarations for SourceMaterial hierarchy
    {
      "@id": "herbapedia:BotanicalSource",
      "owl:disjointWith": ["herbapedia:ZoologicalSource", "herbapedia:MineralSource", "herbapedia:ChemicalSource"]
    },
    {
      "@id": "herbapedia:ZoologicalSource",
      "owl:disjointWith": ["herbapedia:MineralSource", "herbapedia:ChemicalSource"]
    },
    {
      "@id": "herbapedia:MineralSource",
      "owl:disjointWith": ["herbapedia:ChemicalSource"]
    },

    // ========================================================================
    // CORE PROPERTIES
    // ========================================================================

    {
      "@id": "herbapedia:hasPart",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbapedia:BotanicalSource",
      "rdfs:range": "herbapedia:PlantPart",
      "rdfs:label": {
        "en": "has part"
      },
      "rdfs:comment": "Links a botanical source to its parts."
    },

    {
      "@id": "herbapedia:partOf",
      "@type": "owl:ObjectProperty",
      "owl:inverseOf": "herbapedia:hasPart",
      "rdfs:label": {
        "en": "is part of"
      }
    },

    {
      "@id": "herbapedia:containsChemical",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbapedia:BotanicalSource",
      "rdfs:range": "herbapedia:ChemicalCompound",
      "rdfs:label": {
        "en": "contains chemical"
      },
      "rdfs:comment": "Links a botanical source to chemicals it contains."
    },

    {
      "@id": "herbapedia:foundIn",
      "@type": "owl:ObjectProperty",
      "owl:inverseOf": "herbapedia:containsChemical",
      "rdfs:label": {
        "en": "found in"
      }
    },

    {
      "@id": "herbal:derivedFrom",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbal:HerbalPreparation",
      "rdfs:range": "herbapedia:SourceMaterial",
      "rdfs:label": {
        "en": "derived from"
      },
      "rdfs:comment": "Links a preparation to its source material(s)."
    },

    {
      "@id": "herbapedia:hasExtract",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbapedia:SourceMaterial",
      "rdfs:range": "herbal:HerbalPreparation",
      "rdfs:label": {
        "en": "has extract"
      },
      "rdfs:comment": "Links a source material to its extracts (oils, tinctures, etc.)."
    },

    {
      "@id": "herbapedia:isExtractOf",
      "@type": "owl:ObjectProperty",
      "owl:inverseOf": "herbapedia:hasExtract",
      "rdfs:label": {
        "en": "is extract of"
      }
    },

    {
      "@id": "herbapedia:hasLifeStage",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbapedia:BotanicalSource",
      "rdfs:range": "herbapedia:BotanicalSource",
      "rdfs:label": {
        "en": "has life stage"
      },
      "rdfs:comment": "Links a species to its life stages (spores, mycelium, fruiting body, etc.)."
    },

    {
      "@id": "herbapedia:isProcessedFrom",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbal:HerbalPreparation",
      "rdfs:range": "herbal:HerbalPreparation",
      "rdfs:label": {
        "en": "is processed from"
      },
      "rdfs:comment": "Links a processed preparation to its raw material."
    },

    {
      "@id": "herbapedia:hasProcessedForm",
      "@type": "owl:ObjectProperty",
      "owl:inverseOf": "herbapedia:isProcessedFrom",
      "rdfs:label": {
        "en": "has processed form"
      }
    },

    {
      "@id": "herbapedia:isSourceOf",
      "@type": "owl:ObjectProperty",
      "owl:inverseOf": "herbal:derivedFrom",
      "rdfs:label": {
        "en": "is source of"
      }
    },

    {
      "@id": "herbapedia:isLifeStageOf",
      "@type": "owl:ObjectProperty",
      "owl:inverseOf": "herbapedia:hasLifeStage",
      "rdfs:label": {
        "en": "is life stage of"
      }
    },

    {
      "@id": "herbapedia:isImageOf",
      "@type": "owl:ObjectProperty",
      "owl:inverseOf": "herbapedia:hasImages",
      "rdfs:label": {
        "en": "is image of"
      }
    },

    {
      "@id": "herbapedia:hasProfile",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbal:HerbalPreparation",
      "rdfs:range": "herbapedia:MedicineSystemProfile",
      "rdfs:label": {
        "en": "has profile"
      },
      "rdfs:comment": "Links a preparation to its system-specific profile."
    },

    {
      "@id": "herbapedia:isProfileOf",
      "@type": "owl:ObjectProperty",
      "owl:inverseOf": "herbapedia:hasProfile",
      "rdfs:label": {
        "en": "is profile of"
      }
    },

    {
      "@id": "herbapedia:hasChemicalProfile",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbapedia:BotanicalSource",
      "rdfs:range": "botany:ChemicalProfile",
      "rdfs:label": {
        "en": "has chemical profile"
      },
      "rdfs:comment": "Links a botanical source to its chemical analysis profile."
    },

    {
      "@id": "herbapedia:isChemicalProfileOf",
      "@type": "owl:ObjectProperty",
      "owl:inverseOf": "herbapedia:hasChemicalProfile",
      "rdfs:label": {
        "en": "is chemical profile of"
      }
    },

    // ========================================================================
    // TAXONOMY AND CLASSIFICATION PROPERTIES
    // ========================================================================

    {
      "@id": "botany:hasFamily",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "botany:PlantSpecies",
      "rdfs:range": "botany:Family",
      "rdfs:label": {
        "en": "has family"
      },
      "rdfs:comment": "Links a plant species to its taxonomic family."
    },

    {
      "@id": "botany:hasGenus",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "botany:PlantSpecies",
      "rdfs:range": "botany:Genus",
      "rdfs:label": {
        "en": "has genus"
      },
      "rdfs:comment": "Links a plant species to its genus."
    },

    {
      "@id": "botany:memberOf",
      "@type": "owl:ObjectProperty",
      "owl:inverseOf": "botany:hasFamily",
      "rdfs:label": {
        "en": "member of"
      }
    },

    // ========================================================================
    // MEDICINE SYSTEM PROFILE PROPERTIES
    // ========================================================================

    {
      "@id": "herbapedia:derivedFromPlant",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbapedia:MedicineSystemProfile",
      "rdfs:range": "herbapedia:BotanicalSource",
      "rdfs:label": {
        "en": "derived from plant"
      },
      "rdfs:comment": "Links a medicine system profile to its source botanical material."
    },

    {
      "@id": "herbapedia:hasCategory",
      "@type": "owl:ObjectProperty",
      "rdfs:label": {
        "en": "has category"
      },
      "rdfs:comment": "Links a herb to its medicinal category (e.g., tonic, purgative)."
    },

    {
      "@id": "herbapedia:hasNature",
      "@type": "owl:ObjectProperty",
      "rdfs:label": {
        "en": "has nature"
      },
      "rdfs:comment": "Links a herb to its thermal nature (hot, warm, neutral, cool, cold)."
    },

    {
      "@id": "herbapedia:hasFlavor",
      "@type": "owl:ObjectProperty",
      "rdfs:label": {
        "en": "has flavor"
      },
      "rdfs:comment": "Links a herb to its taste/flavor (sweet, bitter, sour, salty, pungent)."
    },

    {
      "@id": "herbapedia:entersMeridian",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:range": "tcm:Meridian",
      "rdfs:label": {
        "en": "enters meridian"
      },
      "rdfs:comment": "Links a TCM herb to the meridians it affects."
    },

    {
      "@id": "herbapedia:hasAction",
      "@type": "owl:ObjectProperty",
      "rdfs:label": {
        "en": "has action"
      },
      "rdfs:comment": "Links a herb to its therapeutic action."
    },

    {
      "@id": "herbapedia:hasOrganAffinity",
      "@type": "owl:ObjectProperty",
      "rdfs:label": {
        "en": "has organ affinity"
      },
      "rdfs:comment": "Links a herb to the organs/systems it primarily affects."
    },

    {
      "@id": "herbapedia:affectsDosha",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "ayurveda:Dravya",
      "rdfs:range": "ayurveda:Dosha",
      "rdfs:label": {
        "en": "affects dosha"
      },
      "rdfs:comment": "Links an Ayurvedic substance to the doshas it affects."
    },

    {
      "@id": "herbapedia:hasRasa",
      "@type": "owl:ObjectProperty",
      "rdfs:label": {
        "en": "has rasa"
      },
      "rdfs:comment": "Links an Ayurvedic substance to its rasa (taste)."
    },

    {
      "@id": "herbapedia:hasGuna",
      "@type": "owl:ObjectProperty",
      "rdfs:label": {
        "en": "has guna"
      },
      "rdfs:comment": "Links an Ayurvedic substance to its guna (quality)."
    },

    {
      "@id": "herbapedia:hasVirya",
      "@type": "owl:ObjectProperty",
      "rdfs:label": {
        "en": "has virya"
      },
      "rdfs:comment": "Links an Ayurvedic substance to its virya (potency)."
    },

    {
      "@id": "herbapedia:hasVipaka",
      "@type": "owl:ObjectProperty",
      "rdfs:label": {
        "en": "has vipaka"
      },
      "rdfs:comment": "Links an Ayurvedic substance to its vipaka (post-digestive effect)."
    },

    // ========================================================================
    // MEDIA AND IMAGES
    // ========================================================================

    {
      "@id": "herbapedia:Image",
      "@type": "owl:Class",
      "rdfs:subClassOf": "schema:ImageObject",
      "rdfs:label": {
        "en": "Image",
        "zh-Hant": "圖像"
      },
      "rdfs:comment": "An image file with associated metadata including attribution and licensing."
    },

    {
      "@id": "herbapedia:ImageMetadata",
      "@type": "owl:Class",
      "rdfs:label": {
        "en": "Image Metadata",
        "zh-Hant": "圖像元數據"
      },
      "rdfs:comment": "Metadata for an image including attribution, licensing (SPDX), and source information."
    },

    {
      "@id": "herbapedia:Attribution",
      "@type": "owl:Class",
      "rdfs:label": {
        "en": "Attribution",
        "zh-Hant": "署名"
      },
      "rdfs:comment": "Copyright and license attribution information for media assets."
    },

    {
      "@id": "herbapedia:hasImages",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbapedia:Entity",
      "rdfs:range": "herbapedia:Image",
      "rdfs:label": {
        "en": "has images"
      },
      "rdfs:comment": "Links an entity to its associated images."
    },

    {
      "@id": "herbapedia:hasMetadata",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbapedia:Image",
      "rdfs:range": "herbapedia:ImageMetadata",
      "rdfs:label": {
        "en": "has metadata"
      },
      "rdfs:comment": "Links an image to its metadata."
    },

    {
      "@id": "herbapedia:hasAttribution",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbapedia:ImageMetadata",
      "rdfs:range": "herbapedia:Attribution",
      "rdfs:label": {
        "en": "has attribution"
      },
      "rdfs:comment": "Links image metadata to attribution information."
    },

    // ========================================================================
    // SPDX AND LICENSING PROPERTIES
    // ========================================================================

    {
      "@id": "herbapedia:spdxId",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "herbapedia:Attribution",
      "rdfs:range": "xsd:string",
      "rdfs:label": {
        "en": "SPDX ID"
      },
      "rdfs:comment": "SPDX License Identifier (e.g., CC0-1.0, CC-BY-SA-3.0, NONE for all-rights-reserved)."
    },

    {
      "@id": "herbapedia:spdxUrl",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "herbapedia:Attribution",
      "rdfs:range": "xsd:anyURI",
      "rdfs:label": {
        "en": "SPDX URL"
      },
      "rdfs:comment": "URL to the SPDX license definition at spdx.org."
    },

    {
      "@id": "herbapedia:fileName",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "herbapedia:ImageMetadata",
      "rdfs:range": "xsd:string",
      "rdfs:label": {
        "en": "file name"
      },
      "rdfs:comment": "Name of the image file."
    },

    {
      "@id": "herbapedia:downloaded",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "herbapedia:ImageMetadata",
      "rdfs:range": "xsd:date",
      "rdfs:label": {
        "en": "downloaded"
      },
      "rdfs:comment": "Date when the image was downloaded/acquired."
    },

    // ========================================================================
    // TCM SPECIFIC PROPERTIES
    // ========================================================================

    {
      "@id": "tcm:pinyin",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:range": "xsd:string",
      "rdfs:label": {
        "en": "pinyin"
      },
      "rdfs:comment": "Pinyin romanization of the Chinese herb name."
    },

    {
      "@id": "tcm:chineseName",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:label": {
        "en": "Chinese name"
      },
      "rdfs:comment": "Chinese character name of the herb."
    },

    {
      "@id": "tcm:latinPharmaceuticalName",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:range": "xsd:string",
      "rdfs:label": {
        "en": "Latin pharmaceutical name"
      },
      "rdfs:comment": "Latin pharmaceutical name of the herb."
    },

    {
      "@id": "tcm:medicinalPart",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:label": {
        "en": "medicinal part"
      },
      "rdfs:comment": "Part of the plant used medicinally."
    },

    {
      "@id": "tcm:processingMethod",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:range": "xsd:string",
      "rdfs:label": {
        "en": "processing method"
      },
      "rdfs:comment": "Method of processing the herb (pao zhi)."
    },

    {
      "@id": "tcm:actions",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:label": {
        "en": "actions"
      },
      "rdfs:comment": "TCM therapeutic actions."
    },

    {
      "@id": "tcm:indications",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:label": {
        "en": "indications"
      },
      "rdfs:comment": "Conditions for which the herb is indicated."
    },

    {
      "@id": "tcm:contraindications",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:label": {
        "en": "contraindications"
      },
      "rdfs:comment": "Conditions where use is contraindicated."
    },

    {
      "@id": "tcm:dosage",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:label": {
        "en": "dosage"
      },
      "rdfs:comment": "Recommended dosage range."
    },

    {
      "@id": "tcm:preparation",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:label": {
        "en": "preparation"
      },
      "rdfs:comment": "Preparation instructions."
    },

    {
      "@id": "tcm:combinesWith",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:range": "tcm:Herb",
      "rdfs:label": {
        "en": "combines with"
      },
      "rdfs:comment": "Herbs commonly combined with this herb."
    },

    {
      "@id": "tcm:comparesTo",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": "tcm:Herb",
      "rdfs:range": "tcm:Herb",
      "rdfs:label": {
        "en": "compares to"
      },
      "rdfs:comment": "Herbs with similar properties for comparison."
    },

    {
      "@id": "tcm:adverseReaction",
      "@type": "owl:DatatypeProperty",
