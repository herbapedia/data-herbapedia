{
  "name": "@herbapedia/data",
  "version": "1.0.0",
  "description": "JSON-LD Knowledge Graph for medicinal botany - the authoritative Herbapedia data repository with TypeScript API",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./graph-browser": {
      "types": "./src/graph/browser/index.ts",
      "default": "./src/graph/browser/index.ts"
    },
    "./types": {
      "types": "./types/index.ts",
      "default": "./types/index.ts"
    },
    "./types/*": {
      "types": "./types/*.ts",
      "default": "./types/*.ts"
    },
    "./api/v1/graph/*": "./api/v1/graph/*.jsonld",
    "./api/v1/node/*": "./api/v1/node/*/*.jsonld",
    "./schema/context/*": "./schema/context/*.jsonld",
    "./schema/json-schema/*": "./schema/json-schema/*.json",
    "./entities/*": "./entities/*",
    "./systems/*": "./systems/*"
  },
  "files": [
    "src",
    "types",
    "schema",
    "entities",
    "systems",
    "media",
    "api/v1"
  ],
  "scripts": {
    "validate": "node scripts/validate.js",
    "build-index": "node scripts/build-index.js",
    "build-graph": "node --import tsx scripts/build-graph.ts",
    "build": "npm run build-index && npm run build-graph",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "herbapedia",
    "medicinal-plants",
    "herbal-medicine",
    "tcm",
    "traditional-chinese-medicine",
    "ayurveda",
    "json-ld",
    "linked-data",
    "semantic-web",
    "botanical",
    "pharmacognosy",
    "knowledge-graph"
  ],
  "author": "Herbapedia",
  "license": "CC-BY-SA-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/herbapedia/data-herbapedia.git"
  },
  "bugs": {
    "url": "https://github.com/herbapedia/data-herbapedia/issues"
  },
  "homepage": "https://herbapedia.org",
  "devDependencies": {
    "@types/lunr": "^2.3.7",
    "@types/node": "^20.0.0",
    "ajv": "^8.12.0",
    "jsonld": "^8.3.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "lunr": "^2.3.9"
  }
}
