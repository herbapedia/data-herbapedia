  "description": {
    "en": "The aerial stems of the ginger plant, growing erect to 30-100 cm tall. Composed of leaf sheaths wrapped around a central pseudostem."
  },
  "morphology": {
    "en": "Erect, unbranched pseudostem composed of tightly wrapped leaf sheaths. Each pseudostem produces 10-20 leaves."
  },
