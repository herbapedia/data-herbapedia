  "description": {
    "en": "The bright red drupaceous berries of ginseng, containing 1-3 flattened seeds. Rich in ginsenosides and studied for potential health benefits."
  },
  "morphology": {
    "en": "Bright red, globose drupe, 5-10 mm diameter. Contains 1-3 flattened, white seeds. Produced in umbel after flowering."
  },
