  "partType": "leaf",
  "description": {
    "en": "The simple, lanceolate leaves of the ginger plant, growing alternately along the pseudostem."
  },
  "morphology": {
    "en": "Lanceolate, 15-30 cm long, 2-5 cm wide. Dark green above, lighter green below. Tip acute, base tapering. Sheathing at base, no petiole."
  },
  "constituents": [
    {
      "name": "Essential Oil",
      "percentage": "0.004-0.04%",
      "notes": "Lower concentration than rhizome"
    }
  ],
