  "description": {
    "en": "The large, oblong leaves of turmeric, growing to 30-40 cm long. Used in traditional medicine and also as a wrapping for food in some cuisines."
  },
  "morphology": {
    "en": "Oblong-lanceolate, 30-40 cm long, 10-15 cm wide. Green above, lighter below. Entire margin, parallel venation typical of monocots."
  },
