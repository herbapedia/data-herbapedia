  "name": {
    "en": "Ginseng",
    "zh-Hant": "人蔘",
    "zh-Hans": "人参",
    "ko": "인삼",
    "ja": "人参"
  },
  "scientificName": "Panax ginseng",
  "family": "Araliaceae",
  "genus": "Panax",
  "description": {
    "en": "A slow-growing perennial plant native to the mountainous forests of East Asia. The root has been used medicinally for thousands of years.",
    "zh-Hant": "人蔘（學名：Panax ginseng）為多年生草本植物，以其根部入藥。在中醫藥理論中歸屬於補益類藥物，具有補氣養血、健脾益肺等功效，是重要的傳統中藥材。",
    "zh-Hans": "人参（学名：Panax ginseng）为多年生草本植物，以其根部入药。在中医药理論中歸属于补益类药物，具有补气养血、健脾益肺等功效，是重要的传统中药材。"
  },
  "commonName": {
    "en": "Asian Ginseng, Korean Ginseng",
    "zh-Hant": "高麗蔘",
    "ko": "고려인삼",
    "zh-Hans": "人参"
  },
  "botanicalDescription": {
    "en": "Panax ginseng is a perennial herb growing 30-60 cm tall. The plant has a fleshy root that can live for over 100 years. Leaves are compound with 5 leaflets arranged in a palmate pattern. Small white flowers bloom in summer, followed by red berries."
  },
  "geographicalDistribution": {
    "en": "Native to mountainous regions of Korea, Northeast China (Manchuria), and far eastern Russia. Cultivated extensively in Korea, China, and Japan."
  },
