  "description": {
    "en": "Complex mixtures of volatile organic compounds extracted from plants, primarily terpenes, terpenoids, and aromatic compounds. Responsible for the distinctive fragrances of aromatic plants. Widely used in aromatherapy, traditional medicine, and as antimicrobial agents."
  },
  "pharmacology": [
    "Antimicrobial activity (antibacterial, antifungal, antiviral)",
    "Anti-inflammatory effects",
    "Antispasmodic properties",
    "Carminative effects",
    "Sedative and anxiolytic activity",
    "Expectorant action"
  ],
  "bioavailability": {
    "en": "Highly lipophilic; rapidly absorbed through skin, mucous membranes, and respiratory tract. Can cross blood-brain barrier."
  },
