  "description": {
    "en": "A large and diverse class of naturally occurring organic compounds derived from the five-carbon isoprene unit. Include monoterpenes, sesquiterpenes, diterpenes, triterpenes, and tetraterpenes. Form the basis for many essential oils and have diverse biological activities."
  },
  "pharmacology": [
    "Anti-inflammatory activity",
    "Antimicrobial effects",
    "Anticancer properties",
    "Neuroprotective effects",
    "Hepatoprotective activity",
    "Sedative and anxiolytic properties"
  ],
  "bioavailability": {
    "en": "Lipophilic; well absorbed through skin and mucous membranes; volatiles absorbed via respiratory tract."
  },
  "safetyData": {
    "toxicity": "Generally low toxicity at therapeutic doses",
    "warnings": [
      "Some terpenes may cause skin irritation",
      "Essential oil concentrates require dilution"
