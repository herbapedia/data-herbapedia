    "Antioxidant activity",
    "Hypoglycemic effects",
    "Anti-tumor activity",
    "Gastroprotective effects"
  ],
  "bioavailability": {
    "en": "Not absorbed intact but interact with gut-associated lymphoid tissue (GALT)"
  },
