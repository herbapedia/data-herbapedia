  "chebiID": "CHEBI:72544",
  "compoundClass": "Polyphenols; Flavonoids",
  "description": {
    "en": "A diverse group of plant polyphenolic compounds with a characteristic C6-C3-C6 carbon skeleton. Responsible for vibrant colors in plants and possess significant antioxidant, anti-inflammatory, and immunomodulatory properties. One of the largest classes of plant secondary metabolites with over 6,000 known varieties."
  },
  "pharmacology": [
    "Potent antioxidant activity (free radical scavenging)",
    "Anti-inflammatory effects (COX-2 inhibition)",
    "Cardiovascular protection",
    "Neuroprotective properties",
    "Antiviral and antibacterial activity",
    "Estrogenic and anti-estrogenic effects"
  ],
  "bioavailability": {
    "en": "Variable bioavailability depending on specific flavonoid type. Generally poorly absorbed, metabolized by gut microbiota. Enhanced by vitamin C co-consumption."
  },
  "safetyData": {
    "toxicity": "Generally safe when consumed in dietary amounts",
    "warnings": [
      "High dose supplements may interact with certain medications"
    ]
  },
