  "description": {
    "en": "Glycosylamines consisting of a nitrogenous base bound to a ribose or deoxyribose sugar. In medicinal fungi like Cordyceps, bioactive nucleosides such as cordycepin and adenosine exhibit various pharmacological activities."
  },
  "pharmacology": [
    "Energy metabolism support (ATP production)",
    "Immunomodulatory effects",
    "Anti-inflammatory activity",
    "Antiviral properties",
    "Neuroprotective effects",
    "Cardiovascular support"
  ],
  "bioavailability": {
    "en": "Well absorbed orally; metabolized to nucleotides and nucleic acids; some nucleosides cross blood-brain barrier."
  },
