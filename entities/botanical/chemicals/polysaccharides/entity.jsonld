  "chebiID": "CHEBI:18154",
  "compoundClass": "Carbohydrates; Polysaccharides",
  "description": {
    "en": "Long-chain carbohydrate molecules composed of multiple monosaccharide units linked by glycosidic bonds. In medicinal plants, polysaccharides often exhibit immunomodulatory, anti-tumor, and antioxidant activities. Key bioactive compounds in many traditional medicines."
  },
  "pharmacology": [
    "Immunomodulation (macrophage activation, cytokine induction)",
    "Anti-tumor activity",
    "Antioxidant effects",
    "Hypoglycemic activity",
    "Gut microbiota modulation",
    "Antiviral activity"
  ],
  "bioavailability": {
    "en": "Generally poorly absorbed intact; exert effects primarily through gut-associated lymphoid tissue (GALT) and microbiota fermentation to short-chain fatty acids."
  },
  "safetyData": {
    "toxicity": "Generally safe",
    "warnings": [
      "May cause gastrointestinal discomfort in sensitive individuals"
    ]
  },
