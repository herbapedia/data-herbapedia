  "commonName": [
    "Tannins",
    "Tannic acid",
    "Plant polyphenols"
  ],
  "chebiID": "CHEBI:26848",
  "compoundClass": "Polyphenols; Tannins",
  "description": {
    "en": "Water-soluble polyphenolic compounds with molecular weights ranging from 500 to over 3000 Daltons. Capable of precipitating proteins and alkaloids. Classified into hydrolyzable tannins (gallotannins, ellagitannins) and condensed tannins (proanthocyanidins)."
  },
  "pharmacology": [
    "Astringent activity (protein precipitation)",
    "Antioxidant effects",
    "Antimicrobial activity",
    "Anti-diarrheal effects",
    "Wound healing promotion",
    "Metal chelation"
  ],
  "bioavailability": {
    "en": "Poorly absorbed; primarily exert local effects in the gastrointestinal tract. Metabolized by gut microbiota to smaller phenolic compounds."
  },
  "safetyData": {
    "toxicity": "Generally safe in dietary amounts",
    "warnings": [
      "May interfere with mineral absorption (iron)",
      "High intake may cause digestive upset",
      "May reduce absorption of certain medications"
    ]
  },
