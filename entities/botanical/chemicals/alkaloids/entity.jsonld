  "description": {
    "en": "A large class of nitrogenous organic compounds of plant origin with pronounced physiological action on humans and other animals. Over 12,000 alkaloids have been identified. Divided into true alkaloids (nitrogen in heterocyclic ring), protoalkaloids, and pseudoalkaloids."
  },
  "pharmacology": [
    "CNS stimulation or depression",
    "Analgesic effects",
    "Antispasmodic activity",
    "Antimalarial properties",
    "Anticancer activity (certain types)",
    "Cardiovascular effects"
  ],
  "bioavailability": {
    "en": "Generally well absorbed orally; extensive first-pass metabolism for many alkaloids. Crosses blood-brain barrier readily due to lipophilicity."
  },
  "safetyData": {
    "toxicity": "Variable; many alkaloids are toxic at relatively low doses",
    "warnings": [
      "Many alkaloids require medical supervision",
      "Potential for drug interactions",
      "Some are controlled substances"
    ]
