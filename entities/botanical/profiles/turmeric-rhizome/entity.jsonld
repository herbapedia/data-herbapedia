      "notes": "Main curcuminoid; provides yellow color and most therapeutic effects"
    },
    {
      "compound": {
        "@id": "https://www.herbapedia.org/entity/botanical/chemical/turmerone"
      },
      "relativeAbundance": "major",
      "concentrationRange": {
        "min": 15,
        "max": 40,
        "unit": "% of essential oil"
      },
      "notes": "Main volatile compound in turmeric oil; includes α-turmerone, β-turmerone, ar-turmerone"
    },
    {
      "compound": {
        "@id": "https://www.herbapedia.org/entity/botanical/chemical/essential-oils"
      },
      "concentrationRange": {
        "min": 2.5,
        "max": 6,
        "unit": "%"
      },
      "detectionMethod": "GC-MS",
      "notes": "Contains turmerones, zingiberene, α-phellandrene, cineole"
