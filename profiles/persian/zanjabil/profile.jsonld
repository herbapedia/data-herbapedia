    "en": "Ginger",
    "fa": "زنجبیل",
    "ar": "زنجبيل"
  },
  "persianName": "زنجبیل",
  "persianTransliteration": "Zanjabil",
  "arabicName": "زنجبيل",
  "derivedFromPlant": {
    "@id": "https://www.herbapedia.org/entity/botanical/species/ginger"
  },
  "hasTemperament": {
    "@id": "https://www.herbapedia.org/system/persian/profile/temperament/hot-dry"
