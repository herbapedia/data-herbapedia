  "tcmFunctions": {
    "en": "- Releases exterior and disperses cold\n- Warms the middle and stops vomiting\n- Warms the lung and resolves phlegm\n- Detoxifies",
    "zh-Hant": "發汗解表，溫中止嘔，溫肺止咳，解毒",
    "zh-Hans": "發汗解表，溫中止嘔，溫肺止咳，解毒"
  },
  "tcmTraditionalUsage": {
    "en": "Fresh Ginger (Sheng Jiang) is primarily used to:\n\n- Release exterior and disperse cold\n- Warm the middle and stop vomiting\n- Warm the lung and resolve phlegm\n- Detoxify fish, crab, and other toxins",
    "zh-Hant": "生薑發汗解表，溫中止嘔，溫肺止咳。用於風寒感冒、胃寒嘔吐、寒痰咳嗽、魚蟹中毒。",
    "zh-Hans": "生薑發汗解表，溫中止嘔，溫肺止咳。用于風寒感冒、胃寒嘔吐、寒痰咳嗽、魚蟹中毒。"
  },
  "tcmHistory": {
    "en": "Ginger has been cultivated for over 5,000 years. In TCM, fresh and dried ginger are considered distinct herbs with different properties and indications.",
    "zh-Hant": "生薑入藥始見於《名醫別錄》。《本草綱目》載：「薑，辛而不葷，去邪辟惡，生啖熟食，醋、醬、糟、鹽、蜜煎調和，無不宜之。」",
    "zh-Hans": "生薑入药始見于《名医別录》。《本草綱目》载：「薑，辛而不葷，去邪辟惡，生啖熟食，醋、醬、糟、鹽、蜜煎调和，無不宜之。」"
  },
  "indications": [
    "Exterior cold pattern",
    "Common cold with chills",
    "Nausea and vomiting",
    "Cough with white phlegm",
    "Fish and crab detoxification"
  ],
  "contraindications": {
    "en": "Contraindicated in Yin deficiency with heat signs, lung heat cough.",
    "zh-Hant": "陰虛內熱、肺熱咳嗽者忌用。",
    "zh-Hans": "阴虚內热、肺热咳嗽者忌用。"
  },
  "dosage": {
    "en": "3-10g decocted; 15-30g for detoxification.",
    "zh-Hant": "煎服3-10克；解毒15-30克。",
    "zh-Hans": "煎服3-10克；解毒15-30克。"
  },
